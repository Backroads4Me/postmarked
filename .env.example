# ============================================================================
# Postmarked environment configuration
# Copy .env.example to .env. The defaults below work for local development.
# Change the REQUIRED PRODUCTION values before any public deployment.
# ============================================================================

# ── Required in production ───────────────────────────────────────────────────
# APP_ENV controls security defaults.
#   dev  — SECRET_KEY may fall back to an insecure default; cookies are not Secure.
#   prod — SECRET_KEY is required; cookies are Secure (HTTPS required).
APP_ENV=dev

# Required when APP_ENV=prod. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme

# Public browser URL. Must start with https:// in production.
APP_BASE_URL=http://localhost:4321

# Admin account. Change ADMIN_PASSWORD before any real deployment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_DISPLAY_NAME=Admin

# Database password. Change before any real deployment.
POSTGRES_PASSWORD=changeme

# ── Safe development defaults ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_DB=postmarked

# IANA timezone for admin upload and log timestamps.
PUBLIC_ADMIN_TIMEZONE=America/New_York

# Container image tag to pull from GHCR.
IMAGE_TAG=latest

# Keep uploaded originals after derivative processing.
MEDIA_KEEP_ORIGINALS=false

# Media volume mount (holds originals/, derivatives/, ingest/, backups/, db_data/).
MEDIA_DIR=./data

# Database backup schedule (daily pg_dump).
BACKUP_HOUR=3
BACKUP_MINUTE=0
BACKUP_RETENTION=7

# Redis URL used by Celery.
REDIS_URL=redis://redis:6379/0

# ── Optional integrations ─────────────────────────────────────────────────────
# SMTP — leave blank to disable email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Postmarked
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true

# Google Maps — leave blank to disable map features.
PUBLIC_GOOGLE_MAPS_API_KEY=
PUBLIC_GOOGLE_MAPS_MAP_ID=

# ── Less-used settings ────────────────────────────────────────────────────────
# Internal API URL for direct frontend dev (Docker compose uses its own default).
API_BASE_URL=http://api:8000
