# ============================================================================
# Postmarked Environment Configuration
# Copy this file to .env and adjust values as needed.
# ============================================================================

# ── Application Environment ──────────────────────────────────────────────────

# APP_ENV controls security defaults. Set to "prod" before exposing the app.
# In "dev" mode: SECRET_KEY may be missing (insecure fallback used), session cookies are not Secure.
# In "prod": SECRET_KEY is required, cookies are Secure (HTTPS required).
APP_ENV=dev
IMAGE_TAG=latest

# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme

# Allowed Origin headers for state-changing requests (CSRF defense).
# Comma-separated list. Must include the URL the browser uses to load the frontend.
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:8000

# Allowed Host headers (TrustedHostMiddleware). Add your domain in production.
ALLOWED_HOSTS=localhost,127.0.0.1,api,web

# ── Admin account ─────────────────────────────────────────────────────────────────

# Seeded local admin account after running api/scripts/seed.py.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_DISPLAY_NAME=Admin

# ── Storage Mounts ──────────────────────────────────────────────────────────

# By default, Compose uses Docker named volumes (e.g., db_data, originals).
# Uncomment and set local paths below to use host bind mounts instead.
#
# IMPORTANT: If you uncomment DB_SOURCE, the host directory must be writable 
# by UID 70 (the postgres user inside the Alpine container). 
# Run `mkdir -p .db_data && sudo chown -R 70:70 .db_data` before starting.
#
# ORIGINALS_SOURCE=./data/originals
# DERIVATIVES_SOURCE=./data/derivatives
# INGEST_SOURCE=./data/ingest
# DB_SOURCE=.db_data

# ── Application URLs ────────────────────────────────────────────────────────

# EXTERNAL: The public URL where this application is hosted.
# Change this in production (e.g., https://postmarked.mydomain.com).
# The API uses this to generate absolute links for emails and OAuth callbacks.
APP_BASE_URL=http://localhost:4321

# INTERNAL: Used by the Web container to fetch data from the API container.
# Do NOT change this. It uses Docker's internal network resolution.
API_BASE_URL=http://api:8000

# ── External APIs ───────────────────────────────────────────────────────────

# Required for map functionality in the web frontend.
PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional. Advanced Google map styling/markers use a Map ID; the app uses
# Google's demo map ID for local testing when this is blank.
PUBLIC_GOOGLE_MAPS_MAP_ID=

# ── Email / SMTP ────────────────────────────────────────────────────────────

# Used by the worker to send email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Postmarked
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true

# ── Database ────────────────────────────────────────────────────────────────

# Default database credentials used by the PostGIS container and the API.
POSTGRES_PASSWORD=changeme
POSTGRES_USER=postgres
POSTGRES_DB=postmarked

# ── Flower (Celery Monitoring UI) ───────────────────────────────────────────

# Basic-auth credentials for the Flower dashboard (user:password) on port 5555.
FLOWER_BASIC_AUTH=admin:changeme

# ── Redis ───────────────────────────────────────────────────────────────────

# Used by Celery for task brokering.
REDIS_URL=redis://redis:6379/0