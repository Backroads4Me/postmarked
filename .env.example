# Goodpath local/deploy configuration
#
# Copy this file to .env for Docker Compose overrides:
#   cp .env.example .env

# APP_ENV controls security defaults. Set to "production" before exposing the app.
# In "dev" mode: SECRET_KEY may be missing (insecure fallback used), session cookies are not Secure.
# In any other value: SECRET_KEY is required, cookies are Secure (HTTPS required).
APP_ENV=dev

# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-a-long-random-string

# Allowed Origin headers for state-changing requests (CSRF defense).
# Comma-separated list. Must include the URL the browser uses to load the frontend.
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:8000

# Allowed Host headers (TrustedHostMiddleware). Add your domain in production.
ALLOWED_HOSTS=localhost,127.0.0.1,api,web

# ── Database ────────────────────────────────────────────────────────────────

# Default database values used by compose.yaml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=goodpath

# Full async connection URL consumed by the API/worker. Must match POSTGRES_* above.
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/goodpath

# ── Redis ───────────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0

# ── Storage mounts ──────────────────────────────────────────────────────────

# By default Compose uses Docker named volumes: originals, derivatives, ingest.
# Uncomment these to use host bind mounts instead. Relative paths are resolved
# from compose.yaml.
# GOODPATH_ORIGINALS_SOURCE=./data/originals
# GOODPATH_DERIVATIVES_SOURCE=./data/derivatives
# GOODPATH_INGEST_SOURCE=./data/ingest

# Optional MapLibre/PMTiles basemap directory. Only used when
# PUBLIC_MAP_PROVIDER=maplibre.
GOODPATH_PMTILES_DIR=../pmtiles

# ── Web (Astro) ─────────────────────────────────────────────────────────────

# Server-side API URL used by Astro. In Docker this should stay on the compose network.
API_BASE_URL=http://api:8000

# Public base URL that the browser sees (used for absolute links / OpenGraph).
PUBLIC_BASE_URL=http://localhost

# Map provider for the browser map. Google is easiest for personal always-online
# hosting; MapLibre keeps the self-hosted PMTiles path available.
PUBLIC_MAP_PROVIDER=google
PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional. Advanced Google map styling/markers use a Map ID; the app uses
# Google's demo map ID for local testing when this is blank.
PUBLIC_GOOGLE_MAPS_MAP_ID=

# ── Flower (Celery monitoring UI) ───────────────────────────────────────────

# Basic-auth credentials for the Flower dashboard (user:password).
FLOWER_BASIC_AUTH=admin:changeme

# ── Seeding ─────────────────────────────────────────────────────────────────

# Seeded local admin account after running api/scripts/seed.py.
GOODPATH_ADMIN_EMAIL=admin@example.com
GOODPATH_ADMIN_PASSWORD=admin123
GOODPATH_ADMIN_DISPLAY_NAME=Ted & Family
