# ============================================================================
# Postmarked environment configuration
# Copy .env.example to .env, then change the required values near the top.
# ============================================================================

# -- Required security and public URL --
# APP_ENV controls security defaults. Use prod before exposing the app.
# In dev, SECRET_KEY may fall back to an insecure default and cookies are not Secure.
# In prod, SECRET_KEY is required and cookies are Secure, so HTTPS is required.
APP_ENV=dev

# Required in production. Generate with:
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme

# Public browser URL for the frontend. Used for generated links and to derive
# the default CORS/CSRF origin and trusted host.
APP_BASE_URL=http://localhost:4321

# -- Required admin account --
# Change ADMIN_PASSWORD before any real deployment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_DISPLAY_NAME=Admin

# -- Required database --
# Change POSTGRES_PASSWORD before any real deployment.
POSTGRES_PASSWORD=changeme
POSTGRES_USER=postgres
POSTGRES_DB=postmarked

# -- Common application settings --
# IANA timezone used for admin upload and log timestamps.
PUBLIC_ADMIN_TIMEZONE=America/New_York

# Optional Google Maps integration. The app works without this, but maps are disabled.
PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional Google Maps cloud map ID.
PUBLIC_GOOGLE_MAPS_MAP_ID=

# -- Email notifications --
# Optional SMTP settings used by the worker for email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Postmarked
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true

# -- Storage --
# Media volume mount.
MEDIA_DIR=./data

# -- Less-used service settings --
# Container image tag to pull from GHCR. Use latest for normal installs.
IMAGE_TAG=latest

# Keep uploaded originals after successful derivative processing.
# Set true if you want to preserve source files for later reprocessing.
MEDIA_KEEP_ORIGINALS=false

# Redis URL used by Celery task brokering.
REDIS_URL=redis://redis:6379/0

# Server-side API URL for direct frontend development.
# Docker compose normally uses its own internal default.
API_BASE_URL=http://api:8000
