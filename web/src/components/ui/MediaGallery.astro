---
/**
 * MediaGallery - Reusable media gallery for posts and stops.
 *
 * Single item: displays at natural aspect ratio, constrained by max dimensions.
 * Multiple items: compact bento grid with varied thumbnail proportions.
 */
interface MediaSummary {
  id: string;
  kind?: 'photo' | 'video' | string;
  width?: number | null;
  height?: number | null;
  blurhash?: string | null;
  dominant_color?: string | null;
  alt_text?: string | null;
  caption?: string | null;
  derivative_paths?: Record<string, string> | null;
}

interface Props {
  media: MediaSummary[];
  /** Max width of the gallery container. Default 'none' (full width). */
  maxWidth?: string;
  /** Max height for a single photo. Default '20rem'. */
  singleMaxHeight?: string;
  /** When true, use a varied bento layout for multiple photos. Default true. */
  bentoGrid?: boolean;
  /** Number of photos to show. Default 4. */
  limit?: number;
  /** When set, all tiles navigate to this URL instead of opening a lightbox. */
  linkHref?: string;
}

const { media, maxWidth = 'none', singleMaxHeight = '16rem', bentoGrid = true, limit = 4, linkHref } = Astro.props;
const allMedia = media || [];
const items = allMedia.slice(0, limit);
const hiddenCount = allMedia.length - items.length;
const isSingle = items.length === 1;
const galleryId = 'media-gallery-' + Math.random().toString(36).slice(2);
const allMediaData = JSON.stringify(allMedia.map((m: MediaSummary) => ({
  id: m.id,
  kind: m.kind || 'photo',
  alt: m.alt_text || m.caption || '',
  caption: m.caption || '',
  src: isVideo(m) ? videoSrc(m) : photoSrc(m),
  fallbackSrc: isVideo(m) ? '/media/' + m.id + '/original' : '',
  poster: isVideo(m) ? posterSrc(m) : '',
})));

function isVideo(m: MediaSummary) {
  return m.kind === 'video';
}

function photoSrc(m: MediaSummary) {
  return m.derivative_paths?.webp || '/media/' + m.id + '/webp';
}

function posterSrc(m: MediaSummary) {
  if (isVideo(m)) {
    return m.derivative_paths?.poster || '/media/' + m.id + '/poster';
  }
  return m.derivative_paths?.webp || '/media/' + m.id + '/webp';
}

function videoSrc(m: MediaSummary) {
  return m.derivative_paths?.mp4 || '/media/' + m.id + '/original';
}

function avifSrc(m: MediaSummary) {
  return m.derivative_paths?.avif || '/media/' + m.id + '/avif';
}

function hasAvif(m: MediaSummary) {
  return !!(m.derivative_paths && m.derivative_paths['avif']);
}

function webpSmSrc(m: MediaSummary) {
  return m.derivative_paths?.webp_sm || '/media/' + m.id + '/webp_sm';
}

function hasSmVariant(m: MediaSummary) {
  return !!(m.derivative_paths?.webp_sm) || ((m.width || 0) > 768 || (m.height || 0) > 768);
}


function tileStyle(m: MediaSummary) {
  const aspect = m.width && m.height ? m.width + ' / ' + m.height : '4 / 3';
  return 'aspect-ratio: ' + aspect + ';';
}

function tileClass(_m: MediaSummary) {
  return '';
}
---

{items.length > 0 && (
  <div
    id={galleryId}
    data-media-gallery
    data-all-media={allMediaData}
    class:list={[
      'media-gallery mt-3 rounded-md overflow-hidden',
      isSingle ? 'media-gallery-single' : bentoGrid ? 'media-gallery-bento' : 'media-gallery-grid',
      maxWidth !== 'none' ? maxWidth : '',
    ]}
  >
    {items.map((m: MediaSummary, index: number) => linkHref ? (
      <a
        href={linkHref}
        class:list={['media-gallery-item block overflow-hidden bg-line-soft', isSingle ? 'media-gallery-link-single' : '']}
        style={isSingle ? tileStyle(m) : undefined}
      >
        {isSingle ? (
          <picture>
            {!isVideo(m) && hasAvif(m) && <source type="image/avif" srcset={avifSrc(m)} />}
            <img
              src={posterSrc(m)}
              alt={m.alt_text || m.caption || ''}
              loading="lazy"
              decoding="async"
              class="block mx-auto h-auto max-w-full"
              style={'max-height: ' + singleMaxHeight + ';'}
            />
          </picture>
        ) : (
          <div class="media-gallery-thumb">
            <picture>
              {!isVideo(m) && hasAvif(m) && <source type="image/avif" srcset={avifSrc(m)} />}
              {!isVideo(m) && hasSmVariant(m) && <source type="image/webp" srcset={`${posterSrc(m)} 1400w, ${webpSmSrc(m)} 768w`} sizes="(max-width: 640px) 100vw, 50vw" />}
              <img
                src={posterSrc(m)}
                alt={m.alt_text || m.caption || ''}
                loading={index < 4 ? 'eager' : 'lazy'}
                decoding="async"
                width={m.width || undefined}
                height={m.height || undefined}
                class="media-gallery-image"
              />
            </picture>
            {isVideo(m) && <span class="media-gallery-play" aria-hidden="true">▶</span>}
            {index === items.length - 1 && hiddenCount > 0 && (
              <span class="media-gallery-more" aria-hidden="true">+{hiddenCount}</span>
            )}
          </div>
        )}
      </a>
    ) : isSingle && isVideo(m) ? (
      <button
        type="button"
        class="media-gallery-item media-gallery-button block overflow-hidden"
        data-media-lightbox-trigger
        data-media-index={index}
        data-media-kind="video"
        data-media-src={videoSrc(m)}
        data-media-fallback-src={'/media/' + m.id + '/original'}
        data-media-poster={posterSrc(m)}
        data-media-alt={m.alt_text || ''}
        data-media-caption={m.caption || ''}
        style={tileStyle(m)}
        aria-label={m.alt_text || m.caption || 'Open video'}
      >
        <video
          src={videoSrc(m)}
          poster={posterSrc(m)}
          preload="metadata"
          muted
          playsinline
          class="block mx-auto h-auto max-w-full"
          style={'max-height: ' + singleMaxHeight + ';'}
        />
        <span class="media-gallery-play" aria-hidden="true">▶</span>
        <span class="media-gallery-expand" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg></span>
      </button>
    ) : isSingle ? (
      <button
        type="button"
        class="media-gallery-item media-gallery-button block overflow-hidden"
        data-media-lightbox-trigger
        data-media-index={index}
        data-media-kind="photo"
        data-media-src={posterSrc(m)}
        data-media-alt={m.alt_text || ''}
        data-media-caption={m.caption || ''}
        style={tileStyle(m)}
      >
        <picture>
          {hasAvif(m) && <source type="image/avif" srcset={avifSrc(m)} />}
          <img
            src={posterSrc(m)}
            alt={m.alt_text || m.caption || ''}
            loading="lazy"
            decoding="async"
            class="block mx-auto h-auto max-w-full"
            style={'max-height: ' + singleMaxHeight + ';'}
          />
        </picture>
        <span class="media-gallery-expand" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg></span>
      </button>
    ) : isVideo(m) ? (
      <button
        type="button"
        class:list={['media-gallery-item media-gallery-button block overflow-hidden bg-line-soft', tileClass(m)]}
        data-media-lightbox-trigger
        data-media-index={index}
        data-media-kind="video"
        data-media-src={videoSrc(m)}
        data-media-fallback-src={'/media/' + m.id + '/original'}
        data-media-poster={posterSrc(m)}
        data-media-alt={m.alt_text || ''}
        data-media-caption={m.caption || ''}
        data-open-at-index={index === items.length - 1 && hiddenCount > 0 ? items.length : undefined}
        aria-label={m.alt_text || m.caption || 'Open video'}
      >
        <div class="media-gallery-thumb">
          <img
            src={posterSrc(m)}
            alt={m.alt_text || m.caption || ''}
            loading={index < 4 ? 'eager' : 'lazy'}
            decoding="async"
            width={m.width || undefined}
            height={m.height || undefined}
            class="media-gallery-image"
          />
          <span class="media-gallery-play" aria-hidden="true">▶</span>
          {index === items.length - 1 && hiddenCount > 0 && (
            <span class="media-gallery-more" aria-hidden="true">+{hiddenCount}</span>
          )}
          <span class="media-gallery-expand" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg></span>
        </div>
      </button>
    ) : (
      <button
        type="button"
        class:list={['media-gallery-item media-gallery-button block overflow-hidden bg-line-soft', tileClass(m)]}
        data-media-lightbox-trigger
        data-media-index={index}
        data-media-kind="photo"
        data-media-src={posterSrc(m)}
        data-media-alt={m.alt_text || ''}
        data-media-caption={m.caption || ''}
        data-open-at-index={index === items.length - 1 && hiddenCount > 0 ? items.length : undefined}
      >
        <div class="media-gallery-thumb">
          <picture>
            {hasAvif(m) && <source type="image/avif" srcset={avifSrc(m)} />}
            {hasSmVariant(m) && <source type="image/webp" srcset={`${posterSrc(m)} 1400w, ${webpSmSrc(m)} 768w`} sizes="(max-width: 640px) 100vw, 50vw" />}
            <img
              src={posterSrc(m)}
              alt={m.alt_text || m.caption || ''}
              loading={index < 4 ? 'eager' : 'lazy'}
              decoding="async"
              width={m.width || undefined}
              height={m.height || undefined}
              class="media-gallery-image"
            />
          </picture>
          {index === items.length - 1 && hiddenCount > 0 && (
            <span class="media-gallery-more" aria-hidden="true">+{hiddenCount}</span>
          )}
          <span class="media-gallery-expand" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg></span>
        </div>
      </button>
    ))}
  </div>
)}

<script>
  interface LightboxItem {
    kind: string;
    src: string;
    fallbackSrc: string;
    poster: string;
    alt: string;
    caption: string;
  }

  interface MediaLightboxDialog extends HTMLDialogElement {
    __mediaLightboxOpen: (items: LightboxItem[], index: number) => void;
  }

  interface SerializedMedia {
    id: string;
    kind: string;
    alt: string;
    caption: string;
    src: string;
    fallbackSrc: string;
    poster: string;
  }

  function ensureMediaLightbox(): MediaLightboxDialog {
    const existing = document.querySelector<MediaLightboxDialog>('[data-global-media-lightbox]');
    if (existing) return existing;

    const dialog = document.createElement('dialog') as MediaLightboxDialog;
    dialog.className = 'media-lightbox';
    dialog.dataset.globalMediaLightbox = 'true';
    dialog.innerHTML = '<button type="button" class="media-lightbox-close" data-media-lightbox-close aria-label="Close">Close</button><div class="media-lightbox-body"><button type="button" class="media-lightbox-nav media-lightbox-prev" data-media-lightbox-prev aria-label="Previous media">‹</button><img class="media-lightbox-image" data-media-lightbox-image alt="" /><video class="media-lightbox-video" data-media-lightbox-video controls playsinline></video><button type="button" class="media-lightbox-nav media-lightbox-next" data-media-lightbox-next aria-label="Next media">›</button></div><div class="media-lightbox-footer"><p class="media-lightbox-caption" data-media-lightbox-caption></p><div class="media-lightbox-count" data-media-lightbox-count></div></div>';
    document.body.append(dialog);

    const image = dialog.querySelector<HTMLImageElement>('[data-media-lightbox-image]')!;
    const video = dialog.querySelector<HTMLVideoElement>('[data-media-lightbox-video]')!;
    const count = dialog.querySelector<HTMLElement>('[data-media-lightbox-count]')!;
    const caption = dialog.querySelector<HTMLElement>('[data-media-lightbox-caption]')!;
    const prev = dialog.querySelector<HTMLButtonElement>('[data-media-lightbox-prev]')!;
    const next = dialog.querySelector<HTMLButtonElement>('[data-media-lightbox-next]')!;
    const close = dialog.querySelector<HTMLButtonElement>('[data-media-lightbox-close]')!;
    const state: { items: LightboxItem[]; activeIndex: number } = { items: [], activeIndex: 0 };

    function preloadItem(item: LightboxItem | undefined) {
      if (!item || item.kind === 'video') return;
      const img = new Image();
      img.src = item.src;
    }

    function show(index: number) {
      if (!state.items.length) return;
      state.activeIndex = Math.max(0, Math.min(index, state.items.length - 1));
      const item = state.items[state.activeIndex];
      video.pause();
      video.removeAttribute('src');
      video.removeAttribute('poster');
      video.load();
      image.removeAttribute('src');
      image.alt = item.alt || '';
      if (item.kind === 'video') {
        image.hidden = true;
        video.hidden = false;
        video.src = item.src || '';
        video.dataset.fallbackSrc = item.fallbackSrc || '';
        if (item.poster) video.poster = item.poster;
      } else {
        video.hidden = true;
        video.dataset.fallbackSrc = '';
        image.hidden = false;
        image.src = item.src || '';
      }
      caption.textContent = item.caption || '';
      caption.hidden = !item.caption;
      count.textContent = String(state.activeIndex + 1) + ' / ' + String(state.items.length);
      prev.hidden = state.activeIndex === 0;
      next.hidden = state.activeIndex === state.items.length - 1;
      // Kick off background fetches for neighbours so they're cached before the user gets there
      preloadItem(state.items[state.activeIndex + 1]);
      preloadItem(state.items[state.activeIndex - 1]);
    }

    dialog.__mediaLightboxOpen = function(items: LightboxItem[], index: number) {
      state.items = items;
      show(index);
      dialog.showModal();
    };

    prev.addEventListener('click', () => show(state.activeIndex - 1));
    next.addEventListener('click', () => show(state.activeIndex + 1));
    close.addEventListener('click', () => dialog.close());
    dialog.addEventListener('close', () => {
      video.pause();
      video.removeAttribute('src');
      video.removeAttribute('poster');
      video.dataset.fallbackSrc = '';
      video.load();
    });
    video.addEventListener('error', () => {
      const fallbackSrc = video.dataset.fallbackSrc || '';
      if (!fallbackSrc || video.currentSrc.endsWith('/original')) return;
      video.src = fallbackSrc;
      video.dataset.fallbackSrc = '';
      video.load();
    });
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
    window.addEventListener('keydown', (event) => {
      if (!dialog.open) return;
      if (event.key === 'ArrowLeft' && state.activeIndex > 0) {
        event.preventDefault();
        show(state.activeIndex - 1);
      }
      if (event.key === 'ArrowRight' && state.activeIndex < state.items.length - 1) {
        event.preventDefault();
        show(state.activeIndex + 1);
      }
    });

    return dialog;
  }

  function initMediaGalleries() {
    document.querySelectorAll<HTMLElement>('[data-media-gallery]').forEach((gallery) => {
      if (gallery.dataset.mediaGalleryReady === 'true') return;
      gallery.dataset.mediaGalleryReady = 'true';

      const triggers = Array.from(gallery.querySelectorAll<HTMLElement>('[data-media-lightbox-trigger]'));
      if (!triggers.length) return;

      const allMediaRaw = gallery.dataset.allMedia;
      const allItems: LightboxItem[] = allMediaRaw
        ? (JSON.parse(allMediaRaw) as SerializedMedia[]).map((m) => ({
            kind: m.kind || 'photo',
            src: m.src || '',
            fallbackSrc: m.fallbackSrc || '',
            poster: m.poster || '',
            alt: m.alt || '',
            caption: m.caption || '',
          }))
        : triggers.map((item) => ({
            kind: item.dataset.mediaKind || 'photo',
            src: item.dataset.mediaSrc || '',
            fallbackSrc: item.dataset.mediaFallbackSrc || '',
            poster: item.dataset.mediaPoster || '',
            alt: item.dataset.mediaAlt || '',
            caption: item.dataset.mediaCaption || '',
          }));

      triggers.forEach((trigger, index) => {
        trigger.addEventListener('click', () => {
          const dialog = ensureMediaLightbox();
          const openAt = trigger.dataset.openAtIndex !== undefined
            ? parseInt(trigger.dataset.openAtIndex, 10)
            : index;
          dialog.__mediaLightboxOpen(allItems, openAt);
        });
      });
    });
  }

  initMediaGalleries();

  // Fade in gallery images when they finish loading
  document.querySelectorAll<HTMLImageElement>('.media-gallery-image').forEach((img) => {
    if (img.complete) {
      img.classList.add('loaded');
    } else {
      img.addEventListener('load', () => img.classList.add('loaded'));
      img.addEventListener('error', () => img.classList.add('loaded'));
    }
  });
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLImageElement>('.media-gallery-image:not(.loaded)').forEach((img) => {
      if (img.complete) {
        img.classList.add('loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('loaded'));
        img.addEventListener('error', () => img.classList.add('loaded'));
      }
    });
  });
  document.addEventListener('astro:page-load', initMediaGalleries);
</script>

<style>
  .media-gallery {
    display: grid;
    gap: 10px;
  }

  .media-gallery-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .media-gallery-grid,
  .media-gallery-bento {
    align-items: start;
    grid-auto-flow: dense;
    grid-template-columns: repeat(auto-fit, minmax(10rem, max-content));
  }

  .media-gallery-item {
    border: 0;
    border-radius: 6px;
    color: inherit;
    cursor: pointer;
    overflow: hidden;
    padding: 0;
    height: min(15rem, 36vw);
    aspect-ratio: 4 / 3;
    justify-self: start;
    max-width: 100%;
    position: relative;
    text-align: inherit;
  }

  .media-gallery-single .media-gallery-item {
    aspect-ratio: unset;
    height: auto;
    width: auto;
  }

  .media-gallery-button {
    background: transparent;
    cursor: zoom-in;
    font: inherit;
  }

  /* Dark overlay on hover */
  .media-gallery-button::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.38);
    opacity: 0;
    transition: opacity 0.18s ease;
    pointer-events: none;
    border-radius: inherit;
    z-index: 1;
  }

  .media-gallery-button:hover::after {
    opacity: 1;
  }

  /* Expand badge */
  .media-gallery-expand {
    position: absolute;
    bottom: 7px;
    right: 7px;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 5px;
    padding: 4px;
    color: white;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.18s ease;
  }

  @media (hover: none) {
    .media-gallery-expand {
      opacity: 1;
    }
  }

  .media-gallery-button:hover .media-gallery-expand {
    opacity: 1;
    inset: 0;
    bottom: auto;
    right: auto;
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
  }

  .media-gallery-button:hover .media-gallery-expand svg {
    width: 28px;
    height: 28px;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.6));
  }

  .media-gallery-link-single {
    display: block;
    text-decoration: none;
  }

  .media-gallery-thumb {
    height: 100%;
    min-height: 100%;
    position: relative;
  }

  .media-gallery-thumb picture {
    display: contents;
  }

  .media-gallery-image {
    height: 100%;
    object-fit: cover;
    width: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .media-gallery-image.loaded {
    opacity: 1;
  }

  .media-gallery-thumb::before {
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .media-gallery-more {
    align-items: center;
    background: rgb(0 0 0 / 0.55);
    bottom: 0;
    color: white;
    display: flex;
    font-family: var(--body);
    font-size: 1.1rem;
    font-weight: 600;
    inset: 0;
    justify-content: center;
    letter-spacing: 0.02em;
    position: absolute;
  }

  .media-gallery-play {
    align-items: center;
    background: rgb(0 0 0 / 0.62);
    border: 1px solid rgb(255 255 255 / 0.28);
    border-radius: 999px;
    color: white;
    display: flex;
    font-size: 13px;
    height: 34px;
    justify-content: center;
    left: 50%;
    line-height: 1;
    padding-left: 2px;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 34px;
  }

  :global(.media-lightbox:not([open])) {
    display: none;
  }

  :global(.media-lightbox) {
    background: rgb(10 13 17 / 0.94);
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: 8px;
    color: white;
    display: flex;
    flex-direction: column;
    height: min(90vh, 900px);
    margin: auto;
    max-width: min(92vw, 1280px);
    padding: 48px 64px 20px;
    width: min(92vw, 1280px);
  }

  :global(.media-lightbox::backdrop) {
    background: rgb(0 0 0 / 0.72);
  }

  :global(.media-lightbox-body) {
    flex: 1;
    min-height: 0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.media-lightbox-image),
  :global(.media-lightbox-video) {
    max-height: 100%;
    max-width: 100%;
    object-fit: contain;
    width: auto;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  :global(.media-lightbox-close),
  :global(.media-lightbox-nav) {
    background: rgb(255 255 255 / 0.08);
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 6px;
    color: white;
    cursor: pointer;
    position: absolute;
  }

  :global(.media-lightbox-close) {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 8px 10px;
    right: 16px;
    text-transform: uppercase;
    top: 14px;
  }

  :global(.media-lightbox-nav) {
    font-size: 32px;
    height: 44px;
    line-height: 1;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    z-index: 1;
  }

  :global(.media-lightbox-prev) {
    left: -52px;
  }

  :global(.media-lightbox-next) {
