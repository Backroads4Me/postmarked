---
/**
 * MediaGallery - Reusable media gallery for posts and stops.
 *
 * Single item: displays at natural aspect ratio, constrained by max dimensions.
 * Multiple items: compact bento grid with varied thumbnail proportions.
 */
interface MediaSummary {
  id: string;
  kind?: 'photo' | 'video' | string;
  width?: number | null;
  height?: number | null;
  blurhash?: string | null;
  dominant_color?: string | null;
  alt_text?: string | null;
  caption?: string | null;
}

interface Props {
  media: MediaSummary[];
  /** Max width of the gallery container. Default 'none' (full width). */
  maxWidth?: string;
  /** Max height for a single photo. Default '20rem'. */
  singleMaxHeight?: string;
  /** When true, use a varied bento layout for multiple photos. Default true. */
  bentoGrid?: boolean;
  /** Number of photos to show. Default 4. */
  limit?: number;
}

const { media, maxWidth = 'none', singleMaxHeight = '20rem', bentoGrid = true, limit = 4 } = Astro.props;
const items = (media || []).slice(0, limit);
const isSingle = items.length === 1;
const galleryId = 'media-gallery-' + Math.random().toString(36).slice(2);

function isVideo(m: MediaSummary) {
  return m.kind === 'video';
}

function posterSrc(m: MediaSummary) {
  return isVideo(m) ? '/media/' + m.id + '/poster' : '/media/' + m.id + '/webp';
}

function tileStyle(m: MediaSummary) {
  const aspect = m.width && m.height ? m.width + ' / ' + m.height : '4 / 3';
  return 'aspect-ratio: ' + aspect + ';';
}

function tileClass(m: MediaSummary) {
  return '';
}
---

{items.length > 0 && (
  <div
    id={galleryId}
    data-media-gallery
    class:list={[
      'media-gallery mt-3 rounded-md overflow-hidden',
      isSingle ? 'media-gallery-single' : bentoGrid ? 'media-gallery-bento' : 'media-gallery-grid',
      maxWidth !== 'none' ? maxWidth : '',
    ]}
  >
    {items.map((m, index) => isSingle && isVideo(m) ? (
      <button
        type="button"
        class="media-gallery-item media-gallery-button block overflow-hidden"
        data-media-lightbox-trigger
        data-media-index={index}
        data-media-kind="video"
        data-media-src={'/media/' + m.id + '/original'}
        data-media-poster={posterSrc(m)}
        data-media-alt={m.alt_text || m.caption || ''}
        style={tileStyle(m)}
        aria-label={m.alt_text || m.caption || 'Open video'}
      >
        <video
          src={'/media/' + m.id + '/original'}
          poster={posterSrc(m)}
          preload="metadata"
          muted
          playsinline
          class="block mx-auto h-auto max-w-full"
          style={'max-height: ' + singleMaxHeight + ';'}
        />
        <span class="media-gallery-play" aria-hidden="true">▶</span>
      </button>
    ) : isSingle ? (
      <button
        type="button"
        class="media-gallery-item media-gallery-button block overflow-hidden"
        data-media-lightbox-trigger
        data-media-index={index}
        data-media-kind="photo"
        data-media-src={posterSrc(m)}
        data-media-alt={m.alt_text || m.caption || ''}
        style={tileStyle(m)}
      >
        <img
          src={posterSrc(m)}
          alt={m.alt_text || m.caption || ''}
          loading="lazy"
          decoding="async"
          class="block mx-auto h-auto max-w-full"
          style={'max-height: ' + singleMaxHeight + ';'}
        />
      </button>
    ) : isVideo(m) ? (
      <button
        type="button"
        class:list={['media-gallery-item media-gallery-button block overflow-hidden bg-line-soft', tileClass(m)]}
        data-media-lightbox-trigger
        data-media-index={index}
        data-media-kind="video"
        data-media-src={'/media/' + m.id + '/original'}
        data-media-poster={posterSrc(m)}
        data-media-alt={m.alt_text || m.caption || ''}
        style={tileStyle(m)}
        aria-label={m.alt_text || m.caption || 'Open video'}
      >
        <div class="media-gallery-thumb">
          <img
            src={posterSrc(m)}
            alt={m.alt_text || m.caption || ''}
            loading={index < 4 ? 'eager' : 'lazy'}
            decoding="async"
            width={m.width || undefined}
            height={m.height || undefined}
            class="media-gallery-image"
          />
          <span class="media-gallery-play" aria-hidden="true">▶</span>
        </div>
      </button>
    ) : (
      <button
        type="button"
        class:list={['media-gallery-item media-gallery-button block overflow-hidden bg-line-soft', tileClass(m)]}
        data-media-lightbox-trigger
        data-media-index={index}
        data-media-kind="photo"
        data-media-src={posterSrc(m)}
        data-media-alt={m.alt_text || m.caption || ''}
        style={tileStyle(m)}
      >
        <div class="media-gallery-thumb">
          <img
            src={posterSrc(m)}
            alt={m.alt_text || m.caption || ''}
            loading={index < 4 ? 'eager' : 'lazy'}
            decoding="async"
            width={m.width || undefined}
            height={m.height || undefined}
            class="media-gallery-image"
          />
        </div>
      </button>
    ))}
  </div>
)}

<script>
  function ensureMediaLightbox() {
    let dialog = document.querySelector('[data-global-media-lightbox]');
    if (dialog) return dialog;

    dialog = document.createElement('dialog');
    dialog.className = 'media-lightbox';
    dialog.dataset.globalMediaLightbox = 'true';
    dialog.innerHTML = '<button type="button" class="media-lightbox-close" data-media-lightbox-close aria-label="Close">Close</button><button type="button" class="media-lightbox-nav media-lightbox-prev" data-media-lightbox-prev aria-label="Previous media">‹</button><img class="media-lightbox-image" data-media-lightbox-image alt="" /><video class="media-lightbox-video" data-media-lightbox-video controls playsinline></video><button type="button" class="media-lightbox-nav media-lightbox-next" data-media-lightbox-next aria-label="Next media">›</button><div class="media-lightbox-count" data-media-lightbox-count></div>';
    document.body.append(dialog);

    const image = dialog.querySelector('[data-media-lightbox-image]');
    const video = dialog.querySelector('[data-media-lightbox-video]');
    const count = dialog.querySelector('[data-media-lightbox-count]');
    const prev = dialog.querySelector('[data-media-lightbox-prev]');
    const next = dialog.querySelector('[data-media-lightbox-next]');
    const close = dialog.querySelector('[data-media-lightbox-close]');
    const state = { items: [], activeIndex: 0 };
    dialog.__mediaLightboxState = state;

    function show(index) {
      if (!state.items.length) return;
      state.activeIndex = Math.max(0, Math.min(index, state.items.length - 1));
      const item = state.items[state.activeIndex];
      video.pause();
      video.removeAttribute('src');
      video.removeAttribute('poster');
      video.load();
      image.removeAttribute('src');
      image.alt = item.alt || '';
      if (item.kind === 'video') {
        image.hidden = true;
        video.hidden = false;
        video.src = item.src || '';
        if (item.poster) video.poster = item.poster;
      } else {
        video.hidden = true;
        image.hidden = false;
        image.src = item.src || '';
      }
      count.textContent = String(state.activeIndex + 1) + ' / ' + String(state.items.length);
      prev.hidden = state.activeIndex === 0;
      next.hidden = state.activeIndex === state.items.length - 1;
    }

    dialog.__mediaLightboxOpen = function open(items, index) {
      state.items = items;
      show(index);
      dialog.showModal();
    };

    prev.addEventListener('click', () => show(state.activeIndex - 1));
    next.addEventListener('click', () => show(state.activeIndex + 1));
    close.addEventListener('click', () => dialog.close());
    dialog.addEventListener('close', () => {
      video.pause();
      video.removeAttribute('src');
      video.removeAttribute('poster');
      video.load();
    });
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
    window.addEventListener('keydown', (event) => {
      if (!dialog.open) return;
      if (event.key === 'ArrowLeft' && state.activeIndex > 0) {
        event.preventDefault();
        show(state.activeIndex - 1);
      }
      if (event.key === 'ArrowRight' && state.activeIndex < state.items.length - 1) {
        event.preventDefault();
        show(state.activeIndex + 1);
      }
    });

    return dialog;
  }

  function initMediaGalleries() {
    document.querySelectorAll('[data-media-gallery]').forEach((gallery) => {
      if (gallery.dataset.mediaGalleryReady === 'true') return;
      gallery.dataset.mediaGalleryReady = 'true';

      const triggers = Array.from(gallery.querySelectorAll('[data-media-lightbox-trigger]'));
      if (!triggers.length) return;

      triggers.forEach((trigger, index) => {
        trigger.addEventListener('click', () => {
          const dialog = ensureMediaLightbox();
          const items = triggers.map((item) => ({
            kind: item.dataset.mediaKind || 'photo',
            src: item.dataset.mediaSrc || '',
            poster: item.dataset.mediaPoster || '',
            alt: item.dataset.mediaAlt || '',
          }));
          dialog.__mediaLightboxOpen(items, index);
        });
      });
    });
  }

  initMediaGalleries();

  // Fade in gallery images when they finish loading
  document.querySelectorAll('.media-gallery-image').forEach((img) => {
    if (img.complete) {
      img.classList.add('loaded');
    } else {
      img.addEventListener('load', () => img.classList.add('loaded'));
      img.addEventListener('error', () => img.classList.add('loaded'));
    }
  });
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.media-gallery-image:not(.loaded)').forEach((img) => {
      if (img.complete) {
        img.classList.add('loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('loaded'));
        img.addEventListener('error', () => img.classList.add('loaded'));
      }
    });
  });
  document.addEventListener('astro:page-load', initMediaGalleries);
</script>

<style>
  .media-gallery {
    display: grid;
    gap: 4px;
  }

  .media-gallery-single {
    grid-template-columns: minmax(0, 1fr);
  }

  .media-gallery-grid,
  .media-gallery-bento {
    align-items: start;
    grid-auto-flow: dense;
    grid-template-columns: repeat(auto-fit, minmax(10rem, max-content));
  }

  .media-gallery-item {
    border: 0;
    color: inherit;
    cursor: pointer;
    padding: 0;
    height: min(18rem, 42vw);
    justify-self: start;
    max-width: 100%;
    position: relative;
    text-align: inherit;
    width: auto;
  }

  .media-gallery-button {
    background: transparent;
    font: inherit;
  }

  .media-gallery-thumb {
    height: 100%;
    min-height: 100%;
    position: relative;
  }

  .media-gallery-image {
    height: 100%;
    object-fit: cover;
    width: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .media-gallery-image.loaded {
    opacity: 1;
  }

  .media-gallery-thumb::before {
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .media-gallery-play {
    align-items: center;
    background: rgb(0 0 0 / 0.62);
    border: 1px solid rgb(255 255 255 / 0.28);
    border-radius: 999px;
    color: white;
    display: flex;
    font-size: 13px;
    height: 34px;
    justify-content: center;
    left: 50%;
    line-height: 1;
    padding-left: 2px;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 34px;
  }

  :global(.media-lightbox) {
    background: rgb(10 13 17 / 0.94);
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: 8px;
    color: white;
    height: min(90vh, 900px);
    margin: auto;
    max-width: min(92vw, 1280px);
    padding: 48px 64px 40px;
    width: min(92vw, 1280px);
  }

  :global(.media-lightbox::backdrop) {
    background: rgb(0 0 0 / 0.72);
  }

  :global(.media-lightbox-image),
  :global(.media-lightbox-video) {
    height: 100%;
    margin: 0 auto;
    max-height: calc(90vh - 104px);
    object-fit: contain;
    width: 100%;
  }

  :global(.media-lightbox-close),
  :global(.media-lightbox-nav) {
    background: rgb(255 255 255 / 0.08);
    border: 1px solid rgb(255 255 255 / 0.18);
    border-radius: 6px;
    color: white;
    cursor: pointer;
    position: absolute;
  }

  :global(.media-lightbox-close) {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 8px 10px;
    right: 16px;
    text-transform: uppercase;
    top: 14px;
  }

  :global(.media-lightbox-nav) {
    font-size: 32px;
    height: 44px;
    line-height: 1;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
  }

  :global(.media-lightbox-prev) {
    left: 12px;
  }

  :global(.media-lightbox-next) {
    right: 12px;
  }

  :global(.media-lightbox-count) {
    bottom: 14px;
    color: rgb(255 255 255 / 0.72);
    font-family: var(--mono);
    font-size: 11px;
    left: 50%;
    letter-spacing: 0.08em;
    position: absolute;
    transform: translateX(-50%);
  }

  @media (max-width: 640px) {
    .media-gallery-bento,
    .media-gallery-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    :global(.media-lightbox) {
      height: 100vh;
      max-height: 100vh;
      max-width: 100vw;
      padding: 56px 12px 48px;
      width: 100vw;
    }

    :global(.media-lightbox-nav) {
      bottom: 10px;
      top: auto;
      transform: none;
    }
  }
</style>
