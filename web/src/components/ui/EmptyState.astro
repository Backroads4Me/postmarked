---
/**
 * EmptyState — Friendly empty/loading/error state.
 */
interface Props {
  icon?: string;
  title?: string;
  message?: string;
  variant?: 'empty' | 'loading' | 'error';
}

const {
  icon = '🗺️',
  title = 'Nothing here yet',
  message = 'Check back soon for updates.',
  variant = 'empty'
} = Astro.props;
---

<div class="empty-state">
  <div class="icon">{icon}</div>
  <h3>{title}</h3>
  <p>{message}</p>
  {variant === 'loading' && (
    <div class="mt-4 flex gap-2">
      <div class="skeleton w-3 h-3 rounded-full" style="animation-delay: 0s;"></div>
      <div class="skeleton w-3 h-3 rounded-full" style="animation-delay: 0.2s;"></div>
      <div class="skeleton w-3 h-3 rounded-full" style="animation-delay: 0.4s;"></div>
    </div>
  )}
</div>
