---
/**
 * NavBar — Responsive navigation.
 * Desktop: top horizontal bar. Mobile: bottom tab bar.
 */

import ThemeToggle from './ThemeToggle.astro';
import { apiUrl } from '../../lib/api.js';
import SearchIsland from '../SearchIsland.jsx';

const { pathname } = Astro.url;
const cookie = Astro.request.headers.get('cookie') || '';

let isLoggedIn = false;
try {
  const res = await fetch(apiUrl('/api/users/me'), {
    headers: cookie ? { cookie } : {},
  });
  isLoggedIn = res.ok;
} catch {}

const navItems = [
  {
    href: '/',
    label: 'Home',
    icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 11.5 12 5l8 6.5"/><path d="M6.5 10.5V20h11v-9.5"/><path d="M10 20v-5h4v5"/></svg>',
  },
  {
    href: '/trips',
    label: 'All Trips',
    icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18 4 20V6l5-2 6 2 5-2v14l-5 2-6-2Z"/><path d="M9 4v14"/><path d="M15 6v14"/></svg>',
  },
  isLoggedIn
    ? {
        href: '/account',
        label: 'Account',
        icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c1.8-4 4.5-6 8-6s6.2 2 8 6"/></svg>',
      }
    : {
        href: '/auth/register',
        label: 'Register',
        icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6.5h16v11H4z"/><path d="m4 7 8 6 8-6"/></svg>',
      },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!-- Desktop Top Nav -->
<nav class="top-nav" id="desktop-nav">
  <div class="top-nav-inner">
    <a href="/" class="flex items-center gap-3">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="text-ember font-semibold text-lg font-display">Postmarked</span>
    </a>
    <div class="flex items-center gap-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
          style="flex-direction: row; gap: 6px; padding: 8px 16px; font-size: 12px;"
        >
          <span class="nav-symbol" set:html={item.icon}></span>
          <span>{item.label}</span>
        </a>
      ))}
      <SearchIsland client:load />
      <ThemeToggle class="theme-toggle--desktop" />
    </div>
  </div>
</nav>

<!-- Mobile Bottom Nav -->
<nav class="bottom-nav" id="mobile-nav">
  {navItems.map(item => (
    <a
      href={item.href}
      class:list={['nav-link', { active: isActive(item.href) }]}
    >
      <span class="nav-symbol" set:html={item.icon}></span>
      <span>{item.label}</span>
    </a>
  ))}
  <ThemeToggle class="theme-toggle--mobile" />
</nav>
