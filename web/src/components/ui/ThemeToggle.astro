---
const { class: className = '' } = Astro.props;
---

<button
  type="button"
  class={`theme-toggle ${className}`}
  data-theme-toggle
  aria-label="Use light theme"
  title="Switch theme"
>
  <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
    <svg viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="m4.93 4.93 1.41 1.41"></path>
      <path d="m17.66 17.66 1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="m6.34 17.66-1.41 1.41"></path>
      <path d="m19.07 4.93-1.41 1.41"></path>
    </svg>
  </span>
  <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
    <svg viewBox="0 0 24 24">
      <path d="M20.5 14.5A7.6 7.6 0 0 1 9.5 3.5 8.6 8.6 0 1 0 20.5 14.5Z"></path>
    </svg>
  </span>
  <span class="theme-toggle__text" data-theme-toggle-label>Theme</span>
</button>

<script is:inline>
  (() => {
    if (window.__postmarkedThemeToggleReady) return;
    window.__postmarkedThemeToggleReady = true;

    const storageKey = 'postmarked-theme';
    const root = document.documentElement;
    const media = window.matchMedia('(prefers-color-scheme: dark)');
    const themeColor = document.querySelector('meta[name="theme-color"]');

    function storedTheme() {
      const value = localStorage.getItem(storageKey);
      return value === 'light' || value === 'dark' ? value : null;
    }

    function resolveTheme() {
      return storedTheme() || (media.matches ? 'dark' : 'light');
    }

    function applyTheme(theme, preference) {
      root.dataset.theme = theme;
      root.dataset.themePreference = preference || storedTheme() || 'system';
      if (themeColor) themeColor.setAttribute('content', theme === 'dark' ? '#0D141C' : '#E1D7BE');

      document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
        const nextTheme = theme === 'dark' ? 'light' : 'dark';
        button.setAttribute('aria-label', `Use ${nextTheme} theme`);
        button.setAttribute('title', `Use ${nextTheme} theme`);
        const label = button.querySelector('[data-theme-toggle-label]');
        if (label) label.textContent = theme === 'dark' ? 'Dark' : 'Light';
      });
    }

    function syncTheme() {
      applyTheme(resolveTheme());
    }

    document.addEventListener('click', (event) => {
      const button = event.target.closest('[data-theme-toggle]');
      if (!button) return;

      const nextTheme = resolveTheme() === 'dark' ? 'light' : 'dark';
      localStorage.setItem(storageKey, nextTheme);
      applyTheme(nextTheme, nextTheme);
    });

    media.addEventListener('change', () => {
      if (!storedTheme()) syncTheme();
    });

    syncTheme();
  })();
</script>
