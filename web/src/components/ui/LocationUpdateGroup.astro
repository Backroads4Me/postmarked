---
/**
 * LocationUpdateGroup — a stop/location card with nested post updates.
 */
import PostCard from './PostCard.astro';
import StopIdentity from './StopIdentity.astro';

interface MediaSummary {
  id: string;
  kind?: 'photo' | 'video' | string;
  width?: number | null;
  height?: number | null;
  blurhash?: string | null;
  dominant_color?: string | null;
  alt_text?: string | null;
  caption?: string | null;
}

interface PostSummary {
  id?: string;
  slug?: string;
  title: string;
  body?: string | null;
  summary?: string | null;
  posted_at?: string;
  media?: MediaSummary[];
}

interface StopSummary {
  id?: string;
  title: string;
  displayTitle?: string;
  detailTitle?: string;
  slug?: string;
  tripSlug?: string;
  trip_slug?: string;
  summary?: string | null;
  start_date?: string;
  posted_at?: string;
  place_name?: string | null;
  address_label?: string | null;
}

interface Props {
  stop: StopSummary;
  posts?: PostSummary[];
}

const { stop, posts = [] } = Astro.props;
const tripSlug = stop.tripSlug || stop.trip_slug;
const href = stop.slug && tripSlug ? `/trips/${tripSlug}/stops/${stop.slug}` : undefined;
const date = stop.start_date || stop.posted_at;

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  } catch { return ''; }
}

function postHref(post: PostSummary) {
  if (!post.slug || !stop.slug || !tripSlug) return undefined;
  return `/trips/${tripSlug}/stops/${stop.slug}/posts/${post.slug}`;
}
---

<article class="location-update-group" id={stop.slug ? `stop-${stop.slug}` : undefined}>
  <div class="location-update-header">
    {href ? (
      <a href={href} class="location-header-link">
        <div class="flex items-baseline gap-2 mb-2">
          {date && (
            <>
              <span class="display text-xl text-muted">{formatDate(date)}</span>
              <span class="display text-xl text-muted" aria-hidden="true">-</span>
            </>
          )}
          <StopIdentity stop={stop} />
        </div>
      </a>
    ) : (
      <div>
        <div class="flex items-baseline gap-2 mb-2">
          {date && (
            <>
              <span class="display text-xl text-muted">{formatDate(date)}</span>
              <span class="display text-xl text-muted" aria-hidden="true">-</span>
            </>
          )}
          <StopIdentity stop={stop} heading />
        </div>
      </div>
    )}
  </div>

  {posts.length > 0 && (
    <div class="location-posts">
      {posts.map((post) => (
        <PostCard
          title={post.title}
          posted_at={post.posted_at}
          body={post.body}
          summary={post.summary}
          media={post.media}
          href={postHref(post)}
          cardClass="location-post"
        />
      ))}
    </div>
  )}
</article>

<style>
  .location-update-group {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .location-update-group:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-float);
  }

  .location-update-header {
    padding: 18px;
  }

  .location-header-link {
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    display: block;
  }

  .location-header-link .text-muted {
    transition: color 160ms ease;
  }

  .location-header-link:hover :global(.stop-identity-primary),
  .location-header-link:hover :global(.stop-identity-detail),
  .location-header-link:hover .text-muted {
    color: var(--ember-2);
  }

  .location-posts {
    border-top: 1px solid var(--line-soft);
    display: grid;
    gap: 22px;
    padding: 12px;
  }

  .location-post {
    background: var(--surface-2);
    border-radius: 6px;
    padding: 14px 16px;
  }
</style>
