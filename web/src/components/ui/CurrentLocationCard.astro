---
/**
 * CurrentLocationCard — Hero card showing where the RV is right now.
 */
interface StopMention {
  cityState: string;
  slug: string;
  tripSlug: string;
}

interface WeatherDay {
  day: string;
  high: number;
  low: number;
  label: string;
  icon: string;
}

interface Weather {
  current: { temp: number; label: string; icon: string };
  forecast: WeatherDay[];
}

interface Props {
  stopTitle: string;
  stopSlug: string;
  tripTitle: string;
  tripSlug: string;
  placeName?: string;
  summary?: string;
  arrivalDate?: string;
  nights?: number;
  note?: string;
  label?: string;
  prevStop?: StopMention;
  nextStop?: StopMention;
  weather?: Weather | null;
}

const { stopTitle, stopSlug, tripTitle, tripSlug, placeName, summary, arrivalDate, nights, note, label = 'Currently At', prevStop, nextStop, weather } = Astro.props;

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
  } catch { return dateStr; }
}

function daysAgo(dateStr?: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  const diff = Math.floor((Date.now() - d.getTime()) / 86400000);
  if (diff === 0) return 'Today';
  if (diff === 1) return '1 day ago';
  return `${diff} days ago`;
}

function cityStateFromAddress(address?: string) {
  if (!address) return '';
  const parts = address.split(',').map((part) => part.trim()).filter(Boolean);
  if (parts.length < 3) return '';

  const city = parts.at(-2);
  const stateZip = parts.at(-1) || '';
  const state = stateZip.match(/^([A-Z]{2})(?:\s+\d{5}(?:-\d{4})?)?$/)?.[1];
  if (!city || !state) return '';

  return `${city}, ${state}`;
}

const cityStateLabel = cityStateFromAddress(summary);
const primaryTitle = cityStateLabel || stopTitle;
const secondaryTitle = cityStateLabel ? stopTitle : placeName && placeName !== stopTitle ? placeName : '';
---

<div class="card-hero" id="current-location">
  <div class="flex items-start gap-6">
    {/* ── Left: location content ── */}
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-3 mb-4">
        <span class="pulse-dot"></span>
        {label && <span class="eyebrow">{label}</span>}
      </div>
      <h2 class="display text-3xl md:text-4xl mb-2">
        <a href={`/trips/${tripSlug}/stops/${stopSlug}`} class="hover:text-ember-2 transition-colors">
          {primaryTitle}
        </a>
      </h2>

      {secondaryTitle && (
        <p class="coord text-lg mb-2">{secondaryTitle}</p>
      )}

      <div class="flex flex-wrap gap-4 text-sm">
        {arrivalDate && (
          <div class="flex flex-col">
            <span class="current-meta-label mb-1">Arrived</span>
            <span class="current-meta-value">{formatDate(arrivalDate)}</span>
          </div>
        )}
        {nights && nights > 0 && (
          <div class="flex flex-col">
            <span class="current-meta-label mb-1">Staying</span>
            <span class="current-meta-value">{nights} night{nights !== 1 ? 's' : ''}</span>
          </div>
        )}
      </div>

      {note && (
        <p class="lede mt-4 text-sm" style="font-family: var(--sans); font-size: 14px;">
          {note}
        </p>
      )}
    </div>

    {/* ── Right: weather panel ── */}
    {weather && (
      <div class="shrink-0 flex flex-col items-start gap-4" style="min-width: 9rem;">
        <div class="flex items-center gap-2">
          <span class="display text-4xl">{weather.current.temp}°</span>
          <img
            src={`/weather-icons/${weather.current.icon}.png`}
            alt={weather.current.label}
            width="56"
            height="56"
          />
        </div>
        <div class="flex flex-col gap-2 w-full">
          {weather.forecast.map(day => (
            <div class="flex items-center justify-between gap-2">
              <span class="text-sm text-muted font-mono w-8">{day.day}</span>
              <img
                src={`/weather-icons/${day.icon}.png`}
                alt={day.label}
                width="24"
                height="24"
              />
              <span class="text-sm text-right">
                <span>{day.high}°</span>
                <span class="text-muted"> / {day.low}°</span>
              </span>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  {(prevStop || nextStop) && (
    <div class="flex justify-between mt-4 pt-3 border-t border-line-soft text-sm">
      {prevStop ? (
        <a href={`/trips/${prevStop.tripSlug}/stops/${prevStop.slug}`} class="flex items-center gap-1.5 text-muted hover:text-paper transition-colors font-medium group">
          <svg class="w-4 h-4 text-muted group-hover:text-paper" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          {prevStop.cityState}
        </a>
      ) : <span />}
      {nextStop && (
        <a href={`/trips/${nextStop.tripSlug}/stops/${nextStop.slug}`} class="flex items-center gap-1.5 text-muted hover:text-paper transition-colors font-medium group">
          {nextStop.cityState}
          <svg class="w-4 h-4 text-muted group-hover:text-paper" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      )}
    </div>
  )}
</div>
