---
/**
 * PostCard — a single post/update card with title, date, body, and media.
 * Shared between the home screen (LocationUpdateGroup) and stop detail pages.
 */
import { renderMarkdown } from '../../lib/markdown.js';
import MediaGallery from './MediaGallery.astro';

interface MediaSummary {
  id: string;
  kind?: 'photo' | 'video' | string;
  width?: number | null;
  height?: number | null;
  blurhash?: string | null;
  dominant_color?: string | null;
  alt_text?: string | null;
  caption?: string | null;
}

interface Props {
  title: string;
  posted_at?: string;
  body?: string | null;
  summary?: string | null;
  media?: MediaSummary[];
  /** Optional link to the full post. When provided, the title is a link. */
  href?: string;
  /** Optional container class for the card. */
  cardClass?: string;
}

const { title, posted_at, body, summary, media, href, cardClass = '' } = Astro.props;

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  } catch { return ''; }
}

const renderedBody = renderMarkdown(body || summary || '');
---

<article class={cardClass}>
  <div class="flex items-start justify-between gap-3 mb-1">
    {href ? (
      <a href={href} class="location-post-title">{title}</a>
    ) : (
      <h4 class="location-post-title">{title}</h4>
    )}
    {posted_at && <span class="label shrink-0">{formatDate(posted_at)}</span>}
  </div>
  {renderedBody && (
    <div class="location-post-markdown text-muted text-sm leading-relaxed line-clamp-3" set:html={renderedBody} />
  )}
  {media && media.length > 0 && (
    <MediaGallery media={media} singleMaxHeight="18rem" />
  )}
</article>

<style>
  .location-post-title {
    color: var(--paper);
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0;
    text-decoration: none;
  }

  .location-post-title:hover {
    color: var(--ember);
  }

  .location-post-markdown :global(p) {
    margin: 0 0 0.45rem;
  }

  .location-post-markdown :global(p:last-child),
  .location-post-markdown :global(ul:last-child),
  .location-post-markdown :global(h3:last-child),
  .location-post-markdown :global(h4:last-child),
  .location-post-markdown :global(h5:last-child) {
    margin-bottom: 0;
  }

  .location-post-markdown :global(ul) {
    list-style: disc;
    margin: 0.35rem 0 0.45rem 1.1rem;
    padding: 0;
  }
</style>
