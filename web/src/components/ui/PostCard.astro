---
/**
 * PostCard — Quick update card for timeline feeds.
 *
 * Photos attached to a post are surfaced inline (up to 3 in a small grid) and
 * link out to the full media via /media/{id}/webp from the authenticated
 * streaming endpoint. Visibility is enforced server-side; the absence of a
 * media entry here means the caller can't see it.
 */
import { renderMarkdown } from '../../lib/markdown.js';
import MediaGallery from './MediaGallery.astro';

interface MediaSummary {
  id: string;
  width?: number | null;
  height?: number | null;
  blurhash?: string | null;
  dominant_color?: string | null;
  alt_text?: string | null;
  caption?: string | null;
}

interface Props {
  title: string;
  body?: string;
  date?: string;
  tripTitle?: string;
  placeName?: string;
  media?: MediaSummary[];
}

const { title, body, date, placeName, media = [] } = Astro.props;
const renderedBody = body ? renderMarkdown(body) : '';

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  } catch { return ''; }
}

---

<div class="card-flat" id={`post-${title?.toLowerCase().replace(/\s+/g, '-')}`}>
  {date && <div class="mb-3"><span class="label">{formatDate(date)}</span></div>}

  <h3 class="text-lg font-medium text-paper mb-1">{title}</h3>
  {renderedBody && (
    <div
      class="post-card-markdown text-muted text-sm leading-relaxed line-clamp-3"
      set:html={renderedBody}
    />
  )}

  <MediaGallery media={media} maxWidth="max-w-sm" />

  <div class="flex items-center gap-3 mt-3 text-xs">
    {placeName && <span class="coord">{placeName}</span>}
  </div>
</div>

<style>
  .post-card-markdown :global(p) {
    margin: 0 0 0.45rem;
  }

  .post-card-markdown :global(p:last-child),
  .post-card-markdown :global(ul:last-child),
  .post-card-markdown :global(h3:last-child),
  .post-card-markdown :global(h4:last-child),
  .post-card-markdown :global(h5:last-child) {
    margin-bottom: 0;
  }

  .post-card-markdown :global(h3),
  .post-card-markdown :global(h4),
  .post-card-markdown :global(h5) {
    color: var(--paper);
    font-size: 1rem;
    font-weight: 600;
    margin: 0.7rem 0 0.3rem;
  }

  .post-card-markdown :global(ul) {
    list-style: disc;
    margin: 0.35rem 0 0.45rem 1.1rem;
    padding: 0;
  }

  .post-card-markdown :global(a) {
    color: var(--ember);
    text-decoration: none;
  }

  .post-card-markdown :global(code) {
    background: var(--surface-2);
    border: 1px solid var(--line-soft);
    border-radius: 4px;
    color: var(--paper);
    font-size: 0.85em;
    padding: 0.05rem 0.25rem;
  }
</style>
