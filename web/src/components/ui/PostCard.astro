---
/**
 * PostCard — a single post/update card with title, date, body, and media.
 * Shared between the home screen (LocationUpdateGroup) and stop detail pages.
 */
import MediaGallery from './MediaGallery.astro';

interface MediaSummary {
  id: string;
  kind?: 'photo' | 'video' | string;
  width?: number | null;
  height?: number | null;
  blurhash?: string | null;
  dominant_color?: string | null;
  alt_text?: string | null;
  caption?: string | null;
}

interface Props {
  title: string;
  posted_at?: string;
  body?: string | null;
  summary?: string | null;
  media?: MediaSummary[];
  /** Optional link to the full post. When provided, the title is a link. */
  href?: string;
  /** Optional container class for the card. */
  cardClass?: string;
}

const { title, posted_at, body, summary, media, href, cardClass = '' } = Astro.props;

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr)
      .toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
      .toUpperCase();
  } catch { return ''; }
}

const dateLabel = formatDate(posted_at);
---

<article class:list={[cardClass, href ? 'post-card-linked' : false]}>
  <div class="location-post-layout">
    <div class="location-post-main">
      {href ? (
        <a href={href} class="location-post-link block">
          <div class="location-post-header">
            <span class="location-post-title">{title}</span>
          </div>
          {summary && (
            <p class="location-post-summary text-muted text-sm leading-relaxed mt-1 mb-0">{summary}</p>
          )}
          <span class="post-card-readmore">
            Read more
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      ) : (
        <div>
          <div class="location-post-header">
            <h4 class="location-post-title">{title}</h4>
          </div>
          {summary && (
            <p class="location-post-summary text-muted text-sm leading-relaxed mt-1 mb-0">{summary}</p>
          )}
        </div>
      )}

      {media && media.length > 0 && (
        <MediaGallery media={media} singleMaxHeight="16rem" linkHref={href} />
      )}
    </div>

    {dateLabel && (
      <aside class="location-post-meta" aria-label={`Posted ${dateLabel}`}>
        <span>Posted</span>
        <time datetime={posted_at}>{dateLabel}</time>
      </aside>
    )}
  </div>
</article>

<style>
  .location-post-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(8rem, 0.28fr);
    gap: 18px;
    align-items: start;
  }

  .location-post-link {
    text-decoration: none;
  }
  .location-post-link:hover .location-post-title,
  .location-post-link:hover .location-post-summary,
  .location-post-link:hover .location-post-markdown,
  .location-post-link:hover .label {
    color: var(--ember);
  }

  .location-post-title {
    color: var(--paper);
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .location-post-summary,
  .location-post-markdown,
  .location-post-link .label {
    transition: color 160ms ease;
  }

  .location-post-meta {
    display: grid;
    gap: 0.32rem;
    justify-items: start;
    padding-top: 0.1rem;
  }

  .location-post-meta span {
    color: var(--ember);
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .location-post-meta time {
    color: var(--muted);
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .post-card-linked {
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 0.18s ease;
  }

  .post-card-linked:hover {
    background-color: rgba(255, 255, 255, 0.03);
  }

  .post-card-readmore {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-top: 0.4rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ember);
    letter-spacing: 0.01em;
  }

  @media (max-width: 700px) {
    .location-post-layout {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .location-post-meta {
      order: -1;
    }
  }
</style>
