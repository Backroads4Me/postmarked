---
/**
 * StopCard — Compact stop summary for feeds and lists.
 */
interface Props {
  title: string;
  displayTitle?: string;
  detailTitle?: string;
  slug?: string;
  tripSlug?: string;
  summary?: string;
  date?: string;
  tripTitle?: string;
  placeName?: string;
  stopType?: string;
}

const { title, displayTitle, detailTitle, slug, tripSlug, summary, date, placeName } = Astro.props;
const href = slug && tripSlug ? `/trips/${tripSlug}/stops/${slug}` : undefined;
const primaryTitle = displayTitle || title;
const secondaryTitle = detailTitle && detailTitle !== primaryTitle ? detailTitle : '';

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  } catch { return ''; }
}
---

<a
  href={href}
  class="card group block"
  id={slug ? `stop-${slug}` : undefined}
  aria-disabled={href ? undefined : 'true'}
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-baseline gap-2 mb-2">
        {date && (
          <>
            <span class="display text-xl text-muted group-hover:text-ember-2 transition-colors">
              {formatDate(date)}
            </span>
            <span class="display text-xl text-muted" aria-hidden="true">—</span>
          </>
        )}
        <h3 class="display text-xl group-hover:text-ember-2 transition-colors truncate">
          {primaryTitle}
        </h3>
      </div>

      {secondaryTitle && <p class="coord mt-1">{secondaryTitle}</p>}
      {summary && <p class="text-muted text-sm mt-2 line-clamp-2">{summary}</p>}

    </div>
  </div>
</a>
