---
/**
 * StopCard — Compact stop summary for feeds and lists.
 */
interface Props {
  title: string;
  slug?: string;
  tripSlug?: string;
  summary?: string;
  date?: string;
  tripTitle?: string;
  placeName?: string;
  stopType?: string;
}

const { title, slug, tripSlug, summary, date, tripTitle, placeName, stopType } = Astro.props;
const href = slug && tripSlug ? `/trips/${tripSlug}/stops/${slug}` : undefined;

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  } catch { return ''; }
}
---

<a
  href={href}
  class="card group block"
  id={slug ? `stop-${slug}` : undefined}
  aria-disabled={href ? undefined : 'true'}
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-2">
        <span class="inline-symbol" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M12 21s6-5.2 6-11a6 6 0 0 0-12 0c0 5.8 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg>
        </span>
        {stopType && <span class="badge text-[10px] py-0.5">{stopType}</span>}
        {date && <span class="label">{formatDate(date)}</span>}
      </div>

      <h3 class="display text-xl group-hover:text-ember-2 transition-colors truncate">
        {title}
      </h3>

      {placeName && <p class="coord mt-1">{placeName}</p>}
      {summary && <p class="text-muted text-sm mt-2 line-clamp-2">{summary}</p>}

      {tripTitle && (
        <div class="flex items-center gap-2 mt-3">
          <span class="label">Trip</span>
          <span class="text-xs text-dim">{tripTitle}</span>
        </div>
      )}
    </div>
  </div>
</a>
