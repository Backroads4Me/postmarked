---
import Layout from '../layouts/Layout.astro';
import CurrentLocationCard from '../components/ui/CurrentLocationCard.astro';
import LocationUpdateGroup from '../components/ui/LocationUpdateGroup.astro';
import EmptyState from '../components/ui/EmptyState.astro';
import { apiUrl } from '../lib/api.js';
import { loadSiteText, sectionText } from '../lib/siteText.js';

// Fetch home data
let homeData = null;
let error = null;
try {
  const res = await fetch(apiUrl('/api/home'));
  if (res.ok) {
    homeData = await res.json();
  } else {
    error = `API returned ${res.status}`;
  }
} catch (e) {
  error = e?.message || 'Failed to connect to API';
}

const current = homeData?.current_stop;
const activeTrip = homeData?.active_trip_segment;
const nextStop = homeData?.next_stop;
const previousStop = homeData?.previous_stop;
const upcomingStops = homeData?.upcoming_stops ?? [];
const siteText = await loadSiteText();
const currentText = sectionText(siteText, 'home.current', {
  label: 'Currently At',
  heading: 'Current Location',
});
const homeHeaderText = sectionText(siteText, 'home.header', {
  label: 'Welcome to Postmarked',
  heading: 'On the Road',
  body: "Quick updates from the road — where we are, where we've been, and where we're headed.",
});
const upcomingText = sectionText(siteText, 'home.upcoming', {
  label: 'Upcoming',
  heading: 'Up Next',
});
const updatesText = sectionText(siteText, 'home.updates', {
  label: null,
  heading: 'Latest Updates',
  cta_label: 'See full timeline',
  cta_href: '/timeline',
});

function cityStateFromAddress(address) {
  if (!address) return '';
  const parts = address.split(',').map((part) => part.trim()).filter(Boolean);
  if (parts.length < 3) return '';

  const city = parts.at(-2);
  const stateZip = parts.at(-1) || '';
  const state = stateZip.match(/^([A-Z]{2})(?:\s+\d{5}(?:-\d{4})?)?$/)?.[1];
  if (!city || !state) return '';

  return `${city}, ${state}`;
}

function stopCityState(stop) {
  return cityStateFromAddress(stop?.summary || stop?.address || '') || stop?.title || '';
}

function locationDisplayFields(stop) {
  const displayTitle = stopCityState(stop) || stop?.title;
  return {
    displayTitle,
    detailTitle: displayTitle && displayTitle !== stop?.title ? stop?.title : stop?.place_name,
  };
}

function groupHomeUpdates(stops = [], posts = []) {
  const groups = new Map();

  function ensureGroup(stop) {
    if (!stop?.id) return null;
    if (!groups.has(stop.id)) {
      groups.set(stop.id, {
        stop: {
          ...stop,
          ...locationDisplayFields(stop),
        },
        posts: [],
        sortDate: new Date(stop.start_date || 0).getTime(),
      });
    }
    return groups.get(stop.id);
  }

  for (const stop of stops) {
    ensureGroup(stop);
  }

  for (const post of posts) {
    const group = ensureGroup(post.stop);
    if (!group) continue;
    group.posts.push(post);
    group.sortDate = Math.max(group.sortDate, new Date(post.posted_at || 0).getTime());
  }

  return Array.from(groups.values()).sort((a, b) => b.sortDate - a.sortDate);
}

const nextStopMention = nextStop ? { cityState: stopCityState(nextStop), slug: nextStop.slug, tripSlug: nextStop.trip_slug } : undefined;
const prevStopMention = previousStop ? { cityState: stopCityState(previousStop), slug: previousStop.slug, tripSlug: previousStop.trip_slug } : undefined;
const updateGroups = groupHomeUpdates(homeData?.recent_stops || [], homeData?.recent_posts || []);

function formatStopDate(dateStr) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

---

<Layout title="Postmarked">
  <main class="frame py-8 md:py-12">
    {error && (
      <section class="mb-6" aria-live="polite">
        <div class="card-flat text-sm text-paper-2">
          <div class="label mb-1">Reader data unavailable</div>
          <p class="text-muted">The frontend is running, but the API did not return journey data: {error}</p>
        </div>
      </section>
    )}

    <section class="mb-8" id="home-header">
      {homeHeaderText.label && <div class="label mb-2">{homeHeaderText.label}</div>}
      <h1 class="display text-3xl md:text-4xl">{homeHeaderText.heading}</h1>
      {homeHeaderText.body && (
        <p class="lede mt-3 text-sm" style="font-family: var(--sans); max-width: none;">
          {homeHeaderText.body}
        </p>
      )}
    </section>

    {/* ── Hero: Current Location ─────────────────────────────── */}
    <section class="mb-10" id="current-location-section">
      {current ? (
        <CurrentLocationCard
          stopTitle={current.title}
          stopSlug={current.slug}
          tripTitle={activeTrip?.title || 'Current Trip'}
          tripSlug={activeTrip?.slug || ''}
          placeName={current.place_name}
          summary={current.summary}
          arrivalDate={current.start_date}
          nights={current.nights}
          note={current.public_note}
          label={currentText.label}
          prevStop={prevStopMention}
          nextStop={nextStopMention}
        />
      ) : (
        <div class="card-hero">
          <div class="flex items-center gap-3 mb-4">
            <span class="brand-mark" aria-hidden="true"></span>
            {currentText.label && <span class="eyebrow">{currentText.label}</span>}
          </div>
          <h2 class="display text-3xl md:text-4xl mb-3">
            {currentText.heading}
          </h2>
          {currentText.body && <p class="lede text-sm">{currentText.body}</p>}
        </div>
      )}
    </section>

    {/* ── Up Next: Published itinerary ───────────────────────── */}
    {upcomingStops.length > 0 && (
      <section class="mb-10 section-band" id="upcoming-stops">
        <div class="flex items-center justify-between mb-4">
          <div>
            {upcomingText.label && <div class="label mb-1">{upcomingText.label}</div>}
            <h2 class="display text-2xl">{upcomingText.heading}</h2>
            {upcomingText.body && <p class="text-sm text-muted mt-1">{upcomingText.body}</p>}
          </div>
        </div>
        <div class="grid gap-3">
          {upcomingStops.map(stop => (
            <div class="card-flat">
              <div class="flex items-center gap-2 mb-1">
                <span class="badge badge-published text-[10px]">Upcoming</span>
                {stop.start_date && (
                  <span class="label">
                    {new Date(stop.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </span>
                )}
                {stop.nights && stop.nights > 0 && (
                  <span class="label">{stop.nights} night{stop.nights !== 1 ? 's' : ''}</span>
                )}
              </div>
              {cityStateFromAddress(stop.summary || stop.address_label) ? (
                <>
                  <h3 class="display text-lg">{cityStateFromAddress(stop.summary || stop.address_label)}</h3>
                  <p class="coord text-xs mt-1">{stop.title}</p>
                  {stop.address_label && <p class="text-xs text-muted mt-1">{stop.address_label}</p>}
                </>
              ) : (
                <>
                  <h3 class="display text-lg">{stop.title}</h3>
                  {stop.place_name && <p class="coord text-xs mt-1">{stop.place_name}</p>}
                </>
              )}
              {stop.miles_from_previous && (
                <p class="text-xs text-dim mt-1">
                  ~{Math.round(stop.miles_from_previous)} mi from previous
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    {/* ── Recent Updates Feed ────────────────────────────────── */}
    <section id="recent-updates">
      <div class="flex items-center justify-between mb-6">
        <div>
          {updatesText.label && <div class="label mb-1">{updatesText.label}</div>}
          <h2 class="display text-2xl">{updatesText.heading}</h2>
          {updatesText.body && <p class="text-sm text-muted mt-1">{updatesText.body}</p>}
        </div>
        {updatesText.cta_label && updatesText.cta_href && (
          <a href={updatesText.cta_href} class="btn btn-ghost btn-display text-2xl" aria-label="View all timeline updates">
            {updatesText.cta_label}
          </a>
        )}
      </div>

      {updateGroups.length > 0 ? (
        <div class="grid gap-4">
          {updateGroups.map(group => (
            <LocationUpdateGroup stop={group.stop} posts={group.posts} />
          ))}
        </div>
      ) : (
        <EmptyState
          icon=""
          title="No updates yet"
          message="Check back soon for travel stories and photos."
        />
      )}
    </section>

    {/* ── Footer ─────────────────────────────────────────────── */}
    <footer class="mt-16 mb-8 text-center">
      <div class="divider"></div>
      <p class="text-dim text-xs mt-6">
        <a href="/about" class="text-ember hover:text-ember-2 transition-colors">Postmarked</a> — Digital postcards from the road.
      </p>
    </footer>

  </main>
</Layout>
