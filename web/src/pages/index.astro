---
import Layout from '../layouts/Layout.astro';
import CurrentLocationCard from '../components/ui/CurrentLocationCard.astro';
import StopCard from '../components/ui/StopCard.astro';
import PostCard from '../components/ui/PostCard.astro';
import EmptyState from '../components/ui/EmptyState.astro';
import { apiUrl } from '../lib/api.js';
import { loadSiteText, sectionText } from '../lib/siteText.js';

// Fetch home data
let homeData = null;
let error = null;
try {
  const res = await fetch(apiUrl('/api/home'));
  if (res.ok) {
    homeData = await res.json();
  } else {
    error = `API returned ${res.status}`;
  }
} catch (e) {
  error = e?.message || 'Failed to connect to API';
}

const current = homeData?.current_stop;
const activeTrip = homeData?.active_trip_segment;
const updates = [
  ...(homeData?.recent_posts || []).map((post) => ({ kind: 'post', ...post })),
  ...(homeData?.recent_stops || []).map((stop) => ({ kind: 'stop', ...stop })),
].sort((a, b) => {
  const dateA = new Date(a.posted_at || a.start_date || 0).getTime();
  const dateB = new Date(b.posted_at || b.start_date || 0).getTime();
  return dateB - dateA;
});
const nextStop = homeData?.next_stop;
const upcomingPlanned = homeData?.upcoming_planned_stops ?? [];
const siteText = await loadSiteText();
const currentText = sectionText(siteText, 'home.current', {
  label: 'Currently At',
  heading: 'Current Location',
});
const homeHeaderText = sectionText(siteText, 'home.header', {
  label: 'Welcome to Goodpath',
  heading: 'Our RV Adventure',
  body: "A family travel journal — where we are, where we've been, and where we're headed.",
});
const nextText = sectionText(siteText, 'home.next', {
  label: 'Next Up',
  heading: 'Next Up',
});
const plannedText = sectionText(siteText, 'home.planned', {
  label: 'From the trip plan',
  heading: 'Up Next',
});
const updatesText = sectionText(siteText, 'home.updates', {
  label: null,
  heading: 'Latest Updates',
  cta_label: 'View All',
  cta_href: '/timeline',
});

function cityStateFromAddress(address) {
  if (!address) return '';
  const parts = address.split(',').map((part) => part.trim()).filter(Boolean);
  if (parts.length < 3) return '';

  const city = parts.at(-2);
  const stateZip = parts.at(-1) || '';
  const state = stateZip.match(/^([A-Z]{2})(?:\s+\d{5}(?:-\d{4})?)?$/)?.[1];
  if (!city || !state) return '';

  return `${city}, ${state}`;
}

function stopCityState(stop) {
  return cityStateFromAddress(stop?.summary || stop?.address || '') || '';
}

function formatStopDate(dateStr) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

const nextCityState = stopCityState(nextStop);
const nextPrimaryTitle = nextStop ? nextCityState || nextStop.title : '';
const nextSecondaryTitle = nextStop
  ? nextCityState
    ? nextStop.title
    : nextStop.place_name && nextStop.place_name !== nextStop.title
      ? nextStop.place_name
      : ''
  : '';
---

<Layout title="Goodpath — Where Are We Now?">
  <main class="frame py-8 md:py-12">
    {error && (
      <section class="mb-6" aria-live="polite">
        <div class="card-flat text-sm text-paper-2">
          <div class="label mb-1">Reader data unavailable</div>
          <p class="text-muted">The frontend is running, but the API did not return journey data: {error}</p>
        </div>
      </section>
    )}

    <section class="mb-8" id="home-header">
      {homeHeaderText.label && <div class="label mb-2">{homeHeaderText.label}</div>}
      <h1 class="display text-3xl md:text-4xl">{homeHeaderText.heading}</h1>
      {homeHeaderText.body && (
        <p class="lede mt-3 text-sm" style="font-family: var(--sans);">
          {homeHeaderText.body}
        </p>
      )}
    </section>

    {/* ── Hero: Current Location ─────────────────────────────── */}
    <section class="mb-10" id="current-location-section">
      {current ? (
        <CurrentLocationCard
          stopTitle={current.title}
          stopSlug={current.slug}
          tripTitle={activeTrip?.title || 'Current Trip'}
          tripSlug={activeTrip?.slug || ''}
          placeName={current.place_name}
          summary={current.summary}
          arrivalDate={current.start_date}
          nights={current.nights}
          note={current.public_note}
          label={currentText.label}
        />
      ) : (
        <div class="card-hero">
          <div class="flex items-center gap-3 mb-4">
            <span class="brand-mark" aria-hidden="true"></span>
            {currentText.label && <span class="eyebrow">{currentText.label}</span>}
          </div>
          <h2 class="display text-3xl md:text-4xl mb-3">
            {currentText.heading}
          </h2>
          {currentText.body && <p class="lede text-sm">{currentText.body}</p>}
        </div>
      )}
    </section>

    {/* ── Next Stop ──────────────────────────────────────────── */}
    {nextStop && (
      <section class="mb-10" id="next-stop-section">
        <div class="card-hero">
          <div class="flex items-center gap-3 mb-4">
            <span class="brand-mark" aria-hidden="true"></span>
            {nextText.label && <span class="eyebrow">{nextText.label}</span>}
          </div>
          <h3 class="display text-3xl md:text-4xl mb-2">
            <a href={`/trips/${nextStop.trip_slug}/stops/${nextStop.slug}`} class="hover:text-ember-2 transition-colors">
              {nextPrimaryTitle}
            </a>
          </h3>
          {nextSecondaryTitle && (
            <p class="coord mb-1">{nextSecondaryTitle}</p>
          )}
          {nextCityState && nextStop.summary && (
            <p class="text-sm text-muted mb-4">{nextStop.summary}</p>
          )}
          <div class="flex flex-wrap gap-4 text-sm">
            {nextStop.start_date && (
              <div class="flex flex-col">
                <span class="current-meta-label mb-1">Arriving</span>
                <span class="current-meta-value">{formatStopDate(nextStop.start_date)}</span>
              </div>
            )}
            {nextStop.nights && nextStop.nights > 0 && (
              <div class="flex flex-col">
                <span class="current-meta-label mb-1">Staying</span>
                <span class="current-meta-value">{nextStop.nights} night{nextStop.nights !== 1 ? 's' : ''}</span>
              </div>
            )}
            <div class="flex flex-col">
              <span class="current-meta-label mb-1">Trip</span>
              <a href={`/trips/${nextStop.trip_slug}`} class="current-meta-value hover:text-ember-2 transition-colors">
                {nextStop.trip_title || activeTrip?.title || 'Current Trip'}
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    {/* ── Up Next: Planned Itinerary ─────────────────────────── */}
    {upcomingPlanned.length > 0 && (
      <section class="mb-10 section-band" id="upcoming-planned">
        <div class="flex items-center justify-between mb-4">
          <div>
            {plannedText.label && <div class="label mb-1">{plannedText.label}</div>}
            <h2 class="display text-2xl">{plannedText.heading}</h2>
            {plannedText.body && <p class="text-sm text-muted mt-1">{plannedText.body}</p>}
          </div>
        </div>
        <div class="grid gap-3">
          {upcomingPlanned.map(p => (
            <div class="card-flat">
              <div class="flex items-center gap-2 mb-1">
                <span class="badge badge-planned text-[10px]">Planned</span>
                {p.arrival_date && (
                  <span class="label">
                    {new Date(p.arrival_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </span>
                )}
                {p.nights && p.nights > 0 && (
                  <span class="label">{p.nights} night{p.nights !== 1 ? 's' : ''}</span>
                )}
              </div>
              {cityStateFromAddress(p.address) ? (
                <>
                  <h3 class="display text-lg">{cityStateFromAddress(p.address)}</h3>
                  <p class="coord text-xs mt-1">{p.name}</p>
                  <p class="text-xs text-muted mt-1">{p.address}</p>
                </>
              ) : (
                <>
                  <h3 class="display text-lg">{p.name}</h3>
                  {p.address && <p class="coord text-xs mt-1">{p.address}</p>}
                </>
              )}
              {p.miles_from_previous && (
                <p class="text-xs text-dim mt-1">
                  ~{Math.round(p.miles_from_previous)} mi from previous
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    {/* ── Recent Updates Feed ────────────────────────────────── */}
    <section id="recent-updates">
      <div class="flex items-center justify-between mb-6">
        <div>
          {updatesText.label && <div class="label mb-1">{updatesText.label}</div>}
          <h2 class="display text-2xl">{updatesText.heading}</h2>
          {updatesText.body && <p class="text-sm text-muted mt-1">{updatesText.body}</p>}
        </div>
        {updatesText.cta_label && updatesText.cta_href && (
          <a href={updatesText.cta_href} class="btn btn-sm btn-ghost" aria-label="View all timeline updates">
            {updatesText.cta_label}
          </a>
        )}
      </div>

      {updates.length > 0 ? (
        <div class="grid gap-4">
          {updates.map(item => (
            item.kind === 'post' ? (
              <PostCard
                title={item.title}
                body={item.body}
                date={item.posted_at}
                tripTitle={item.stop?.trip_title}
                placeName={item.stop?.place_name}
                media={item.media}
              />
            ) : (
              <StopCard
                title={item.title}
                displayTitle={stopCityState(item) || item.title}
                detailTitle={stopCityState(item) ? item.title : item.place_name}
                slug={item.slug}
                tripSlug={item.trip_slug}
                summary={item.summary}
                date={item.start_date}
                tripTitle={item.trip_title}
                placeName={item.place_name}
              />
            )
          ))}
        </div>
      ) : (
        <EmptyState
          icon=""
          title="No updates yet"
          message="Check back soon for travel stories and photos."
        />
      )}
    </section>

    {/* ── Footer ─────────────────────────────────────────────── */}
    <footer class="mt-16 mb-8 text-center">
      <div class="divider"></div>
      <p class="text-dim text-xs mt-6">
        <span class="text-ember">Goodpath</span> — A self-hosted RV travel journal
      </p>
    </footer>

  </main>
</Layout>
