---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Forgot Password">
  <div class="frame min-h-screen flex items-center justify-center py-20">
    <div class="w-full max-w-sm bg-surface p-8 rounded-lg border border-line shadow-1">
      <div class="mb-8 text-center">
        <h1 class="display text-3xl mb-2">Reset Password</h1>
        <p class="text-sm text-muted">Enter your email and we will send a reset link.</p>
      </div>

      <div id="message-banner" class="hidden mb-4 p-3 rounded border text-sm"></div>

      <form class="flex flex-col gap-4" onsubmit="event.preventDefault(); requestReset(this);">
        <div class="flex flex-col gap-1">
          <label class="label" for="email">Email address</label>
          <input type="email" id="email" name="email" class="form-input" required>
        </div>

        <button type="submit" id="submit-btn" class="btn btn-primary justify-center mt-4">Send reset link</button>
      </form>

      <div class="mt-6 text-center">
        <a href="/auth/login" class="text-sm text-muted hover:text-ember transition-colors">Back to sign in</a>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  async function requestReset(form) {
    const btn = document.getElementById('submit-btn');
    const banner = document.getElementById('message-banner');
    banner.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      await fetch('/api/auth/forgot-password', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: form.email.value }),
      });
      showMessage('If that email exists, a reset link has been sent.', false);
    } catch (err) {
      showMessage('Could not reach the server. Try again.', true);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send reset link';
    }

    function showMessage(msg, error) {
      banner.textContent = msg;
      banner.style.color = error ? 'var(--ember)' : 'var(--paper)';
      banner.style.borderColor = error ? 'var(--ember)' : 'var(--line)';
      banner.style.background = error ? 'var(--ember-glow)' : 'var(--surface-2)';
      banner.classList.remove('hidden');
    }
  }
</script>
