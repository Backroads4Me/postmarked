---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Reset Password">
  <div class="frame min-h-screen flex items-center justify-center py-20">
    <div class="w-full max-w-sm bg-surface p-8 rounded-lg border border-line shadow-1">
      <div class="mb-8 text-center">
        <h1 class="display text-3xl mb-2">Choose New Password</h1>
        <p class="text-sm text-muted">Set a new password for your account.</p>
      </div>

      <div id="message-banner" class="hidden mb-4 p-3 rounded border text-sm"></div>

      <form class="flex flex-col gap-4" onsubmit="event.preventDefault(); resetPassword(this);">
        <div class="flex flex-col gap-1">
          <label class="label" for="password">New password</label>
          <input type="password" id="password" name="password" class="form-input" required minlength="8">
        </div>

        <button type="submit" id="submit-btn" class="btn btn-primary justify-center mt-4">Reset password</button>
      </form>

      <div class="mt-6 text-center">
        <a href="/auth/login" class="text-sm text-muted hover:text-ember transition-colors">Back to sign in</a>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const token = new URLSearchParams(window.location.search).get('token') || '';

  async function resetPassword(form) {
    const btn = document.getElementById('submit-btn');
    const banner = document.getElementById('message-banner');
    banner.classList.add('hidden');
    if (!token) {
      showMessage('The reset link is missing a token.', true);
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Resetting…';

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password: form.password.value }),
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.detail || 'Could not reset password.');
      }
      showMessage('Password updated. You can sign in now.', false);
    } catch (err) {
      showMessage(err.message || 'Could not reset password.', true);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Reset password';
    }

    function showMessage(msg, error) {
      banner.textContent = msg;
      banner.style.color = error ? 'var(--ember)' : 'var(--paper)';
      banner.style.borderColor = error ? 'var(--ember)' : 'var(--line)';
      banner.style.background = error ? 'var(--ember-glow)' : 'var(--surface-2)';
      banner.classList.remove('hidden');
    }
  }
</script>
