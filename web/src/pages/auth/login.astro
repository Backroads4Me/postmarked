---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Login">
  <div class="frame min-h-screen flex items-center justify-center py-8">
    <div class="w-full max-w-sm bg-surface p-8 rounded-lg border border-line shadow-1">
      <div class="mb-8 text-center">
        <h1 class="display text-3xl mb-2">Welcome Back</h1>
        <p class="text-sm text-muted">Sign in to your account</p>
      </div>

      <div id="error-banner" class="alert alert-danger hidden mb-4"></div>

      <form class="flex flex-col gap-4" onsubmit="event.preventDefault(); login(this);">
        <div class="flex flex-col gap-1">
          <label class="label" for="email">Email address</label>
          <input type="email" id="email" name="email" class="form-input" required>
        </div>

        <div class="flex flex-col gap-1">
          <label class="label" for="password">Password</label>
          <input type="password" id="password" name="password" class="form-input" required>
        </div>

        <button type="submit" id="submit-btn" class="btn btn-primary justify-center mt-4">Sign In</button>
      </form>

      <div class="mt-6 text-center">
        <a href="/auth/register" class="text-sm text-muted hover:text-ember transition-colors">Create an account</a>
        <span class="text-sm text-muted px-2">·</span>
        <a href="/auth/forgot-password" class="text-sm text-muted hover:text-ember transition-colors">Forgot password?</a>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const nextPath = new URLSearchParams(window.location.search).get('next') || '/';

  async function login(form) {
    const btn = document.getElementById('submit-btn');
    const banner = document.getElementById('error-banner');
    banner.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Signing in…';

    const formData = new URLSearchParams();
    formData.append('username', form.email.value);
    formData.append('password', form.password.value);

    try {
      const res = await fetch('/api/auth/jwt/login', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: formData.toString(),
      });

      if (res.ok) {
        window.location.href = nextPath.startsWith('/') ? nextPath : '/';
      } else {
        const data = await res.json().catch(() => ({}));
        showError(data.detail || 'Invalid email or password.');
      }
    } catch (err) {
      showError('Could not reach the server. Try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Sign In';
    }

    function showError(msg) {
      banner.textContent = msg;
      banner.classList.remove('hidden');
    }
  }
</script>
