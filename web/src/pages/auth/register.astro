---
import Layout from '../../layouts/Layout.astro';
import { apiUrl } from '../../lib/api.js';

const isSubscribeIntent = Astro.url.searchParams.get('subscribe') === '1';
const configRes = await fetch(apiUrl('/api/config'));
const { email_enabled, require_user_approval, sms_enabled } = await configRes.json();
---

<Layout title="Register">
  <div class="frame min-h-screen flex items-center justify-center py-8">
    <div class="w-full max-w-2xl bg-surface p-8 rounded-lg border border-line shadow-1">

      <!-- Success state: shown after registration -->
      <div id="success-panel" class="hidden text-center">
        <div class="text-3xl mb-4">&#10003;</div>
        {require_user_approval ? (
          <>
            <h2 class="display text-2xl mb-2">Request received!</h2>
            <p class="text-sm text-muted mb-6">Your account is pending approval. The owner will review and activate your access shortly.</p>
          </>
        ) : (
          <>
            <h2 class="display text-2xl mb-2">You're in!</h2>
            <p class="text-sm text-muted mb-6">Your account is ready. You can sign in now.</p>
          </>
        )}
        <a href="/auth/login" class="btn justify-center">Sign In</a>
      </div>

      <!-- Registration form -->
      <div id="form-panel">
        <div class="mb-8 text-center">
          <h1 class="display text-3xl mb-2">{isSubscribeIntent && email_enabled ? 'Subscribe to Updates' : 'Join Postmarked'}</h1>
          {isSubscribeIntent && email_enabled && <p class="text-sm text-muted mb-3">Create an account and choose how you'd like to hear about updates.</p>}
          <a href="/auth/login" class="text-sm text-muted hover:text-ember transition-colors">Already have an account? Sign in</a>
        </div>

        <div id="error-banner" class="hidden mb-4 p-3 rounded border text-sm" style="color: var(--ember); border-color: var(--ember); background: var(--ember-glow);"></div>

        <form class="flex flex-col gap-4" onsubmit="event.preventDefault(); register(this);">
          <div class="flex flex-col gap-1">
            <label class="label" for="display_name">Display name</label>
            <input type="text" id="display_name" name="display_name" class="bg-surface-2 border border-line-soft rounded p-3 text-sm focus:border-ember focus:outline-none transition-colors" placeholder="How you'll appear to others" required>
          </div>

          <div class="flex flex-col gap-1">
            <label class="label" for="email">Email address</label>
            <input type="email" id="email" name="email" class="bg-surface-2 border border-line-soft rounded p-3 text-sm focus:border-ember focus:outline-none transition-colors" required>
          </div>

          <div class="flex flex-col gap-1">
            <label class="label" for="password">Password</label>
            <input type="password" id="password" name="password" class="bg-surface-2 border border-line-soft rounded p-3 text-sm focus:border-ember focus:outline-none transition-colors" required minlength="8">
          </div>

          {(email_enabled || sms_enabled) && (
            <fieldset class="flex flex-col gap-4 pt-4 border-t border-line">
              <legend class="label text-base">Notifications <span class="font-normal text-muted">(optional)</span></legend>

              <div class="flex flex-col gap-2">
                <p class="label">Channels</p>

                {email_enabled && (
                  <label class="flex items-center gap-3 text-sm cursor-pointer">
                    <input type="checkbox" name="email_notify" class="shrink-0" />
                    <span class="text-paper">Email updates</span>
                  </label>
                )}

                {sms_enabled && (
                  <div class="flex flex-col gap-3">
                    <div class="flex flex-col gap-1">
                      <label class="label" for="phone_number">Phone number <span class="text-muted font-normal">(optional)</span></label>
                      <input type="tel" id="phone_number" name="phone_number"
                        class="bg-surface-2 border border-line-soft rounded p-3 text-sm focus:border-ember focus:outline-none transition-colors"
                        placeholder="5551234567"
                        oninput="onPhoneInput(this)"
                        onblur="normalizePhone(this)" />
                    </div>
                    <label class="flex items-start gap-3 text-sm text-muted cursor-pointer">
                      <input type="checkbox" name="sms_opted_in" id="sms_opted_in" class="mt-0.5 shrink-0"
                        onchange="onSmsOptInChange(this)" />
                      <span>
                        <strong class="text-paper">Text message updates</strong><br />
                        By selecting this box, you agree to receive SMS notifications about trip updates from Postmarked.
                        Message frequency varies. Message &amp; data rates may apply.
                        Reply STOP to opt out at any time or HELP for help.
                        <a href="/privacy" class="underline hover:text-ember transition-colors">Privacy Policy</a> &amp; <a href="/terms" class="underline hover:text-ember transition-colors">Terms</a>.
                      </span>
                    </label>
                  </div>
                )}
              </div>

              <div class="flex flex-col gap-2">
                <p class="label">Frequency</p>
                <label class="flex items-start gap-3 text-sm text-muted cursor-pointer">
                  <input type="radio" name="notify_frequency" value="all_updates" class="mt-0.5 shrink-0" checked />
                  <span><strong class="text-paper">Immediately</strong><br />As soon as new updates are posted.</span>
                </label>
                <label class="flex items-start gap-3 text-sm text-muted cursor-pointer">
                  <input type="radio" name="notify_frequency" value="weekly_digest" class="mt-0.5 shrink-0" />
                  <span><strong class="text-paper">Weekly</strong><br />A weekly roundup sent every Monday morning.</span>
                </label>
              </div>
            </fieldset>
          )}

          <button type="submit" id="submit-btn" class="btn justify-center mt-4">Create account</button>
        </form>

      </div>

    </div>
  </div>
</Layout>

<script is:inline>
  function showError(msg) {
    const banner = document.getElementById('error-banner');
    if (!banner) return;
    banner.textContent = msg;
    banner.classList.remove('hidden');
  }

  function clearError() {
    document.getElementById('error-banner')?.classList.add('hidden');
  }

  function normalizePhone(phoneEl) {
    let digits = phoneEl.value.replace(/\D/g, '');
    if (digits.length === 11 && digits.startsWith('1')) digits = digits.slice(1);
    phoneEl.value = digits;
    const optIn = document.getElementById('sms_opted_in');
    if (digits && optIn && !optIn.checked) {
      showError('Check the "Text message updates" box to opt in to SMS notifications, or clear the phone number if you don\'t want updates.');
    }
  }

  function onPhoneInput(phoneEl) {
    if (!phoneEl.value.trim()) clearError();
  }

  function onSmsOptInChange(checkbox) {
    const phone = document.getElementById('phone_number');
    if (checkbox.checked) {
      if (!phone || !phone.value.trim()) {
        phone?.focus();
        showError('Enter a phone number to receive text message updates.');
      } else {
        clearError();
      }
    } else {
      if (phone) phone.value = '';
      clearError();
    }
  }

  async function register(form) {
    const btn = document.getElementById('submit-btn');
    const banner = document.getElementById('error-banner');
    banner.classList.add('hidden');

    const emailOn = form.email_notify?.checked ?? false;
    const smsOn = form.sms_opted_in?.checked ?? false;
    const phone = form.phone_number?.value?.trim() || '';
    const freq = form.notify_frequency?.value ?? 'all_updates';

    if (smsOn && !phone) {
      showError('Enter a phone number to enable text message updates.');
      return;
    }
    if (phone && phone.replace(/\D/g, '').length !== 10) {
      showError('Enter a valid 10-digit phone number.');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Creating account…';

    try {
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: form.email.value,
          password: form.password.value,
          display_name: form.display_name.value.trim() || null,
          email_opted_in: emailOn,
          notification_frequency: freq,
          phone_number: form.phone_number?.value?.trim() || null,
          sms_opted_in: smsOn,
        }),
      });

      if (res.ok) {
        document.getElementById('form-panel').classList.add('hidden');
        document.getElementById('success-panel').classList.remove('hidden');
      } else {
        const data = await res.json().catch(() => ({}));
        const detail = data.detail;
        let msg = 'Registration failed. Please try again.';
        if (typeof detail === 'string') msg = detail;
        else if (Array.isArray(detail)) msg = detail.map(d => d.msg).join(' ');
        showError(msg);
      }
    } catch (err) {
      showError('Could not reach the server. Try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Create account';
    }

  }
</script>
