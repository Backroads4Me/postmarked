---
import Layout from '../layouts/Layout.astro';
import { apiUrl } from '../lib/api.js';

const cookie = Astro.request.headers.get('cookie') || '';
const [res, configRes] = await Promise.all([
  fetch(apiUrl('/api/account'), { headers: cookie ? { cookie } : {} }),
  fetch(apiUrl('/api/config')),
]);
if (res.status === 401 || res.status === 403) {
  return Astro.redirect('/auth/login?next=/account');
}
if (!res.ok) {
  throw new Error(`Account API returned ${res.status}`);
}
const account = await res.json();
const configData = configRes.ok ? await configRes.json().catch(() => ({})) : {};
const email_enabled = configData.email_enabled ?? false;
const sms_enabled = configData.sms_enabled ?? false;
---

<Layout title="Account — Postmarked">
  <main class="frame py-16">
    <section class="max-w-2xl mx-auto">
      <div class="mb-8">
        <h1 class="display text-4xl mb-2">Account</h1>
        <p class="text-muted">Manage your profile, password, and notification preferences.</p>
      </div>

      <div id="message-banner" class="alert hidden mb-6"></div>

      <div class="grid gap-6">
        <section class="bg-surface border border-line rounded-lg p-6">
          <h2 class="display text-2xl mb-4">Profile</h2>
          <form class="grid gap-4" onsubmit="event.preventDefault(); updateProfile(this);">
            <div class="grid gap-1">
              <label class="label" for="display_name">Display name</label>
              <input id="display_name" name="display_name" value={account.display_name || ''} class="form-input" />
            </div>
            <div class="grid gap-1">
              <label class="label" for="email">Email address</label>
              <input id="email" name="email" type="email" value={account.email} required class="form-input" />
            </div>
            <div class="flex flex-wrap items-center gap-3 sm:justify-self-start">
              <button type="submit" class="btn btn-primary justify-center">Save changes</button>
              <button type="button" class="btn justify-center" onclick="signOut()">Sign out</button>
            </div>
          </form>
        </section>

        {(email_enabled || sms_enabled) && (
          <section id="notifications" class="bg-surface border border-line rounded-lg p-6">
            <h2 class="display text-2xl mb-1">Notifications</h2>
            <p class="text-sm text-muted mb-5">Choose how you'd like to hear about new updates.</p>
            <form class="grid gap-6" onsubmit="event.preventDefault(); updateNotifications(this);">

              <div class="grid gap-3">
                <p class="label">Channels</p>

                {email_enabled && (
                  <label class="flex items-center gap-3 text-sm cursor-pointer">
                    <input type="checkbox" name="email_notify" class="shrink-0"
                      checked={account.email_opted_in} />
                    <span class="text-paper">Email updates</span>
                  </label>
                )}

                {sms_enabled && (
                  <div class="flex flex-col gap-3">
                    <div class="grid gap-1">
                      <label class="label" for="phone_number">Phone number <span class="text-muted font-normal">(optional)</span></label>
                      <input id="phone_number" name="phone_number" type="tel"
                        value={account.phone_number || ''}
                        placeholder="5551234567"
                        class="form-input"
                        onblur="normalizePhone(this)" />
                    </div>
                    <label class="flex items-start gap-3 text-sm text-muted cursor-pointer">
                      <input type="checkbox" name="sms_opted_in" id="sms_opted_in" class="mt-0.5 shrink-0"
                        checked={account.sms_opted_in}
                        onchange="onSmsOptInChange(this)" />
                      <span>
                        <strong class="text-paper">Text message updates</strong><br />
                        By selecting this box, you agree to receive SMS notifications about trip updates from Postmarked.
                        Message frequency varies. Message &amp; data rates may apply.
                        Reply STOP to opt out at any time or HELP for help.
                        <a href="/privacy" class="underline hover:text-ember transition-colors">Privacy Policy</a> &amp; <a href="/terms" class="underline hover:text-ember transition-colors">Terms</a>.
                      </span>
                    </label>
                  </div>
                )}
              </div>

              <div class="grid gap-3">
                <p class="label">Frequency</p>
                <label class="flex items-start gap-3 text-sm text-muted cursor-pointer">
                  <input type="radio" name="notify_frequency" value="all_updates" class="mt-0.5 shrink-0"
                    checked={account.notification_frequency !== 'weekly_digest'} />
                  <span><strong class="text-paper">Immediately</strong><br />As soon as new updates are posted.</span>
                </label>
                <label class="flex items-start gap-3 text-sm text-muted cursor-pointer">
                  <input type="radio" name="notify_frequency" value="weekly_digest" class="mt-0.5 shrink-0"
                    checked={account.notification_frequency === 'weekly_digest'} />
                  <span><strong class="text-paper">Weekly</strong><br />A weekly roundup sent every Monday morning.</span>
                </label>
              </div>

              <button type="submit" class="btn btn-primary justify-center sm:justify-self-start">Save notification preferences</button>
            </form>
          </section>
        )}

        <section class="bg-surface border border-line rounded-lg p-6">
          <h2 class="display text-2xl mb-4">Password</h2>
          <form class="grid gap-4" onsubmit="event.preventDefault(); updatePassword(this);">
            <div class="grid gap-1">
              <label class="label" for="current_password">Current password</label>
              <input id="current_password" name="current_password" type="password" required class="form-input" />
            </div>
            <div class="grid gap-1">
              <label class="label" for="new_password">New password</label>
              <input id="new_password" name="new_password" type="password" required minlength="8" class="form-input" />
            </div>
            <button type="submit" class="btn btn-primary justify-center sm:justify-self-start">Update password</button>
          </form>
        </section>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  async function updateProfile(form) {
    await saveJson('/api/account/profile', {
      display_name: form.display_name.value.trim() || null,
      email: form.email.value,
    }, 'Profile saved.');
  }

  function normalizePhone(phoneEl) {
    let digits = phoneEl.value.replace(/\D/g, '');
    if (digits.length === 11 && digits.startsWith('1')) digits = digits.slice(1);
    phoneEl.value = digits;
    const optIn = document.getElementById('sms_opted_in');
    if (digits && optIn && !optIn.checked) {
      showMessage('Check the "Text message updates" box to opt in to SMS notifications, or clear the phone number if you don\'t want updates.', true);
    }
  }

  function onSmsOptInChange(checkbox) {
    const phone = document.getElementById('phone_number');
    if (checkbox.checked) {
      if (!phone || !phone.value.trim()) {
        phone?.focus();
        showMessage('Enter a phone number to receive text message updates.', true);
      }
    } else {
      if (phone) phone.value = '';
    }
  }

  async function updateNotifications(form) {
    const emailOn = form.email_notify?.checked ?? false;
    const smsOn = form.sms_opted_in?.checked ?? false;
    const phone = form.phone_number?.value?.trim() || '';
    const freq = form.notify_frequency.value;

    if (smsOn && !phone) {
      showMessage('Enter a phone number to enable text message updates.', true);
      return;
    }
    if (phone && phone.replace(/\D/g, '').length !== 10) {
      showMessage('Enter a valid 10-digit phone number.', true);
      return;
    }

    await saveJson('/api/account/notifications', {
      email_opted_in: emailOn,
      notification_frequency: freq,
      phone_number: phone || null,
      sms_opted_in: smsOn,
    }, 'Notification preferences saved.');
  }

  async function updatePassword(form) {
    await saveJson('/api/account/password', {
      current_password: form.current_password.value,
      new_password: form.new_password.value,
    }, 'Password updated.');
    form.reset();
  }

  async function signOut() {
    try {
      await fetch('/api/auth/jwt/logout', {
        method: 'POST',
        credentials: 'include',
      });
    } finally {
      window.location.href = '/auth/login';
    }
  }

  async function saveJson(path, payload, successMessage) {
    try {
      const res = await fetch(path, {
        method: 'PATCH',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.detail || 'Save failed.');
      }
      showMessage(successMessage, false);
    } catch (err) {
      showMessage(err.message || 'Save failed.', true);
    }
  }

  function showMessage(msg, error) {
    const banner = document.getElementById('message-banner');
    banner.textContent = msg;
    banner.classList.toggle('alert-danger', error);
    banner.classList.toggle('alert-success', !error);
    banner.classList.remove('hidden');
  }
</script>
