---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { apiUrl } from '../../lib/api.js';

let sections = [];
const cookie = Astro.request.headers.get('cookie');

try {
  const res = await fetch(apiUrl('/api/admin/site-text'), {
    headers: cookie ? { cookie } : {}
  });

  if (res.status === 401 || res.status === 403) {
    return Astro.redirect('/auth/login');
  }

  if (res.ok) {
    sections = await res.json();
  }
} catch (e) {
  console.error('Failed to load site text', e);
}

const pageLabels = {
  home: 'Home',
  trips: 'Trips',
  timeline: 'Timeline',
  email: 'Email',
};

const buttonSections = new Set(['home.updates']);
const sectionFields = {
  'home.header': ['heading', 'body'],
  'home.current': ['label'],
  'home.next': ['label'],
  'home.upcoming': ['heading', 'body'],
  'home.updates': ['heading', 'body', 'cta_label', 'cta_href'],
  'trips.header': ['heading', 'body'],
  'timeline.header': ['heading', 'body'],
  'email.post_notification': ['heading', 'body', 'cta_label'],
};

const fieldHints: Record<string, Partial<Record<string, string>>> = {
  'email.post_notification': {
    heading: 'Use {post_title} to include the post title.',
    body: 'Use {post_title} to include the post title.',
  },
};

function sectionKey(section) {
  return `${section.page_key}.${section.section_key}`;
}

function hasField(section, field) {
  return sectionFields[sectionKey(section)]?.includes(field) ?? false;
}
---

<AdminLayout title="Site Text">

  <div id="site-text-list" class="grid gap-5">
    {sections.map(section => (
      <form
        class="bg-surface-2 border border-line rounded p-4 grid gap-4 site-text-form"
        data-page-key={section.page_key}
        data-section-key={section.section_key}
      >
        <div class="flex items-center justify-between gap-4">
          <div>
            <div class="label mb-1">{pageLabels[section.page_key] || section.page_key}</div>
            <h2 class="display text-xl capitalize">{section.section_key.replaceAll('-', ' ')}</h2>
          </div>
          <span class="text-xs text-muted font-mono form-status" aria-live="polite"></span>
        </div>

        {!hasField(section, 'label') && <input type="hidden" name="label" value={section.label || ''} />}
        {!hasField(section, 'heading') && <input type="hidden" name="heading" value={section.heading || ''} />}
        {!hasField(section, 'body') && <input type="hidden" name="body" value={section.body || ''} />}
        {!hasField(section, 'cta_label') && <input type="hidden" name="cta_label" value={section.cta_label || ''} />}
        {!hasField(section, 'cta_href') && <input type="hidden" name="cta_href" value={section.cta_href || ''} />}

        {(hasField(section, 'label') || hasField(section, 'heading')) && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {hasField(section, 'label') && (
              <label class="grid gap-2 text-sm font-bold">
                Label
                <input name="label" value={section.label || ''} class="bg-surface-1 border border-line p-3 font-normal" />
              </label>
            )}
            {hasField(section, 'heading') && (
              <label class="grid gap-2 text-sm font-bold">
                Heading
                <input name="heading" value={section.heading || ''} required class="bg-surface-1 border border-line p-3 font-normal" />
                {fieldHints[sectionKey(section)]?.heading && (
                  <span class="text-xs text-muted font-normal">{fieldHints[sectionKey(section)]?.heading}</span>
                )}
              </label>
            )}
          </div>
        )}

        {hasField(section, 'body') && (
          <label class="grid gap-2 text-sm font-bold">
            Body
            <textarea name="body" rows="3" class="bg-surface-1 border border-line p-3 font-normal">{section.body || ''}</textarea>
            {fieldHints[sectionKey(section)]?.body && (
              <span class="text-xs text-muted font-normal">{fieldHints[sectionKey(section)]?.body}</span>
            )}
          </label>
        )}

        {buttonSections.has(`${section.page_key}.${section.section_key}`) && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <label class="grid gap-2 text-sm font-bold">
              Button Label
              <input name="cta_label" value={section.cta_label || ''} class="bg-surface-1 border border-line p-3 font-normal" />
            </label>
            <label class="grid gap-2 text-sm font-bold">
              Button Link
              <input name="cta_href" value={section.cta_href || ''} class="bg-surface-1 border border-line p-3 font-normal" />
            </label>
          </div>
        )}

        {!buttonSections.has(`${section.page_key}.${section.section_key}`) && hasField(section, 'cta_label') && (
          <label class="grid gap-2 text-sm font-bold">
            Link Text
            <input name="cta_label" value={section.cta_label || ''} class="bg-surface-1 border border-line p-3 font-normal" />
          </label>
        )}

        <div>
          <button type="submit" class="btn btn-sm">Save Text</button>
        </div>
      </form>
    ))}
  </div>

  <script>
    document.querySelectorAll('.site-text-form').forEach((form) => {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const target = event.currentTarget as HTMLFormElement;
        const status = target.querySelector('.form-status');
        const pageKey = target.dataset.pageKey;
        const sectionKey = target.dataset.sectionKey;
        const data = Object.fromEntries(new FormData(target).entries());

        if (status) status.textContent = 'Saving...';

        try {
          const res = await fetch(`/api/admin/site-text/${pageKey}/${sectionKey}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(data),
          });

          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            throw new Error(err.detail || `HTTP ${res.status}`);
          }

          if (status) status.textContent = 'Saved';
        } catch (error) {
          if (status) status.textContent = error instanceof Error ? error.message : 'Save failed';
        }
      });
    });
  </script>
</AdminLayout>
