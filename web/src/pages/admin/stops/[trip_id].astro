---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

const { trip_id } = Astro.params;
const cookie = Astro.request.headers.get('cookie');

let trip = null;
let stops = [];

try {
  const [tripsRes, stopsRes] = await Promise.all([
    fetch(apiUrl('/api/admin/trips'), { headers: cookie ? { cookie } : {} }),
    fetch(apiUrl('/api/admin/stops'), { headers: cookie ? { cookie } : {} }),
  ]);

  if (tripsRes.status === 401 || tripsRes.status === 403) return Astro.redirect('/auth/login');

  if (tripsRes.ok) {
    const all = await tripsRes.json();
    trip = all.find(t => t.id === trip_id);
  }
  if (stopsRes.ok) {
    const all = await stopsRes.json();
    stops = all.filter(s => s.trip_id === trip_id);
  }
} catch (e) {
  console.error(e);
}

if (!trip) return Astro.redirect('/admin/stops');

function formatDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<AdminLayout title={`Stops — ${trip.title}`}>
  <div class="mb-8 flex justify-between items-start">
    <div>
      <a href="/admin/stops" class="text-xs font-mono uppercase tracking-widest text-dim hover:text-ember mb-3 inline-block">← All Trips</a>
      <div class="label mb-1">Stops</div>
      <h1 class="display text-3xl">{trip.title}</h1>
    </div>
    <button type="button" id="show-add-form" class="btn btn-sm">+ Add Stop</button>
  </div>

  {/* Add stop form (hidden by default) */}
  <div id="add-stop-form-wrap" class="hidden card-flat mb-8">
    <h2 class="text-lg font-semibold mb-4">New Stop</h2>
    <form id="add-stop-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <input type="hidden" name="trip_id" value={trip.id} />

      <div class="flex flex-col gap-1 md:col-span-2">
        <label class="text-xs font-bold">Title *</label>
        <input type="text" name="title" required maxlength="200"
          class="bg-surface-2 border border-line p-2 text-sm focus:border-ember" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Slug *</label>
        <input type="text" name="slug" required
          class="bg-surface-2 border border-line p-2 text-sm" placeholder="auto-filled from title" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Place Name</label>
        <input type="text" name="place_name"
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Latitude *</label>
        <input type="number" name="latitude" step="any" required min="-90" max="90"
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Longitude *</label>
        <input type="number" name="longitude" step="any" required min="-180" max="180"
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Start Date *</label>
        <input type="datetime-local" name="start_date" required
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">End Date</label>
        <input type="datetime-local" name="end_date"
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Type</label>
        <select name="stop_type" class="bg-surface-2 border border-line p-2 text-sm">
          <option value="campground">Campground</option>
          <option value="boondocking">Boondocking</option>
          <option value="overnight">Overnight</option>
          <option value="attraction">Attraction</option>
          <option value="restaurant">Restaurant</option>
          <option value="service">Service</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Status</label>
        <select name="status" class="bg-surface-2 border border-line p-2 text-sm">
          <option value="active">Active</option>
          <option value="planned">Planned</option>
          <option value="published">Published</option>
          <option value="archived">Archived</option>
        </select>
      </div>

      <div class="md:col-span-2">
        <div id="add-stop-error" class="text-ember text-sm hidden p-2 border border-ember bg-surface-2 mb-3"></div>
        <div class="flex gap-3">
          <button type="submit" class="btn btn-sm">Save Stop</button>
          <button type="button" id="cancel-add-form" class="btn btn-sm btn-ghost">Cancel</button>
        </div>
      </div>
    </form>
  </div>

  {stops.length > 0 ? (
    <div class="card-flat" style="padding: 0; overflow: hidden;">
      <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
        <thead>
          <tr style="border-bottom: 1px solid var(--line);">
            <th class="label" style="padding: 10px 16px; text-align: left;">Title</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Type</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Status</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Date</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Actions</th>
          </tr>
        </thead>
        <tbody id="stops-tbody">
          {stops.map(stop => (
            <tr style="border-bottom: 1px solid var(--line-soft);" data-stop-row={stop.id}>
              <td style="padding: 10px 16px;">
                <div class="flex items-center gap-2">
                  {stop.is_current && <span class="pulse-dot" style="width: 8px; height: 8px;"></span>}
                  <span style="color: var(--paper);">{stop.title}</span>
                </div>
                {stop.place_name && <span class="coord block mt-0.5">{stop.place_name}</span>}
              </td>
              <td style="padding: 10px 12px; text-align: center;">
                <span class="text-xs text-muted">{stop.stop_type || '—'}</span>
              </td>
              <td style="padding: 10px 12px; text-align: center;">
                <span class={`badge text-[9px] ${stop.status === 'active' ? 'badge-active' : stop.status === 'published' ? 'badge-published' : 'badge-planned'}`}>
                  {stop.status}
                </span>
              </td>
              <td style="padding: 10px 12px; text-align: center; color: var(--muted);">
                {formatDate(stop.start_date)}
              </td>
              <td style="padding: 10px 12px; text-align: center;">
                <div class="flex gap-2 justify-center">
                  <a href={`/admin/stops/${trip.id}/${stop.id}`} class="btn btn-sm btn-ghost text-[10px]">Edit</a>
                  <button
                    type="button"
                    class="btn btn-sm js-delete-stop text-[10px]"
                    data-stop-id={stop.id}
                    data-stop-title={stop.title}
                    style="border-color: rgba(212,107,92,.45); color: var(--sunset);"
                  >
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="empty-state">
      <div class="icon">📍</div>
      <h3>No stops yet</h3>
      <p>Add the first stop for this trip.</p>
    </div>
  )}
</AdminLayout>

<script>
  // Toggle add form
  document.getElementById('show-add-form')?.addEventListener('click', () => {
    document.getElementById('add-stop-form-wrap')?.classList.remove('hidden');
    document.getElementById('show-add-form')?.classList.add('hidden');
  });
  document.getElementById('cancel-add-form')?.addEventListener('click', () => {
    document.getElementById('add-stop-form-wrap')?.classList.add('hidden');
    document.getElementById('show-add-form')?.classList.remove('hidden');
    (document.getElementById('add-stop-form') as HTMLFormElement)?.reset();
  });

  // Auto-slugify title
  document.querySelector<HTMLInputElement>('[name="title"]')?.addEventListener('input', (e) => {
    const slugInput = document.querySelector<HTMLInputElement>('[name="slug"]');
    if (!slugInput || slugInput.dataset.manual) return;
    const title = (e.target as HTMLInputElement).value;
    slugInput.value = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  });
  document.querySelector<HTMLInputElement>('[name="slug"]')?.addEventListener('input', (e) => {
    (e.target as HTMLInputElement).dataset.manual = '1';
  });

  // Add stop submit
  document.getElementById('add-stop-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const errorDiv = document.getElementById('add-stop-error');
    const data = Object.fromEntries(new FormData(form).entries());

    // Convert numeric strings
    if (data.latitude) data.latitude = parseFloat(data.latitude as string) as any;
    if (data.longitude) data.longitude = parseFloat(data.longitude as string) as any;
    if (!data.end_date) delete data.end_date;
    if (!data.place_name) delete data.place_name;

    errorDiv?.classList.add('hidden');

    try {
      const res = await fetch('/api/admin/stops', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.detail || `HTTP ${res.status}`);
      }
      location.reload();
    } catch (err) {
      if (errorDiv) {
        errorDiv.textContent = err instanceof Error ? err.message : String(err);
        errorDiv.classList.remove('hidden');
      }
    }
  });

  // Delete stop
  document.querySelectorAll('button.js-delete-stop').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const stopId = target.dataset.stopId;
      const title = target.dataset.stopTitle || 'this stop';
      if (!stopId || !confirm(`Delete "${title}"? This cannot be undone.`)) return;

      target.disabled = true;
      try {
        const res = await fetch(`/api/admin/stops/${stopId}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        document.querySelector(`[data-stop-row="${stopId}"]`)?.remove();
      } catch (err) {
        target.disabled = false;
        alert(`Could not delete stop: ${err instanceof Error ? err.message : String(err)}`);
      }
    });
  });
</script>
