---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

const { trip_id } = Astro.params;
const cookie = Astro.request.headers.get('cookie');

let trip = null;
let stops = [];
let plannedStops = [];

try {
  const [tripsRes, stopsRes, plannedRes] = await Promise.all([
    fetch(apiUrl('/api/admin/trips'), { headers: cookie ? { cookie } : {} }),
    fetch(apiUrl('/api/admin/stops'), { headers: cookie ? { cookie } : {} }),
    fetch(apiUrl(`/api/admin/imports/planned-stops/${trip_id}`), { headers: cookie ? { cookie } : {} }),
  ]);

  if (tripsRes.status === 401 || tripsRes.status === 403) return Astro.redirect('/auth/login');

  if (tripsRes.ok) {
    const all = await tripsRes.json();
    trip = all.find(t => t.id === trip_id);
  }
  if (stopsRes.ok) {
    const all = await stopsRes.json();
    stops = all.filter(s => s.trip_id === trip_id);
  }
  if (plannedRes.ok) {
    plannedStops = await plannedRes.json();
  }
} catch (e) {
  console.error(e);
}

if (!trip) return Astro.redirect('/admin/stops');

function formatDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const tripIsPrivate = trip.visibility === 'private';
---

<AdminLayout title={`Stops — ${trip.title}`}>
  <div class="mb-8 flex flex-col sm:flex-row gap-4 sm:justify-between sm:items-start">
    <div>
      <a href="/admin/stops" class="text-xs font-mono uppercase tracking-widest text-dim hover:text-ember mb-3 inline-block">← All Trips</a>
      <div class="label mb-1">Stops</div>
      <h1 class="display text-3xl">{trip.title}</h1>
    </div>
    <div class="flex flex-wrap gap-2">
      <button type="button" id="show-bulk-controls" class="btn btn-sm btn-ghost">Select Stops</button>
      <button type="button" id="show-add-form" class="btn btn-sm">+ Add Stop</button>
    </div>
  </div>

  {/* Add stop form (hidden by default) */}
  <div id="add-stop-form-wrap" class="hidden card-flat mb-8">
    <h2 class="text-lg font-semibold mb-4">New Stop</h2>
    <form id="add-stop-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <input type="hidden" name="trip_id" value={trip.id} />

      <div class="flex flex-col gap-1 md:col-span-2">
        <label class="text-xs font-bold">Title *</label>
        <input type="text" name="title" required maxlength="200"
          class="bg-surface-2 border border-line p-2 text-sm focus:border-ember" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Slug *</label>
        <input type="text" name="slug" required
          class="bg-surface-2 border border-line p-2 text-sm" placeholder="auto-filled from title" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Place Name</label>
        <input type="text" name="place_name"
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Latitude *</label>
        <input type="number" name="latitude" step="any" required min="-90" max="90"
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Longitude *</label>
        <input type="number" name="longitude" step="any" required min="-180" max="180"
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Start Date *</label>
        <input type="datetime-local" name="start_date" required
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">End Date</label>
        <input type="datetime-local" name="end_date"
          class="bg-surface-2 border border-line p-2 text-sm" />
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Type</label>
        <select name="stop_type" class="bg-surface-2 border border-line p-2 text-sm">
          <option value="campground">Campground</option>
          <option value="boondocking">Boondocking</option>
          <option value="overnight">Overnight</option>
          <option value="attraction">Attraction</option>
          <option value="restaurant">Restaurant</option>
          <option value="service">Service</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Status</label>
        <select name="status" class="bg-surface-2 border border-line p-2 text-sm">
          <option value="draft" selected>Draft</option>
          <option value="published">Published</option>
          <option value="unpublished">Unpublished</option>
          <option value="archived">Archived</option>
        </select>
        <span class="text-xs text-dim">Only published stops appear outside admin pages. Visibility applies after publishing.</span>
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-bold">Visibility</label>
        <select name="visibility" class="bg-surface-2 border border-line p-2 text-sm" disabled={tripIsPrivate}>
          <option value="public" selected={!tripIsPrivate}>Public</option>
          <option value="private" selected={tripIsPrivate}>Private</option>
        </select>
        {tripIsPrivate && <input type="hidden" name="visibility" value="private" />}
        <span class="text-xs text-dim">
          Private trips can only have private stops. Public trips can still hide individual stops.
        </span>
      </div>

      <div class="md:col-span-2">
        <div id="add-stop-error" class="text-ember text-sm hidden p-2 border border-ember bg-surface-2 mb-3"></div>
        <div class="flex gap-3">
          <button type="submit" class="btn btn-sm">Save Stop</button>
          <button type="button" id="cancel-add-form" class="btn btn-sm btn-ghost">Cancel</button>
        </div>
      </div>
    </form>
  </div>

  {stops.length > 0 ? (
    <div>
      <div id="bulk-controls" class="hidden card-flat mb-4">
        <div class="flex flex-col lg:flex-row gap-3 lg:items-end lg:justify-between">
          <div>
            <div class="label mb-1">Bulk edit</div>
            <p class="text-xs text-muted">
              <span id="bulk-selected-count">0</span> selected. Change status, type, or delete selected stops.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-2">
            <label class="flex flex-col gap-1">
              <span class="label">Status</span>
              <select id="bulk-status" class="bg-surface-2 border border-line p-2 text-sm min-w-36">
                <option value="">No change</option>
                <option value="draft">Draft</option>
                <option value="published">Published</option>
                <option value="unpublished">Unpublished</option>
                <option value="archived">Archived</option>
              </select>
            </label>
            <label class="flex flex-col gap-1">
              <span class="label">Type</span>
              <select id="bulk-type" class="bg-surface-2 border border-line p-2 text-sm min-w-36">
                <option value="">No change</option>
                <option value="campground">Campground</option>
                <option value="boondocking">Boondocking</option>
                <option value="overnight">Overnight</option>
                <option value="attraction">Attraction</option>
                <option value="restaurant">Restaurant</option>
                <option value="service">Service</option>
                <option value="other">Other</option>
              </select>
            </label>
            <label class="flex flex-col gap-1">
              <span class="label">Visibility</span>
              <select id="bulk-visibility" class="bg-surface-2 border border-line p-2 text-sm min-w-36" disabled={tripIsPrivate}>
                <option value="">No change</option>
                <option value="public">Public</option>
                <option value="private">Private</option>
              </select>
            </label>
            <div class="flex items-end gap-2">
              <button type="button" id="bulk-apply" class="btn btn-sm">Apply</button>
              <button
                type="button"
                id="bulk-delete"
                class="btn btn-sm"
                style="border-color: rgba(212,107,92,.45); color: var(--sunset);"
              >
                Delete
              </button>
              <button type="button" id="bulk-cancel" class="btn btn-sm btn-ghost">Cancel</button>
            </div>
          </div>
        </div>
        <div id="bulk-error" class="hidden text-ember text-sm mt-3"></div>
      </div>

      <div class="card-flat overflow-x-auto" style="padding: 0;">
      <table style="width: 100%; min-width: 760px; border-collapse: collapse; font-size: 13px;">
        <thead>
          <tr style="border-bottom: 1px solid var(--line);">
            <th class="label js-bulk-cell hidden" style="padding: 10px 12px; text-align: center; width: 44px;">
              <input type="checkbox" id="bulk-select-all" aria-label="Select all stops" />
            </th>
            <th class="label" style="padding: 10px 16px; text-align: left;">Title</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Type</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Visibility</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Status</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Date</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Actions</th>
          </tr>
        </thead>
        <tbody id="stops-tbody">
          {stops.map(stop => (
            <tr style="border-bottom: 1px solid var(--line-soft);" data-stop-row={stop.id}>
              <td class="js-bulk-cell hidden" style="padding: 10px 12px; text-align: center;">
                <input
                  type="checkbox"
                  class="js-stop-select"
                  value={stop.id}
                  aria-label={`Select ${stop.title}`}
                />
              </td>
              <td style="padding: 10px 16px;">
                <div class="flex items-center gap-2">
                  {stop.is_current && <span class="pulse-dot" style="width: 8px; height: 8px;"></span>}
                  <span style="color: var(--paper);">{stop.title}</span>
                </div>
                {stop.place_name && <span class="coord block mt-0.5">{stop.place_name}</span>}
              </td>
              <td style="padding: 10px 12px; text-align: center;">
                <span class="text-xs text-muted">{stop.stop_type || '—'}</span>
              </td>
              <td style="padding: 10px 12px; text-align: center;">
                <span class={`badge text-[9px] ${stop.visibility === 'public' ? 'badge-public' : 'badge-draft'}`}>
                  {stop.visibility}
                </span>
              </td>
              <td style="padding: 10px 12px; text-align: center;">
                <span class={`badge text-[9px] ${stop.status === 'draft' ? 'badge-draft' : stop.status === 'published' ? 'badge-published' : stop.status === 'unpublished' ? 'badge-unpublished' : stop.status === 'archived' ? 'badge-private' : 'badge-planned'}`}>
                  {stop.status}
                </span>
              </td>
              <td style="padding: 10px 12px; text-align: center; color: var(--muted);">
                {formatDate(stop.start_date)}
              </td>
              <td style="padding: 10px 12px; text-align: center;">
                <div class="flex gap-2 justify-center">
                  <a href={`/admin/stops/${trip.id}/${stop.id}`} class="btn btn-sm btn-ghost text-[10px]">Edit</a>
                  <button
                    type="button"
                    class="btn btn-sm js-delete-stop text-[10px]"
                    data-stop-id={stop.id}
                    data-stop-title={stop.title}
                    style="border-color: rgba(212,107,92,.45); color: var(--sunset);"
                  >
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      </div>
    </div>
  ) : plannedStops.length > 0 ? (
    <div class="card-flat overflow-x-auto" style="padding: 0;">
      <div class="p-4 bg-surface-1" style="border-bottom: 1px solid var(--line);">
        <div class="label">Imported itinerary</div>
        <p class="text-xs text-muted mt-1">
          Legacy import rows: {plannedStops.length} stop{plannedStops.length === 1 ? '' : 's'} imported before Excel imports created normal stops.
        </p>
      </div>
      <table style="width: 100%; min-width: 720px; border-collapse: collapse; font-size: 13px;">
        <thead>
          <tr style="border-bottom: 1px solid var(--line);">
            <th class="label" style="padding: 10px 16px; text-align: left;">Name</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Arrival</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Departure</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">Nights</th>
            <th class="label" style="padding: 10px 12px; text-align: center;">State</th>
          </tr>
        </thead>
        <tbody>
          {plannedStops.map(stop => (
            <tr style="border-bottom: 1px solid var(--line-soft);">
              <td style="padding: 10px 16px;">
                <div style="color: var(--paper); font-weight: 600;">{stop.name}</div>
                {stop.address && <span class="coord block mt-0.5">{stop.address}</span>}
              </td>
              <td style="padding: 10px 12px; text-align: center; color: var(--muted);">
                {formatDate(stop.arrival_date)}
              </td>
              <td style="padding: 10px 12px; text-align: center; color: var(--muted);">
                {formatDate(stop.departure_date)}
              </td>
              <td style="padding: 10px 12px; text-align: center; color: var(--muted);">
                {stop.nights ?? '—'}
              </td>
              <td style="padding: 10px 12px; text-align: center;">
                <span class="badge badge-planned text-[9px]">{stop.import_state}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="empty-state">
      <div class="icon">📍</div>
      <h3>No stops yet</h3>
      <p>Add the first stop for this trip.</p>
    </div>
  )}
</AdminLayout>

<script>
  // Toggle add form
  document.getElementById('show-add-form')?.addEventListener('click', () => {
    document.getElementById('add-stop-form-wrap')?.classList.remove('hidden');
    document.getElementById('show-add-form')?.classList.add('hidden');
  });
  document.getElementById('cancel-add-form')?.addEventListener('click', () => {
    document.getElementById('add-stop-form-wrap')?.classList.add('hidden');
    document.getElementById('show-add-form')?.classList.remove('hidden');
    (document.getElementById('add-stop-form') as HTMLFormElement)?.reset();
  });

  // Auto-slugify title
  document.querySelector<HTMLInputElement>('[name="title"]')?.addEventListener('input', (e) => {
    const slugInput = document.querySelector<HTMLInputElement>('[name="slug"]');
    if (!slugInput || slugInput.dataset.manual) return;
    const title = (e.target as HTMLInputElement).value;
    slugInput.value = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  });
  document.querySelector<HTMLInputElement>('[name="slug"]')?.addEventListener('input', (e) => {
    (e.target as HTMLInputElement).dataset.manual = '1';
  });

  // Add stop submit
  document.getElementById('add-stop-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const errorDiv = document.getElementById('add-stop-error');
    const data = Object.fromEntries(new FormData(form).entries());

    // Convert numeric strings
    if (data.latitude) data.latitude = parseFloat(data.latitude as string) as any;
    if (data.longitude) data.longitude = parseFloat(data.longitude as string) as any;
    if (!data.end_date) delete data.end_date;
    if (!data.place_name) delete data.place_name;

    errorDiv?.classList.add('hidden');

    try {
      const res = await fetch('/api/admin/stops', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.detail || `HTTP ${res.status}`);
      }
      location.reload();
    } catch (err) {
      if (errorDiv) {
        errorDiv.textContent = err instanceof Error ? err.message : String(err);
        errorDiv.classList.remove('hidden');
      }
    }
  });

  // Delete stop
  document.querySelectorAll('button.js-delete-stop').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const stopId = target.dataset.stopId;
      const title = target.dataset.stopTitle || 'this stop';
      if (!stopId || !confirm(`Delete "${title}"? This cannot be undone.`)) return;

      target.disabled = true;
      try {
        const res = await fetch(`/api/admin/stops/${stopId}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        document.querySelector(`[data-stop-row="${stopId}"]`)?.remove();
      } catch (err) {
        target.disabled = false;
        alert(`Could not delete stop: ${err instanceof Error ? err.message : String(err)}`);
      }
    });
  });

  const bulkControls = document.getElementById('bulk-controls');
  const bulkCells = Array.from(document.querySelectorAll<HTMLElement>('.js-bulk-cell'));
  const bulkShowButton = document.getElementById('show-bulk-controls');
  const bulkCancelButton = document.getElementById('bulk-cancel');
  const bulkApplyButton = document.getElementById('bulk-apply') as HTMLButtonElement | null;
  const bulkDeleteButton = document.getElementById('bulk-delete') as HTMLButtonElement | null;
  const bulkSelectAll = document.getElementById('bulk-select-all') as HTMLInputElement | null;
  const bulkStatus = document.getElementById('bulk-status') as HTMLSelectElement | null;
  const bulkType = document.getElementById('bulk-type') as HTMLSelectElement | null;
  const bulkVisibility = document.getElementById('bulk-visibility') as HTMLSelectElement | null;
  const bulkCount = document.getElementById('bulk-selected-count');
  const bulkError = document.getElementById('bulk-error');

  function selectedStopIds() {
    return Array.from(document.querySelectorAll<HTMLInputElement>('.js-stop-select:checked'))
      .map(input => input.value);
  }

  function setBulkError(message: string | null) {
    if (!bulkError) return;
    if (message) {
      bulkError.textContent = message;
      bulkError.classList.remove('hidden');
    } else {
      bulkError.textContent = '';
      bulkError.classList.add('hidden');
    }
  }

  function updateBulkCount() {
    const selected = selectedStopIds();
    if (bulkCount) bulkCount.textContent = String(selected.length);
    if (bulkSelectAll) {
      const total = document.querySelectorAll<HTMLInputElement>('.js-stop-select').length;
      bulkSelectAll.checked = total > 0 && selected.length === total;
      bulkSelectAll.indeterminate = selected.length > 0 && selected.length < total;
    }
  }

  function setBulkMode(enabled: boolean) {
    bulkControls?.classList.toggle('hidden', !enabled);
    bulkCells.forEach(cell => cell.classList.toggle('hidden', !enabled));
    bulkShowButton?.classList.toggle('hidden', enabled);
    if (!enabled) {
      document.querySelectorAll<HTMLInputElement>('.js-stop-select').forEach(input => {
        input.checked = false;
      });
      if (bulkSelectAll) {
        bulkSelectAll.checked = false;
        bulkSelectAll.indeterminate = false;
      }
      if (bulkStatus) bulkStatus.value = '';
      if (bulkType) bulkType.value = '';
      if (bulkVisibility) bulkVisibility.value = '';
      setBulkError(null);
      updateBulkCount();
    }
  }

  async function runBulkAction(payload: Record<string, unknown>) {
    const stopIds = selectedStopIds();
    if (stopIds.length === 0) {
      setBulkError('Select at least one stop.');
      return false;
    }

    setBulkError(null);
    if (bulkApplyButton) bulkApplyButton.disabled = true;
    if (bulkDeleteButton) bulkDeleteButton.disabled = true;

    try {
      const res = await fetch('/api/admin/stops/bulk', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ stop_ids: stopIds, ...payload }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.detail || `HTTP ${res.status}`);
      }
      return true;
    } catch (err) {
      setBulkError(err instanceof Error ? err.message : String(err));
      return false;
    } finally {
      if (bulkApplyButton) bulkApplyButton.disabled = false;
      if (bulkDeleteButton) bulkDeleteButton.disabled = false;
    }
  }

  bulkShowButton?.addEventListener('click', () => setBulkMode(true));
  bulkCancelButton?.addEventListener('click', () => setBulkMode(false));

  bulkSelectAll?.addEventListener('change', () => {
    document.querySelectorAll<HTMLInputElement>('.js-stop-select').forEach(input => {
      input.checked = Boolean(bulkSelectAll.checked);
    });
    updateBulkCount();
  });

  document.querySelectorAll<HTMLInputElement>('.js-stop-select').forEach(input => {
    input.addEventListener('change', updateBulkCount);
  });

  bulkApplyButton?.addEventListener('click', async () => {
    const payload: Record<string, unknown> = {};
    if (bulkStatus?.value) payload.status = bulkStatus.value;
    if (bulkType?.value) payload.stop_type = bulkType.value;
    if (bulkVisibility?.value) payload.visibility = bulkVisibility.value;
    if (!payload.status && !payload.stop_type && !payload.visibility) {
      setBulkError('Choose a status, type, or visibility to update.');
      return;
    }
    if (await runBulkAction(payload)) location.reload();
  });

  bulkDeleteButton?.addEventListener('click', async () => {
    const stopIds = selectedStopIds();
    if (stopIds.length === 0) {
      setBulkError('Select at least one stop.');
      return;
    }
    if (!confirm(`Delete ${stopIds.length} selected stop${stopIds.length === 1 ? '' : 's'}? This cannot be undone.`)) return;
    if (await runBulkAction({ delete: true })) {
      stopIds.forEach(id => document.querySelector(`[data-stop-row="${id}"]`)?.remove());
      setBulkMode(false);
    }
  });
</script>
