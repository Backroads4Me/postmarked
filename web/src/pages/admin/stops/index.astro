---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

let trips = [];
const cookie = Astro.request.headers.get('cookie');

try {
  const res = await fetch(apiUrl('/api/admin/trips'), {
    headers: cookie ? { cookie } : {}
  });
  if (res.status === 401 || res.status === 403) return Astro.redirect('/auth/login');
  if (res.ok) trips = await res.json();
} catch (e) {
  console.error(e);
}

function statusBadge(status) {
  return status === 'draft'
    ? 'badge-draft'
    : status === 'active'
      ? 'badge-active'
      : status === 'published'
        ? 'badge-published'
        : 'badge-planned';
}
---

<AdminLayout title="Stops">
  <div class="mb-8">
    <div class="label mb-2">Manage</div>
    <h1 class="display text-3xl">Stops</h1>
    <p class="text-muted text-sm mt-2">Select a trip to view and manage its stops.</p>
  </div>

  {trips.length > 0 ? (
    <div class="bg-surface-2 border border-line rounded divide-y divide-line">
      {trips.map(trip => (
        <a
          href={`/admin/stops/${trip.id}`}
          class="p-4 flex items-center justify-between hover:bg-surface-1 transition-colors group"
        >
          <div>
            <div class="flex items-center gap-2">
              <span class="font-medium" style="color: var(--paper);">{trip.title}</span>
              <span class={`badge text-[9px] ${statusBadge(trip.status)}`}>
                {trip.status}
              </span>
            </div>
            <div class="text-xs text-dim font-mono mt-0.5">{trip.slug}</div>
          </div>
          <span class="text-dim text-sm group-hover:text-ember transition-colors">Manage stops →</span>
        </a>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <div class="icon">📍</div>
      <h3>No trips yet</h3>
      <p>Create a trip first, then add stops to it.</p>
      <a href="/admin/trips/new" class="btn btn-sm mt-4">New Trip</a>
    </div>
  )}
</AdminLayout>
