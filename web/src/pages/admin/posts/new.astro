---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import QuickPostIsland from '../../../components/admin/QuickPostIsland.jsx';
---

<AdminLayout title="New Post">
  <div class="mb-6">
    <div class="label mb-2">Compose</div>
    <h1 class="display text-3xl">New Quick Post</h1>
    <p class="text-muted text-sm mt-2">
      Share a short update, optionally with photos or video. Defaults to the current stop.
    </p>
  </div>

  <QuickPostIsland client:load />
</AdminLayout>
