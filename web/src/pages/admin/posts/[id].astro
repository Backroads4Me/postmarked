---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

const { id } = Astro.params;
const cookie = Astro.request.headers.get('cookie');

let post = null;
let stops = [];
let pois = [];
try {
  const [postsRes, stopsRes] = await Promise.all([
    fetch(apiUrl('/api/admin/posts'), { headers: cookie ? { cookie } : {} }),
    fetch(apiUrl('/api/admin/stops'), { headers: cookie ? { cookie } : {} }),
  ]);
  if (postsRes.status === 401 || postsRes.status === 403) return Astro.redirect('/auth/login');
  if (postsRes.ok) {
    const all = await postsRes.json();
    post = all.find(p => p.id === id);
  }
  if (stopsRes.ok) stops = await stopsRes.json();
} catch (e) {}

if (!post) return Astro.redirect('/admin/posts');

stops.sort((a, b) => new Date(b.start_date) - new Date(a.start_date));

const isActivity = post.post_type === 'activity';

// Load POIs for the current stop if this is an activity post
if (isActivity && post.stop_id) {
  try {
    const poisRes = await fetch(apiUrl(`/api/admin/stops/${post.stop_id}/pois`), { headers: cookie ? { cookie } : {} });
    if (poisRes.ok) pois = await poisRes.json();
  } catch (e) {}
}

// Format datetime for datetime-local input (strips timezone, yields local-ish value)
function toDatetimeLocal(iso) {
  if (!iso) return '';
  return new Date(iso).toISOString().slice(0, 16);
}
---

<AdminLayout title={`Edit: ${post.title}`}>
  <div class="max-w-2xl">
    <div class="mb-8">
      <a href="/admin/posts" class="text-xs font-mono uppercase tracking-widest text-dim hover:text-ember mb-4 inline-block">← Back</a>
      <div class="flex items-center gap-3">
        <h1 class="display text-3xl">Edit Post</h1>
        <span class="badge" style={isActivity ? 'background: var(--ember-glow); color: var(--ember);' : ''}>
          {post.post_type}
        </span>
      </div>
    </div>

    <form id="post-edit-form" class="flex flex-col gap-6" data-post-type={post.post_type}>
      <input type="hidden" name="id" value={post.id} />
      <input type="hidden" name="post_type" value={post.post_type} />

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold" for="title">Title</label>
        <input id="title" type="text" name="title" value={post.title} required maxlength="200"
          class="bg-surface-2 border border-line p-3 focus:border-ember" />
      </div>

      {isActivity && (
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="summary">Summary</label>
          <input id="summary" type="text" name="summary" value={post.summary ?? ''} maxlength="500"
            placeholder="Short card text for the activity"
            class="bg-surface-2 border border-line p-3 focus:border-ember" />
        </div>
      )}

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold" for="body">Body (markdown)</label>
        <textarea id="body" name="body" rows="8"
          class="bg-surface-2 border border-line p-3 font-sans focus:border-ember">{post.body ?? ''}</textarea>
      </div>

      {isActivity && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold" for="activity_type">Activity Type</label>
            <select id="activity_type" name="activity_type" class="bg-surface-2 border border-line p-3">
              {['hiking','museum','restaurant','attraction','service','scenic_drive','shopping','family','other'].map(t => (
                <option value={t} selected={post.activity_type === t} style="text-transform: capitalize;">
                  {t.replace(/_/g, ' ')}
                </option>
              ))}
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold" for="activity_started_at">
              When <span class="text-ember">*</span>
            </label>
            <input id="activity_started_at" type="datetime-local" name="activity_started_at"
              value={toDatetimeLocal(post.activity_started_at)}
              class="bg-surface-2 border border-line p-3 focus:border-ember" />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold" for="activity_ended_at">Ended At (optional)</label>
            <input id="activity_ended_at" type="datetime-local" name="activity_ended_at"
              value={toDatetimeLocal(post.activity_ended_at)}
              class="bg-surface-2 border border-line p-3 focus:border-ember" />
          </div>
        </div>
      )}

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="stop_id">Stop</label>
          <select id="stop_id" name="stop_id" class="bg-surface-2 border border-line p-3">
            <option value="">No stop</option>
            {stops.map(s => (
              <option value={s.id} selected={s.id === post.stop_id}>{s.title}</option>
            ))}
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="status">Status</label>
          <select id="status" name="status" class="bg-surface-2 border border-line p-3">
            {['draft','published','unpublished','archived'].map(status => (
              <option value={status} selected={post.status === status}>{status}</option>
            ))}
          </select>
          <span class="text-xs text-dim">Only published posts appear outside admin pages.</span>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="visibility">Visibility</label>
          <select id="visibility" name="visibility" class="bg-surface-2 border border-line p-3">
            <option value="private" selected={post.visibility === 'private'}>Private — logged-in users</option>
            <option value="public" selected={post.visibility === 'public'}>Public — anyone</option>
          </select>
          <span class="text-xs text-dim">Visibility applies after the post is published.</span>
        </div>
      </div>

      {isActivity && (
        <div class="flex flex-col gap-2" id="poi-row">
          <label class="text-sm font-bold" for="poi_id">Place (optional)</label>
          <select id="poi_id" name="poi_id" class="bg-surface-2 border border-line p-3">
            <option value="">No place linked</option>
            {pois.map(p => (
              <option value={p.id} selected={p.id === post.poi_id}>
                {p.label} ({p.poi_type})
              </option>
            ))}
          </select>
          <p class="text-xs text-dim" id="poi-hint">
            {pois.length === 0 ? 'No POIs for this stop. Add them in the Stops admin.' : ''}
          </p>
        </div>
      )}

      <div id="form-error" class="text-ember text-sm hidden p-3 border border-ember bg-surface-2"></div>
      <div id="form-success" class="text-green-500 text-sm hidden p-3 border border-green-500 bg-surface-2">Saved!</div>

      <div class="flex flex-wrap gap-3 items-center mt-2">
        <button type="submit" class="btn">Save</button>
        <button type="button" id="delete-btn" class="btn btn-sm"
          style="border-color: rgba(212,107,92,.55); color: var(--sunset);">
          Delete
        </button>
      </div>
    </form>
  </div>

  <script define:vars={{ isActivity, initialStopId: post.stop_id ?? '' }}>
    const form = document.getElementById('post-edit-form');
    const errorDiv = document.getElementById('form-error');
    const successDiv = document.getElementById('form-success');
    const stopSelect = document.getElementById('stop_id');

    // Reload POIs when stop changes (activity posts only)
    if (isActivity && stopSelect) {
      stopSelect.addEventListener('change', async () => {
        const stopId = stopSelect.value;
        const poiSelect = document.getElementById('poi_id');
        const hint = document.getElementById('poi-hint');
        if (!poiSelect) return;

	        if (!stopId) {
	          resetPoiOptions(poiSelect, []);
	          if (hint) hint.textContent = '';
	          return;
	        }

        try {
	          const res = await fetch(`/api/admin/stops/${stopId}/pois`, { credentials: 'include' });
	          const pois = res.ok ? await res.json() : [];
	          resetPoiOptions(poiSelect, pois);
	          if (hint) hint.textContent = pois.length === 0 ? 'No POIs for this stop. Add them in the Stops admin.' : '';
	        } catch {
	          if (hint) hint.textContent = 'Failed to load POIs';
        }
	      });
	    }

	    function resetPoiOptions(select, pois) {
	      select.replaceChildren();

	      const empty = document.createElement('option');
	      empty.value = '';
	      empty.textContent = 'No place linked';
	      select.appendChild(empty);

	      for (const poi of pois) {
	        const option = document.createElement('option');
	        option.value = poi.id;
	        option.textContent = `${poi.label} (${poi.poi_type})`;
	        select.appendChild(option);
	      }
	    }
	
	    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const id = formData.get('id');
      const postType = formData.get('post_type');

      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      const body = {
        title: formData.get('title'),
        body: formData.get('body') || null,
        stop_id: formData.get('stop_id') || null,
        status: formData.get('status'),
        visibility: formData.get('visibility'),
      };

      if (postType === 'activity') {
        body.activity_type = formData.get('activity_type') || null;
        body.summary = formData.get('summary') || null;
        body.activity_started_at = formData.get('activity_started_at') || null;
        body.activity_ended_at = formData.get('activity_ended_at') || null;
        body.poi_id = formData.get('poi_id') || null;
      }

      try {
        const res = await fetch(`/api/admin/posts/${id}`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          successDiv.classList.remove('hidden');
          setTimeout(() => successDiv.classList.add('hidden'), 3000);
        } else {
          const err = await res.json().catch(() => ({}));
          errorDiv.textContent = err.detail || `Error ${res.status}`;
          errorDiv.classList.remove('hidden');
        }
      } catch {
        errorDiv.textContent = 'Network error';
        errorDiv.classList.remove('hidden');
      }
    });

    document.getElementById('delete-btn').addEventListener('click', async () => {
      const id = form.querySelector('[name="id"]').value;
      const title = form.querySelector('[name="title"]').value;
      if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;

      try {
        const res = await fetch(`/api/admin/posts/${id}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (res.ok) {
          window.location.href = '/admin/posts';
        } else {
          errorDiv.textContent = `Delete failed: HTTP ${res.status}`;
          errorDiv.classList.remove('hidden');
        }
      } catch {
        errorDiv.textContent = 'Network error';
        errorDiv.classList.remove('hidden');
      }
    });
  </script>
</AdminLayout>
