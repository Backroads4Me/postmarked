---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';
import { cityStateFromAddress } from '../../../lib/location.js';
import { renderMarkdown } from '../../../lib/markdown.js';
import MediaGallery from '../../../components/ui/MediaGallery.astro';

const { id } = Astro.params;
const cookie = Astro.request.headers.get('cookie');

let post = null;
let stops = [];
try {
  const [postsRes, stopsRes] = await Promise.all([
    fetch(apiUrl('/api/admin/posts'), { headers: cookie ? { cookie } : {} }),
    fetch(apiUrl('/api/admin/stops'), { headers: cookie ? { cookie } : {} }),
  ]);
  if (postsRes.status === 401 || postsRes.status === 403) return Astro.redirect('/auth/login');
  if (postsRes.ok) {
    const all = await postsRes.json();
    post = all.find(p => p.id === id);
  }
  if (stopsRes.ok) stops = await stopsRes.json();
} catch (e) {}

if (!post) return Astro.redirect('/admin/posts');

stops.sort((a, b) => new Date(b.start_date) - new Date(a.start_date));

const attachedMedia = post.media || [];
const renderedPreviewBody = renderMarkdown(post.body || '');

function toDateInput(iso) {
  if (!iso) return '';
  return new Date(iso).toISOString().slice(0, 10);
}

function stopOptionLabel(stop) {
  const cityState = cityStateFromAddress(stop.address_label || stop.summary) || stop.title;
  const monthYear = stop.start_date
    ? new Date(stop.start_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
    : '';
  return monthYear ? `${cityState} - ${monthYear}` : cityState;
}
---

<AdminLayout title={`Edit: ${post.title}`}>
  <div class="w-full">
    <div class="mb-8">
      <a href="/admin/posts" class="text-xs font-mono uppercase tracking-widest text-dim hover:text-ember inline-block">← Back</a>
    </div>

    <form id="post-edit-form" class="flex flex-col gap-6">
      <input type="hidden" name="id" value={post.id} />

      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_18rem] gap-4">
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="title">Title</label>
          <input id="title" type="text" name="title" value={post.title} required maxlength="200"
            class="bg-surface-2 border border-line p-3 focus:border-ember" />
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="posted_at">Post date</label>
          <input id="posted_at" type="date" name="posted_at" value={toDateInput(post.posted_at)}
            class="bg-surface-2 border border-line p-3 focus:border-ember" />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold" for="summary">Summary</label>
        <textarea id="summary" name="summary" rows="2" maxlength="500"
          placeholder="A sentence or two that appears before the photos."
          class="bg-surface-2 border border-line p-3 font-sans focus:border-ember">{post.summary ?? ''}</textarea>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold" for="body">Body (markdown)</label>
        <textarea id="body" name="body" rows="8"
          placeholder="The full post text — appears after the photos."
          class="bg-surface-2 border border-line p-3 font-sans focus:border-ember">{post.body ?? ''}</textarea>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_14rem_18rem] gap-4">
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="stop_id">Stop</label>
          <select id="stop_id" name="stop_id" class="bg-surface-2 border border-line p-3">
            <option value="">No stop</option>
            {stops.map(s => (
              <option value={s.id} selected={s.id === post.stop_id}>{stopOptionLabel(s)}</option>
            ))}
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="status">Status</label>
          <select id="status" name="status" class="bg-surface-2 border border-line p-3">
            {['draft','published','unpublished','archived'].map(status => (
              <option value={status} selected={post.status === status}>{status.charAt(0).toUpperCase() + status.slice(1)}</option>
            ))}
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="visibility">Visibility</label>
          <select id="visibility" name="visibility" class="bg-surface-2 border border-line p-3">
            <option value="private" selected={post.visibility === 'private'}>Private — logged-in users</option>
            <option value="public" selected={post.visibility === 'public'}>Public — anyone</option>
          </select>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="flex items-baseline gap-3">
            <label class="text-sm font-bold">Attached media</label>
            <span class="text-xs text-dim">{attachedMedia.length} item{attachedMedia.length === 1 ? '' : 's'}</span>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <input id="media-upload-input" type="file" accept="image/*,video/*" multiple class="hidden" />
            <button type="button" id="upload-media-btn" class="btn btn-sm">Upload photos</button>
            <button type="button" id="open-media-picker-btn" class="btn btn-sm btn-ghost-ember">Attach existing</button>
          </div>
        </div>
        <div id="media-attach-status" class="text-xs text-dim min-h-[1rem]"></div>
        <div id="media-picker-panel" class="hidden bg-surface-2 border border-line-soft rounded p-3">
          <div class="flex items-center justify-between gap-3 mb-3">
            <div class="label">Media library</div>
            <button type="button" id="close-media-picker-btn" class="btn btn-sm btn-ghost">Close</button>
          </div>
          <div id="media-picker-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2 max-h-80 overflow-auto"></div>
          <div class="flex items-center gap-2 mt-3">
            <button type="button" id="attach-selected-media-btn" class="btn btn-sm">Attach selected</button>
            <span id="media-picker-status" class="text-xs text-dim"></span>
          </div>
        </div>
        {attachedMedia.length > 0 ? (
          <div id="media-list" class="bg-surface-2 border border-line-soft rounded divide-y divide-line-soft">
            {attachedMedia.map((m) => (
              <div
                class="flex items-center gap-3 p-2 media-card"
                draggable="true"
                data-media-card
                data-media-id={m.id}
              >
                <span
                  class="media-drag-handle shrink-0 cursor-grab text-dim select-none px-1"
                  aria-hidden="true"
                  title="Drag to reorder"
                >⠿</span>
                <a
                  href={m.kind === 'video' ? `/media-player/${m.id}` : `/media/${m.id}/webp`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block w-16 h-16 shrink-0 overflow-hidden rounded bg-line-soft border border-line hover:opacity-90 transition-opacity"
                  style="text-decoration: none;"
                >
                  {m.kind === 'video' ? (
                    <img
                      src={`/media/${m.id}/poster`}
                      alt={m.alt_text || m.caption || ''}
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <img
                      src={`/media/${m.id}/webp`}
                      alt={m.alt_text || m.caption || ''}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover"
                    />
                  )}
                </a>
                <div class="min-w-0 flex-1 self-center">
                  <textarea
                    id={`media-caption-${m.id}`}
                    rows="2"
                    aria-label="Photo description"
                    class="media-caption-input block w-full h-12 bg-bg border border-line-soft rounded p-2 text-xs text-paper focus:border-ember resize-none"
                    data-media-caption-input
                    data-media-id={m.id}
                    placeholder="Add a description"
                  >{m.caption || ''}</textarea>
                  <div class="text-xs text-dim h-0 overflow-hidden" data-media-caption-status={m.id}></div>
                </div>
                <button
                  type="button"
                  class="btn btn-sm shrink-0"
                  style="border-color: rgba(212,107,92,.45); color: var(--sunset);"
                  data-delete-media-id={m.id}
                  data-delete-media-kind={m.kind}
                  aria-label={`Delete ${m.kind}`}
                >
                  Delete
                </button>
              </div>
            ))}
          </div>
        ) : (
          <div class="bg-surface-2 border border-line-soft rounded p-3 text-sm text-muted">
            No media is attached to this post.
          </div>
        )}
      </div>

      <section class="flex flex-col gap-2">
        <div class="flex items-baseline justify-between gap-3">
          <h2 class="display text-xl m-0">Timeline preview</h2>
          <span id="preview-meta" class="label">{post.status} · {post.visibility}</span>
        </div>
        <article class="card-flat">
          <div class="flex items-start justify-between gap-3 mb-1">
            <h3 id="preview-title" class="text-lg font-medium text-paper m-0 min-w-0">{post.title}</h3>
            <span id="preview-date" class="label shrink-0 mt-1">{new Date(post.posted_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' })}</span>
          </div>
          {post.summary && <p id="preview-summary" class="text-muted text-sm mt-1 mb-0">{post.summary}</p>}
          {!post.summary && <p id="preview-summary" class="text-muted text-sm mt-1 mb-0 hidden"></p>}
          <MediaGallery media={attachedMedia} maxWidth="max-w-sm" />
          <div id="preview-body" class="post-preview-markdown text-muted text-sm leading-relaxed mt-3" set:html={renderedPreviewBody} />
          <div class="flex items-center gap-3 mt-3 text-xs">
            <span id="preview-place" class="coord">{post.place_name || post.stop_title || ''}</span>
          </div>
        </article>
      </section>

      <div id="form-error" class="text-ember text-sm hidden p-3 border border-ember bg-surface-2"></div>
      <div id="form-success" class="text-green-500 text-sm hidden p-3 border border-green-500 bg-surface-2">Saved!</div>

      <div class="flex flex-wrap gap-3 items-center mt-2">
        <button type="submit" class="btn">Save</button>
        <button type="button" id="delete-btn" class="btn btn-sm"
          style="border-color: rgba(212,107,92,.55); color: var(--sunset);">
          Delete
        </button>
      </div>
    </form>
  </div>

  <script define:vars={{ stops }}>
    const form = document.getElementById('post-edit-form');
    const errorDiv = document.getElementById('form-error');
    const successDiv = document.getElementById('form-success');
    const previewTitle = document.getElementById('preview-title');
    const previewSummary = document.getElementById('preview-summary');
    const previewBody = document.getElementById('preview-body');
    const previewDate = document.getElementById('preview-date');
    const previewMeta = document.getElementById('preview-meta');
    const previewPlace = document.getElementById('preview-place');
    const postId = form.querySelector('[name="id"]').value;
    const mediaUploadInput = document.getElementById('media-upload-input');
    const uploadMediaBtn = document.getElementById('upload-media-btn');
    const openMediaPickerBtn = document.getElementById('open-media-picker-btn');
    const closeMediaPickerBtn = document.getElementById('close-media-picker-btn');
    const mediaPickerPanel = document.getElementById('media-picker-panel');
    const mediaPickerList = document.getElementById('media-picker-list');
    const attachSelectedMediaBtn = document.getElementById('attach-selected-media-btn');
    const mediaPickerStatus = document.getElementById('media-picker-status');
    const mediaAttachStatus = document.getElementById('media-attach-status');
    const TUS_VERSION = '1.0.0';

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderInline(value) {
      return escapeHtml(value)
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        .replace(/\[([^\]]+)\]\((https?:\/\/[^)\s]+|\/[^)\s]*)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
    }

    function renderMarkdown(value) {
      const source = String(value ?? '').trim();
      if (!source) return '<p>Markdown preview appears here as you write.</p>';
      const blocks = [];
      let items = [];
      const flush = () => {
        if (!items.length) return;
        blocks.push(`<ul>${items.map((item) => `<li>${item}</li>`).join('')}</ul>`);
        items = [];
      };
      for (const line of source.split(/\r?\n/)) {
        const trimmed = line.trim();
        if (!trimmed) {
          flush();
          continue;
        }
        const list = trimmed.match(/^[-*]\s+(.+)$/);
        if (list) {
          items.push(renderInline(list[1]));
          continue;
        }
        flush();
        const heading = trimmed.match(/^(#{1,3})\s+(.+)$/);
        if (heading) {
          const level = heading[1].length + 2;
          blocks.push(`<h${level}>${renderInline(heading[2])}</h${level}>`);
        } else {
          blocks.push(`<p>${renderInline(trimmed)}</p>`);
        }
      }
      flush();
      return blocks.join('');
    }

    function updatePreview() {
      const title = form.querySelector('[name="title"]').value.trim() || 'Untitled post';
      const summary = form.querySelector('[name="summary"]').value.trim();
      const body = form.querySelector('[name="body"]').value;
      const postedAt = form.querySelector('[name="posted_at"]').value;
      const status = form.querySelector('[name="status"]').value;
      const visibility = form.querySelector('[name="visibility"]').value;
      const stopId = form.querySelector('[name="stop_id"]').value;
      const stop = stops.find((s) => s.id === stopId);

      previewTitle.textContent = title;
      previewSummary.textContent = summary;
      previewSummary.classList.toggle('hidden', !summary);
      previewBody.innerHTML = renderMarkdown(body);
      previewDate.textContent = postedAt ? new Date(postedAt + 'T00:00:00Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' }) : '';
      previewMeta.textContent = `${status} · ${visibility}`;
      previewPlace.textContent = stop?.place_name || stop?.title || '';
    }

    form.addEventListener('input', updatePreview);
    form.addEventListener('change', updatePreview);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const id = formData.get('id');

      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      const body = {
        title: formData.get('title'),
        summary: formData.get('summary') || null,
        body: formData.get('body') || null,
        stop_id: formData.get('stop_id') || null,
        status: formData.get('status'),
        visibility: formData.get('visibility'),
        posted_at: formData.get('posted_at') ? formData.get('posted_at') + 'T00:00:00.000Z' : undefined,
        post_type: 'update',
      };

      try {
        const res = await fetch(`/api/admin/posts/${id}`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          successDiv.classList.remove('hidden');
          setTimeout(() => successDiv.classList.add('hidden'), 3000);
        } else {
          const err = await res.json().catch(() => ({}));
          errorDiv.textContent = err.detail || `Error ${res.status}`;
          errorDiv.classList.remove('hidden');
        }
      } catch {
        errorDiv.textContent = 'Network error';
        errorDiv.classList.remove('hidden');
      }
    });

    function mediaThumb(asset) {
      if (asset.kind === 'video') return '/media/' + asset.id + '/poster';
      return '/media/' + asset.id + '/webp';
    }

    async function attachMediaIds(mediaIds) {
      if (!mediaIds.length) return;
      mediaAttachStatus.textContent = 'Attaching media';
      const res = await fetch('/api/admin/posts/' + postId + '/media', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ media_ids: mediaIds }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.detail || 'Attach failed: HTTP ' + res.status);
      }
      window.location.reload();
    }

    async function uploadOneMedia(file) {
      const meta = 'filename ' + btoa(file.name) + ',filetype ' + btoa(file.type || 'application/octet-stream');
      const createRes = await fetch('/api/admin/media/tus', {
        method: 'POST',
        credentials: 'include',
        headers: {
          'Tus-Resumable': TUS_VERSION,
          'Upload-Length': String(file.size),
          'Upload-Metadata': meta,
        },
      });
      if (!createRes.ok) throw new Error('Upload create failed: HTTP ' + createRes.status);
      const location = createRes.headers.get('Location');
      if (!location) throw new Error('Upload did not return a Location header');

      const patchRes = await fetch(location, {
        method: 'PATCH',
        credentials: 'include',
        headers: {
          'Tus-Resumable': TUS_VERSION,
          'Upload-Offset': '0',
          'Content-Type': 'application/offset+octet-stream',
        },
        body: file,
      });
      if (!patchRes.ok) throw new Error('Upload failed: HTTP ' + patchRes.status);
      return patchRes.headers.get('X-Postmarked-Asset-Id') || location.split('/').pop();
    }

    uploadMediaBtn.addEventListener('click', () => mediaUploadInput.click());
    mediaUploadInput.addEventListener('change', async () => {
      const files = Array.from(mediaUploadInput.files || []);
      if (!files.length) return;
      uploadMediaBtn.disabled = true;
      mediaAttachStatus.textContent = 'Uploading 0 / ' + files.length;
      try {
        const mediaIds = [];
        for (const [index, file] of files.entries()) {
          mediaAttachStatus.textContent = 'Uploading ' + (index + 1) + ' / ' + files.length;
          mediaIds.push(await uploadOneMedia(file));
        }
        await attachMediaIds(mediaIds);
      } catch (err) {
        mediaAttachStatus.textContent = err?.message || 'Upload failed';
        uploadMediaBtn.disabled = false;
      } finally {
        mediaUploadInput.value = '';
      }
    });

    async function loadMediaPicker() {
      mediaPickerPanel.classList.remove('hidden');
      mediaPickerStatus.textContent = 'Loading';
      mediaPickerList.innerHTML = '';
      try {
        const res = await fetch('/api/admin/media', { credentials: 'include' });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const assets = await res.json();
        mediaPickerStatus.textContent = assets.length + ' items';
        mediaPickerList.innerHTML = assets.length ? assets.map((asset) => {
          const thumb = mediaThumb(asset);
          const label = (asset.caption || asset.original_filename || asset.id || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
          return '<label class="flex items-center gap-3 border border-line-soft rounded p-2 bg-bg cursor-pointer hover:border-ember">'
            + '<input type="checkbox" value="' + asset.id + '" data-media-picker-checkbox />'
            + '<img src="' + thumb + '" alt="" class="w-12 h-12 rounded object-cover bg-line-soft shrink-0" loading="lazy" />'
            + '<span class="min-w-0 flex-1">'
            + '<span class="block text-xs text-paper truncate">' + label + '</span>'
            + '<span class="label">' + asset.kind + ' · ' + asset.processing_state + '</span>'
            + '</span>'
            + '</label>';
        }).join('') : '<div class="text-sm text-muted p-3">No media assets found.</div>';
      } catch (err) {
        mediaPickerStatus.textContent = err?.message || 'Failed to load media';
      }
    }

    openMediaPickerBtn.addEventListener('click', loadMediaPicker);
    closeMediaPickerBtn.addEventListener('click', () => mediaPickerPanel.classList.add('hidden'));
    attachSelectedMediaBtn.addEventListener('click', async () => {
      const mediaIds = Array.from(mediaPickerList.querySelectorAll('[data-media-picker-checkbox]:checked')).map((input) => input.value);
      if (!mediaIds.length) {
        mediaPickerStatus.textContent = 'Select media first';
        return;
      }
      attachSelectedMediaBtn.disabled = true;
      mediaPickerStatus.textContent = 'Attaching';
      try {
        await attachMediaIds(mediaIds);
      } catch (err) {
        mediaPickerStatus.textContent = err?.message || 'Attach failed';
        attachSelectedMediaBtn.disabled = false;
      }
    });

    document.querySelectorAll('[data-media-caption-input]').forEach((input) => {
      let savedValue = input.value;
      let saveTimer = null;

      async function saveCaption() {
        const mediaId = input.dataset.mediaId;
        const caption = input.value.trim();
        const status = document.querySelector(`[data-media-caption-status="${mediaId}"]`);
        if (!mediaId || caption === savedValue.trim()) return;

        if (saveTimer) window.clearTimeout(saveTimer);
        status.textContent = 'Saving';
        input.disabled = true;

        try {
          const res = await fetch(`/api/admin/media/${mediaId}`, {
            method: 'PATCH',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ caption }),
          });
          if (res.ok) {
            savedValue = caption;
            status.textContent = 'Saved';
            saveTimer = window.setTimeout(() => { status.textContent = ''; }, 2000);
          } else {
            const err = await res.json().catch(() => ({}));
            status.textContent = err.detail || `Save failed: HTTP ${res.status}`;
          }
        } catch {
          status.textContent = 'Network error';
        } finally {
          input.disabled = false;
        }
      }

      input.addEventListener('blur', saveCaption);
      input.addEventListener('keydown', (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key === 'Enter') {
          event.preventDefault();
          input.blur();
        }
      });
    });

    document.querySelectorAll('[data-delete-media-id]').forEach((button) => {
      button.addEventListener('click', async () => {
        const mediaId = button.dataset.deleteMediaId;
        const kind = button.dataset.deleteMediaKind || 'media item';
        if (!mediaId) return;
        if (!confirm(`Delete this ${kind}? This removes it from the post and deletes the media file.`)) return;

        errorDiv.classList.add('hidden');
        successDiv.classList.add('hidden');
        button.disabled = true;
        button.textContent = 'Deleting';

        try {
          const res = await fetch(`/api/admin/media/${mediaId}`, {
            method: 'DELETE',
            credentials: 'include',
          });
          if (res.ok) {
            window.location.reload();
          } else {
            const err = await res.json().catch(() => ({}));
            errorDiv.textContent = err.detail || `Delete failed: HTTP ${res.status}`;
            errorDiv.classList.remove('hidden');
            button.disabled = false;
            button.textContent = 'Delete';
          }
        } catch {
          errorDiv.textContent = 'Network error';
          errorDiv.classList.remove('hidden');
          button.disabled = false;
          button.textContent = 'Delete';
        }
      });
    });

    // ── Media drag-to-reorder ─────────────────────────────────────────────
    (function initMediaReorder() {
      const list = document.getElementById('media-list');
      if (!list) return;

      let dragging = null;

      list.addEventListener('dragstart', (e) => {
        const card = e.target.closest('[data-media-card]');
        if (!card) return;
        dragging = card;
        card.style.opacity = '0.4';
        e.dataTransfer.effectAllowed = 'move';
      });

      list.addEventListener('dragend', () => {
        if (dragging) dragging.style.opacity = '';
        dragging = null;
        list.querySelectorAll('[data-media-card]').forEach(c => c.classList.remove('drag-over'));
      });

      list.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        const target = e.target.closest('[data-media-card]');
        if (!target || target === dragging) return;
        list.querySelectorAll('[data-media-card]').forEach(c => c.classList.remove('drag-over'));
        target.classList.add('drag-over');
        const cards = Array.from(list.querySelectorAll('[data-media-card]'));
        const fromIndex = cards.indexOf(dragging);
        const toIndex = cards.indexOf(target);
        if (fromIndex < toIndex) {
          target.after(dragging);
        } else {
          target.before(dragging);
        }
      });

      list.addEventListener('drop', async (e) => {
        e.preventDefault();
        list.querySelectorAll('[data-media-card]').forEach(c => c.classList.remove('drag-over'));
        const mediaIds = Array.from(list.querySelectorAll('[data-media-card]')).map(c => c.dataset.mediaId);
        mediaAttachStatus.textContent = 'Saving order…';
        try {
          const res = await fetch(`/api/admin/posts/${postId}/media/order`, {
            method: 'PUT',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ media_ids: mediaIds }),
          });
          if (res.ok) {
            mediaAttachStatus.textContent = 'Order saved';
            setTimeout(() => { mediaAttachStatus.textContent = ''; }, 2000);
          } else {
            mediaAttachStatus.textContent = 'Save failed';
          }
        } catch {
          mediaAttachStatus.textContent = 'Network error';
        }
      });
    })();

    document.getElementById('delete-btn').addEventListener('click', async () => {
      const id = form.querySelector('[name="id"]').value;
      const title = form.querySelector('[name="title"]').value;
      if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;

      try {
        const res = await fetch(`/api/admin/posts/${id}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (res.ok) {
          window.location.href = '/admin/posts';
        } else {
          errorDiv.textContent = `Delete failed: HTTP ${res.status}`;
          errorDiv.classList.remove('hidden');
        }
      } catch {
        errorDiv.textContent = 'Network error';
        errorDiv.classList.remove('hidden');
      }
    });
  </script>
  <style>
    .media-drag-handle { font-size: 1.2rem; line-height: 1; }
    .media-card.drag-over { outline: 2px solid var(--ember); outline-offset: -2px; }
    .media-card[draggable="true"] { cursor: default; }
  </style>
</AdminLayout>
