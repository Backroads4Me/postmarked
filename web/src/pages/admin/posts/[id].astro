---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';
import { renderMarkdown } from '../../../lib/markdown.js';
import MediaGallery from '../../../components/ui/MediaGallery.astro';

const { id } = Astro.params;
const cookie = Astro.request.headers.get('cookie');

let post = null;
let stops = [];
try {
  const [postsRes, stopsRes] = await Promise.all([
    fetch(apiUrl('/api/admin/posts'), { headers: cookie ? { cookie } : {} }),
    fetch(apiUrl('/api/admin/stops'), { headers: cookie ? { cookie } : {} }),
  ]);
  if (postsRes.status === 401 || postsRes.status === 403) return Astro.redirect('/auth/login');
  if (postsRes.ok) {
    const all = await postsRes.json();
    post = all.find(p => p.id === id);
  }
  if (stopsRes.ok) stops = await stopsRes.json();
} catch (e) {}

if (!post) return Astro.redirect('/admin/posts');

stops.sort((a, b) => new Date(b.start_date) - new Date(a.start_date));

const attachedMedia = post.media || [];
const renderedPreviewBody = renderMarkdown(post.body || '');

// Format datetime for datetime-local input (strips timezone, yields local-ish value)
function toDatetimeLocal(iso) {
  if (!iso) return '';
  return new Date(iso).toISOString().slice(0, 16);
}
---

<AdminLayout title={`Edit: ${post.title}`}>
  <div class="max-w-2xl">
    <div class="mb-8">
      <a href="/admin/posts" class="text-xs font-mono uppercase tracking-widest text-dim hover:text-ember mb-4 inline-block">← Back</a>
      <div class="flex items-center gap-3">
        <h1 class="display text-3xl">Edit Post</h1>
      </div>
    </div>

    <form id="post-edit-form" class="flex flex-col gap-6">
      <input type="hidden" name="id" value={post.id} />

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold" for="title">Title</label>
        <input id="title" type="text" name="title" value={post.title} required maxlength="200"
          class="bg-surface-2 border border-line p-3 focus:border-ember" />
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold" for="posted_at">Post date</label>
        <input id="posted_at" type="datetime-local" name="posted_at" value={toDatetimeLocal(post.posted_at)}
          class="bg-surface-2 border border-line p-3 focus:border-ember" />
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold" for="body">Body (markdown)</label>
        <textarea id="body" name="body" rows="8"
          class="bg-surface-2 border border-line p-3 font-sans focus:border-ember">{post.body ?? ''}</textarea>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="stop_id">Stop</label>
          <select id="stop_id" name="stop_id" class="bg-surface-2 border border-line p-3">
            <option value="">No stop</option>
            {stops.map(s => (
              <option value={s.id} selected={s.id === post.stop_id}>{s.title}</option>
            ))}
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="status">Status</label>
          <select id="status" name="status" class="bg-surface-2 border border-line p-3">
            {['draft','published','unpublished','archived'].map(status => (
              <option value={status} selected={post.status === status}>{status}</option>
            ))}
          </select>
          <span class="text-xs text-dim">Only published posts appear outside admin pages.</span>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold" for="visibility">Visibility</label>
          <select id="visibility" name="visibility" class="bg-surface-2 border border-line p-3">
            <option value="private" selected={post.visibility === 'private'}>Private — logged-in users</option>
            <option value="public" selected={post.visibility === 'public'}>Public — anyone</option>
          </select>
          <span class="text-xs text-dim">Visibility applies after the post is published.</span>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex items-baseline justify-between gap-3">
          <label class="text-sm font-bold">Attached media</label>
          <span class="text-xs text-dim">{attachedMedia.length} item{attachedMedia.length === 1 ? '' : 's'}</span>
        </div>
        {attachedMedia.length > 0 ? (
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {attachedMedia.map((m) => (
              <a
                href={`/media/${m.id}/webp`}
                target="_blank"
                rel="noopener noreferrer"
                class="block bg-surface-2 border border-line-soft rounded overflow-hidden hover:border-ember transition-colors"
                style="text-decoration: none;"
              >
                <div class="aspect-square bg-line-soft">
                  {m.kind === 'video' ? (
                    <img
                      src={`/media/${m.id}/poster`}
                      alt={m.alt_text || m.caption || ''}
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <img
                      src={`/media/${m.id}/webp`}
                      alt={m.alt_text || m.caption || ''}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover"
                    />
                  )}
                </div>
                <div class="p-2">
                  <div class="label">{m.kind} · {m.processing_state}</div>
                  {(m.caption || m.alt_text) && (
                    <div class="text-xs text-muted mt-1 truncate">{m.caption || m.alt_text}</div>
                  )}
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="bg-surface-2 border border-line-soft rounded p-3 text-sm text-muted">
            No media is attached to this post.
          </div>
        )}
      </div>

      <section class="flex flex-col gap-2">
        <div class="flex items-baseline justify-between gap-3">
          <h2 class="display text-xl m-0">Timeline preview</h2>
          <span id="preview-meta" class="label">{post.status} · {post.visibility}</span>
        </div>
        <article class="card-flat">
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-symbol" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M5 19h14"/><path d="m14 5 5 5"/><path d="M4 16.5 15.5 5 19 8.5 7.5 20H4v-3.5Z"/></svg>
            </span>
            <span class="eyebrow">Update</span>
            <span id="preview-date" class="label ml-auto">{new Date(post.posted_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
          </div>
          <h3 id="preview-title" class="text-lg font-medium text-paper mb-1">{post.title}</h3>
          <div id="preview-body" class="post-preview-markdown text-muted text-sm leading-relaxed line-clamp-3" set:html={renderedPreviewBody || '<p>Markdown preview appears here as you write.</p>'} />
          <MediaGallery media={attachedMedia} maxWidth="max-w-sm" />
          <div class="flex items-center gap-3 mt-3 text-xs">
            <span id="preview-place" class="coord">{post.place_name || post.stop_title || ''}</span>
          </div>
        </article>
      </section>

      <div id="form-error" class="text-ember text-sm hidden p-3 border border-ember bg-surface-2"></div>
      <div id="form-success" class="text-green-500 text-sm hidden p-3 border border-green-500 bg-surface-2">Saved!</div>

      <div class="flex flex-wrap gap-3 items-center mt-2">
        <button type="submit" class="btn">Save</button>
        <button type="button" id="delete-btn" class="btn btn-sm"
          style="border-color: rgba(212,107,92,.55); color: var(--sunset);">
          Delete
        </button>
      </div>
    </form>
  </div>

  <script define:vars={{ stops }}>
    const form = document.getElementById('post-edit-form');
    const errorDiv = document.getElementById('form-error');
    const successDiv = document.getElementById('form-success');
    const previewTitle = document.getElementById('preview-title');
    const previewBody = document.getElementById('preview-body');
    const previewDate = document.getElementById('preview-date');
    const previewMeta = document.getElementById('preview-meta');
    const previewPlace = document.getElementById('preview-place');

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderInline(value) {
      return escapeHtml(value)
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        .replace(/\[([^\]]+)\]\((https?:\/\/[^)\s]+|\/[^)\s]*)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
    }

    function renderMarkdown(value) {
      const source = String(value ?? '').trim();
      if (!source) return '<p>Markdown preview appears here as you write.</p>';
      const blocks = [];
      let items = [];
      const flush = () => {
        if (!items.length) return;
        blocks.push(`<ul>${items.map((item) => `<li>${item}</li>`).join('')}</ul>`);
        items = [];
      };
      for (const line of source.split(/\r?\n/)) {
        const trimmed = line.trim();
        if (!trimmed) {
          flush();
          continue;
        }
        const list = trimmed.match(/^[-*]\s+(.+)$/);
        if (list) {
          items.push(renderInline(list[1]));
          continue;
        }
        flush();
        const heading = trimmed.match(/^(#{1,3})\s+(.+)$/);
        if (heading) {
          const level = heading[1].length + 2;
          blocks.push(`<h${level}>${renderInline(heading[2])}</h${level}>`);
        } else {
          blocks.push(`<p>${renderInline(trimmed)}</p>`);
        }
      }
      flush();
      return blocks.join('');
    }

    function updatePreview() {
      const title = form.querySelector('[name="title"]').value.trim() || 'Untitled post';
      const body = form.querySelector('[name="body"]').value;
      const postedAt = form.querySelector('[name="posted_at"]').value;
      const status = form.querySelector('[name="status"]').value;
      const visibility = form.querySelector('[name="visibility"]').value;
      const stopId = form.querySelector('[name="stop_id"]').value;
      const stop = stops.find((s) => s.id === stopId);

      previewTitle.textContent = title;
      previewBody.innerHTML = renderMarkdown(body);
      previewDate.textContent = postedAt ? new Date(postedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
      previewMeta.textContent = `${status} · ${visibility}`;
      previewPlace.textContent = stop?.place_name || stop?.title || '';
    }

    form.addEventListener('input', updatePreview);
    form.addEventListener('change', updatePreview);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const id = formData.get('id');

      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      const body = {
        title: formData.get('title'),
        body: formData.get('body') || null,
        stop_id: formData.get('stop_id') || null,
        status: formData.get('status'),
        visibility: formData.get('visibility'),
        posted_at: new Date(formData.get('posted_at')).toISOString(),
        post_type: 'update',
      };

      try {
        const res = await fetch(`/api/admin/posts/${id}`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          successDiv.classList.remove('hidden');
          setTimeout(() => successDiv.classList.add('hidden'), 3000);
        } else {
          const err = await res.json().catch(() => ({}));
          errorDiv.textContent = err.detail || `Error ${res.status}`;
          errorDiv.classList.remove('hidden');
        }
      } catch {
        errorDiv.textContent = 'Network error';
        errorDiv.classList.remove('hidden');
      }
    });

    document.getElementById('delete-btn').addEventListener('click', async () => {
      const id = form.querySelector('[name="id"]').value;
      const title = form.querySelector('[name="title"]').value;
      if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;

      try {
        const res = await fetch(`/api/admin/posts/${id}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (res.ok) {
          window.location.href = '/admin/posts';
        } else {
          errorDiv.textContent = `Delete failed: HTTP ${res.status}`;
          errorDiv.classList.remove('hidden');
        }
      } catch {
        errorDiv.textContent = 'Network error';
        errorDiv.classList.remove('hidden');
      }
    });
  </script>
</AdminLayout>
