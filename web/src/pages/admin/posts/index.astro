---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

let posts = [];
try {
  const res = await fetch(apiUrl('/api/admin/posts'), {
    headers: { 'Cookie': Astro.request.headers.get('cookie') || '' }
  });
  if (res.ok) posts = await res.json();
} catch (e) {
  console.error(e);
}

function formatPostDate(dateStr) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function statusBadge(status) {
  if (status === 'draft') return 'badge-draft';
  if (status === 'published') return 'badge-published';
  if (status === 'unpublished') return 'badge-unpublished';
  if (status === 'archived') return 'badge-private';
  return 'badge-draft';
}
---

<AdminLayout title="Posts">
  <div class="mb-8 flex justify-end">
    <a href="/admin/posts/new" class="btn btn-sm">Quick Post</a>
  </div>

  {posts.length > 0 ? (
    <div class="grid gap-4">
      {posts.map(post => (
        <div class="card-flat">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="text-lg" aria-hidden="true">✏️</span>
              <span class={`badge text-[9px] ${statusBadge(post.status)}`}>
                {post.status}
              </span>
              <span class={`badge text-[9px] ${post.visibility === 'public' ? 'badge-public' : 'badge-private'}`}>
                {post.visibility}
              </span>
            </div>
            <div class="flex items-center gap-3 self-center">
              <span class="text-paper text-base font-medium leading-none">{formatPostDate(post.posted_at)}</span>
              <a href={`/admin/posts/${post.id}`} class="btn ghost btn-sm">Edit</a>
            </div>
          </div>
          <h3 class="text-base font-medium" style="color: var(--paper);">{post.title}</h3>
          {post.body && <p class="text-sm text-muted mt-1 line-clamp-2">{post.body}</p>}
          {post.stop_title && (
            <span class="coord mt-2 block">📍 {post.stop_title}</span>
          )}
        </div>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <div class="icon">✏️</div>
      <h3>No posts yet</h3>
      <p>Create a quick post to share what you're up to.</p>
    </div>
  )}
</AdminLayout>
