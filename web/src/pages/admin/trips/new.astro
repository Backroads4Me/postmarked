---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

const cookie = Astro.request.headers.get('cookie');
// Basic authorization check
try {
  const check = await fetch(apiUrl('/api/admin/trips'), { headers: cookie ? { cookie } : {} });
  if (check.status === 401 || check.status === 403) return Astro.redirect('/auth/login');
} catch(e) {}
---

<AdminLayout title="New Trip">
  <div class="max-w-2xl">
    <div class="mb-8">
      <a href="/admin/trips" class="text-xs font-mono uppercase tracking-widest text-dim hover:text-ember inline-block">← Back</a>
    </div>
    
    <form id="trip-form" class="flex flex-col gap-6">
      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold">Title</label>
        <input type="text" name="title" required class="bg-surface-2 border border-line p-3 focus:outline-none focus:border-ember" placeholder="Summer Rockies Loop">
      </div>
      
      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold">Slug</label>
        <input type="text" name="slug" required class="bg-surface-2 border border-line p-3" placeholder="summer-rockies-loop">
        <span class="text-xs text-dim">URL identifier. Must be unique.</span>
      </div>
      
      <div class="flex flex-col gap-2">
        <label class="text-sm font-bold">Summary</label>
        <textarea name="summary" rows="3" class="bg-surface-2 border border-line p-3 focus:outline-none focus:border-ember"></textarea>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold">Status</label>
          <select name="status" class="bg-surface-2 border border-line p-3">
            <option value="draft" selected>Draft</option>
            <option value="published">Published</option>
            <option value="unpublished">Unpublished</option>
            <option value="archived">Archived</option>
          </select>
          <span class="text-xs text-dim">Only published trips appear outside admin pages. Visibility applies after publishing.</span>
        </div>
        
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold">Visibility</label>
          <select name="visibility" class="bg-surface-2 border border-line p-3">
            <option value="private" selected>Private — logged-in users</option>
            <option value="public">Public — anyone</option>
          </select>
        </div>
      </div>
      
      <div id="form-error" class="text-ember text-sm hidden p-3 border border-ember bg-surface-2"></div>
      
      <button type="submit" class="btn mt-4">Save Trip</button>
    </form>
  </div>

  <script>
    document.getElementById('trip-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const errorDiv = document.getElementById('form-error');
      const data = Object.fromEntries(new FormData(form).entries());
      
      try {
        const res = await fetch('/api/admin/trips', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (res.ok) {
          const trip = await res.json();
          window.location.href = '/admin/trips';
        } else {
          const err = await res.json();
          errorDiv.textContent = err.detail || 'Validation error';
          errorDiv.classList.remove('hidden');
        }
      } catch (err) {
        errorDiv.textContent = 'Network error saving trip';
        errorDiv.classList.remove('hidden');
      }
    });
  </script>
</AdminLayout>
