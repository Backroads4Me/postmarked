---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';
import { formatDate as fmtDate } from '../../../lib/dates.js';

const { id } = Astro.params;
const cookie = Astro.request.headers.get('cookie');

let trip = null;
try {
  // First verify authorization via trips list or detail endpoint
  const authRes = await fetch(apiUrl('/api/admin/trips'), { headers: cookie ? { cookie } : {} });
  if (authRes.status === 401 || authRes.status === 403) return Astro.redirect('/auth/login');

  // Lookup all admin trips to find by ID, then fetch detail through the regular reader endpoint.
  const allTrips = await authRes.json();
  trip = allTrips.find(t => t.id === id);
  
  if (trip) {
    const dRes = await fetch(apiUrl(`/api/trips/${trip.slug}`), { headers: cookie ? { cookie } : {} });
    if (dRes.ok) trip = await dRes.json();

  }
} catch(e) {}

if (!trip) return Astro.redirect('/admin/trips');

function formatDate(value) {
  return fmtDate(value, { month: 'short', day: 'numeric', year: 'numeric' }) || '—';
}
---

<AdminLayout title={`Edit ${trip.title}`}>
  <div class="w-full grid grid-cols-1 lg:grid-cols-2 gap-12">
    <div>
      <div class="mb-8">
        <a href="/admin/trips" class="inline-flex items-center gap-1.5 text-xs font-mono uppercase tracking-widest text-dim hover:text-ember transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18 9 12l6-6"/></svg>
          Back
        </a>
      </div>
      
      <form id="trip-update-form" class="flex flex-col gap-6" data-has-cover={trip.cover_media?.derivative_paths?.webp ? 'true' : 'false'}>
        <input type="hidden" name="id" value={trip.id} />
        
        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold">Title</label>
          <input type="text" name="title" value={trip.title} required class="form-input">
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold">Slug</label>
          <input type="text" name="slug" value={trip.slug} required class="form-input">
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-sm font-bold">Summary</label>
          <textarea name="summary" rows="3" class="form-input">{trip.summary}</textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold">Status</label>
            <select name="status" class="form-input">
              <option value="draft" selected={trip.status === "draft"}>Draft</option>
              <option value="published" selected={trip.status === "published"}>Published</option>
              <option value="unpublished" selected={trip.status === "unpublished"}>Unpublished</option>
              <option value="archived" selected={trip.status === "archived"}>Archived</option>
            </select>
            <span class="text-xs text-dim">Only published trips appear outside admin pages. Visibility applies after publishing.</span>
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold">Visibility</label>
            <select name="visibility" class="form-input">
              <option value="private" selected={trip.visibility === "private"}>Private — logged-in users</option>
              <option value="public" selected={trip.visibility === "public"}>Public — anyone</option>
            </select>
            <span class="text-xs text-dim">Private content is visible to logged-in readers only.</span>
          </div>
        </div>

        <div id="form-error" class="alert alert-danger hidden"></div>
        <div id="form-success" class="alert alert-success hidden">Saved!</div>

        <button type="submit" class="btn btn-primary mt-4">Save Trip</button>
      </form>

      <section class="card-flat mt-8">
        <div class="label mb-3">Cover Image</div>

        <div id="cover-preview">
        {trip.cover_media?.derivative_paths?.webp ? (
          <div class="mb-4">
            <img
              src={trip.cover_media.derivative_paths.webp}
              alt="Cover"
              class="w-full rounded border border-line object-cover"
              style="max-height: 180px;"
            />
            <p class="text-xs text-dim mt-1">Current cover</p>
          </div>
        ) : (
          <div class="mb-4 w-full rounded border border-line bg-surface-1 flex items-center justify-center text-dim text-sm" style="height:100px;">
            No cover image
          </div>
        )}
        </div>

        <div id="cover-upload-status" class="text-xs text-muted mb-2 hidden"></div>
        <input
          id="cover-file-input"
          type="file"
          accept="image/*"
          class="form-input"
        />
        <div class="flex flex-wrap gap-3 mt-3">
          <button id="cover-upload-btn" type="button" class="btn btn-sm">Upload Cover</button>
          <button
            id="cover-clear-btn"
            type="button"
            class:list={['btn btn-sm btn-primary', { hidden: !trip.cover_media }]}
          >
            Clear Cover
          </button>
        </div>
      </section>

      <section class="card-flat danger-zone mt-8">
        <div class="label mb-2 text-sunset">Danger Zone</div>
        <h2 class="text-lg font-semibold mb-2">Delete this trip</h2>
        <p class="text-sm text-muted mb-4">
          Removes the trip, its stops, and trip-only cover/uploads. Posts and attached media are kept but detached where possible.
        </p>
        <button
          type="button"
          id="trip-delete-button"
          class="btn btn-sm btn-primary"
          data-trip-id={trip.id}
          data-trip-title={trip.title}
        >
          Delete Trip
        </button>
      </section>
    </div>
    
    <div>
      <div class="mb-8 flex justify-between items-center">
        <h2 class="display text-3xl">Stops</h2>
      </div>
      
      <div class="admin-list">
        {trip.stops && trip.stops.length > 0 ? (
          <div class="divide-y divide-line">
            {trip.stops.map(stop => (
              <div class="p-4 flex flex-col md:flex-row justify-between md:items-center gap-4">
                <div>
                  <div class="font-bold text-lg">{stop.title}</div>
                  <div class="text-xs text-dim font-mono tracking-widest">{formatDate(stop.start_date)}</div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="p-8 text-center text-muted">
            No stops added yet.
          </div>
        )}
      </div>
    </div>
  </div>

  <script>
    document.getElementById('trip-update-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const errorDiv = document.getElementById('form-error');
      const successDiv = document.getElementById('form-success');

      const formData = new FormData(form);
      const id = formData.get('id');
      formData.delete('id');
      const data = Object.fromEntries(formData.entries());

      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      const hasCover = form.dataset.hasCover === 'true';
      if (data.status === 'published' && !hasCover) {
        errorDiv.textContent = 'A cover image is required before publishing. Upload one above, then try again.';
        errorDiv.classList.remove('hidden');
        return;
      }
      
      try {
        const res = await fetch(`/api/admin/trips/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (res.ok) {
          successDiv.classList.remove('hidden');
          setTimeout(() => successDiv.classList.add('hidden'), 3000);
        } else {
          const err = await res.json();
          errorDiv.textContent = err.detail || 'Validation error';
          errorDiv.classList.remove('hidden');
        }
      } catch (err) {
        errorDiv.textContent = 'Network error saving trip';
        errorDiv.classList.remove('hidden');
      }
    });

    document.getElementById('trip-delete-button')?.addEventListener('click', async (e) => {
      const target = e.currentTarget;
      const id = target.dataset.tripId;
      const title = target.dataset.tripTitle || 'this trip';
      const errorDiv = document.getElementById('form-error');
      if (!id) return;

      const confirmed = window.confirm(`Delete "${title}"? This also removes its stops. This cannot be undone.`);
      if (!confirmed) return;

      errorDiv.classList.add('hidden');
      target.disabled = true;
      target.textContent = 'Deleting...';

      try {
        const res = await fetch(`/api/admin/trips/${id}`, {
          method: 'DELETE',
          credentials: 'include',
        });

        if (res.ok) {
          window.location.href = '/admin/trips';
        } else {
          const detail = await res.text();
          throw new Error(detail || `HTTP ${res.status}`);
        }
      } catch (err) {
        target.disabled = false;
        target.textContent = 'Delete Trip';
        errorDiv.textContent = `Could not delete trip: ${err instanceof Error ? err.message : String(err)}`;
        errorDiv.classList.remove('hidden');
      }
    });

    // Cover image TUS upload
    document.getElementById('cover-upload-btn')?.addEventListener('click', async () => {
      const fileInput = document.getElementById('cover-file-input') as HTMLInputElement;
      const statusEl = document.getElementById('cover-upload-status');
      const tripId = document.querySelector<HTMLInputElement>('[name="id"]')?.value;
      const file = fileInput?.files?.[0];
      if (!file || !tripId) return;

      const btn = document.getElementById('cover-upload-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Uploading…';
      statusEl?.classList.remove('hidden');
      if (statusEl) statusEl.textContent = 'Uploading…';

      try {
        const TUS_VERSION = '1.0.0';
        const meta = `filename ${btoa(file.name)},filetype ${btoa(file.type || 'image/jpeg')}`;
        const createRes = await fetch('/api/admin/media/tus', {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Tus-Resumable': TUS_VERSION,
            'Upload-Length': String(file.size),
            'Upload-Metadata': meta,
          },
        });
        if (!createRes.ok) throw new Error(`Upload create failed: ${createRes.status}`);
        const location = createRes.headers.get('Location');
        if (!location) throw new Error('No Location header');

        const patchRes = await fetch(location, {
          method: 'PATCH',
          credentials: 'include',
          headers: {
            'Tus-Resumable': TUS_VERSION,
            'Upload-Offset': '0',
            'Content-Type': 'application/offset+octet-stream',
          },
          body: file,
        });
        if (!patchRes.ok) throw new Error(`Upload patch failed: ${patchRes.status}`);

        const assetId = patchRes.headers.get('X-Postmarked-Asset-Id') || location.split('/').pop();

        // Set as cover
        const patchTrip = await fetch(`/api/admin/trips/${tripId}`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ cover_media_id: assetId }),
        });
        if (!patchTrip.ok) throw new Error(`Failed to set cover: ${patchTrip.status}`);

        updateCoverPreview(file);
        if (fileInput) fileInput.value = '';
        if (statusEl) statusEl.textContent = 'Cover uploaded. Processing may take a moment.';
        document.getElementById('cover-clear-btn')?.classList.remove('hidden');
        document.getElementById('trip-update-form')?.setAttribute('data-has-cover', 'true');
        btn.textContent = 'Done';
      } catch (e) {
        if (statusEl) statusEl.textContent = `Error: ${e instanceof Error ? e.message : String(e)}`;
        btn.disabled = false;
        btn.textContent = 'Upload Cover';
      }
    });

    document.getElementById('cover-clear-btn')?.addEventListener('click', async (e) => {
      const button = e.currentTarget as HTMLButtonElement;
      const tripId = document.querySelector<HTMLInputElement>('[name="id"]')?.value;
      const statusEl = document.getElementById('cover-upload-status');
      if (!tripId) return;

      const confirmed = window.confirm('Clear this cover image? The current cover media file will be deleted.');
      if (!confirmed) return;

      button.disabled = true;
      button.textContent = 'Clearing...';
      statusEl?.classList.remove('hidden');
      if (statusEl) statusEl.textContent = 'Clearing cover...';

      try {
        const res = await fetch(`/api/admin/trips/${tripId}`, {
          method: 'PATCH',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ cover_media_id: null }),
        });
        if (!res.ok) throw new Error(`Failed to clear cover: ${res.status}`);

        clearCoverPreview();
        button.classList.add('hidden');
        if (statusEl) statusEl.textContent = 'Cover cleared.';
        document.getElementById('trip-update-form')?.setAttribute('data-has-cover', 'false');
      } catch (err) {
        if (statusEl) statusEl.textContent = `Error: ${err instanceof Error ? err.message : String(err)}`;
      } finally {
        button.disabled = false;
        button.textContent = 'Clear Cover';
      }
    });

    function updateCoverPreview(file: File) {
      const preview = document.getElementById('cover-preview');
      if (!preview) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'mb-4';

      const image = document.createElement('img');
      image.src = URL.createObjectURL(file);
      image.alt = 'Cover';
      image.className = 'w-full rounded border border-line object-cover';
      image.style.maxHeight = '180px';
      image.addEventListener('load', () => URL.revokeObjectURL(image.src), { once: true });

      const caption = document.createElement('p');
      caption.className = 'text-xs text-dim mt-1';
      caption.textContent = 'Current cover';

      wrapper.append(image, caption);
      preview.replaceChildren(wrapper);
    }

    function clearCoverPreview() {
      const preview = document.getElementById('cover-preview');
      if (!preview) return;

      const empty = document.createElement('div');
      empty.className = 'mb-4 w-full rounded border border-line bg-surface-1 flex items-center justify-center text-dim text-sm';
      empty.style.height = '100px';
      empty.textContent = 'No cover image';

      preview.replaceChildren(empty);
    }
  </script>
</AdminLayout>
