---
import AdminLayout from '../../../layouts/AdminLayout.astro';

let trips = [];
const cookie = Astro.request.headers.get('cookie');

try {
  const res = await fetch('http://api:8000/admin/trips', {
    headers: cookie ? { cookie } : {}
  });
  
  if (res.status === 401 || res.status === 403) {
    return Astro.redirect('/auth/login');
  }
  
  if (res.ok) {
    trips = await res.json();
  }
} catch (e) {
  console.error("Failed to load admin trips", e);
}
---

<AdminLayout title="Manage Trips">
  <div class="mb-12 flex justify-between items-center">
    <div>
      <h1 class="display text-4xl">Trips</h1>
      <p class="text-muted mt-2">Manage all journeys, including non-published drafts.</p>
    </div>
    <a href="/admin/trips/new" class="btn">New Trip</a>
  </div>
  
  <div class="bg-surface-2 border border-line rounded">
    {trips.length > 0 ? (
      <div class="divide-y divide-line">
        {trips.map(trip => (
          <div class="p-4 flex flex-col md:flex-row justify-between md:items-center gap-4">
            <div>
              <div class="font-bold text-lg">{trip.title}</div>
              <div class="text-sm text-dim font-mono tracking-widest">{trip.slug} · {trip.status} · {trip.visibility}</div>
            </div>
            <div class="flex gap-2">
              <a href={`/admin/trips/${trip.id}`} class="btn ghost btn-sm">Edit</a>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="p-8 text-center text-muted">
        No trips found. Create one to get started.
      </div>
    )}
  </div>
</AdminLayout>
