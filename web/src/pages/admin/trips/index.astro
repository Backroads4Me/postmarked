---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

let trips = [];
const cookie = Astro.request.headers.get('cookie');

try {
  const res = await fetch(apiUrl('/api/admin/trips'), {
    headers: cookie ? { cookie } : {}
  });

  if (res.status === 401 || res.status === 403) {
    return Astro.redirect('/auth/login');
  }

  if (res.ok) {
    trips = await res.json();
  }
} catch (e) {
  console.error("Failed to load admin trips", e);
}

const draftTrips = trips.filter(t => t.status === 'draft');
const activeTrips = trips.filter(t => t.status !== 'draft');

function statusBadge(status) {
  return status === 'draft'
    ? 'badge-draft'
    : status === 'published'
        ? 'badge-published'
        : status === 'unpublished'
          ? 'badge-unpublished'
        : status === 'archived'
          ? 'badge-private'
          : 'badge-planned';
}
---

<AdminLayout title="Manage Trips">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h1 class="display text-4xl">Trips</h1>
      <p class="text-muted mt-2">Manage all journeys, including non-published drafts.</p>
    </div>
    <a href="/admin/trips/new" class="btn">New Trip</a>
  </div>

  {draftTrips.length > 0 && (
    <section class="mb-6">
      <div class="label mb-2">Drafts</div>
      <div class="bg-surface-2 border border-line rounded">
        <div class="divide-y divide-line">
          {draftTrips.map(trip => (
            <div class="p-4 flex flex-col md:flex-row justify-between md:items-center gap-4" data-trip-row={trip.id}>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-bold text-lg">{trip.title}</span>
                  <span class="badge badge-draft text-[9px]">draft</span>
                  <span class={`badge text-[9px] ${trip.visibility === 'public' ? 'badge-public' : 'badge-private'}`}>
                    {trip.visibility}
                  </span>
                </div>
                <div class="text-xs text-dim font-mono tracking-widest">
                  {trip.slug}
                  {trip.start_date && ` · ${new Date(trip.start_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}`}
                  {trip.end_date && ` – ${new Date(trip.end_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}`}
                </div>
              </div>
              <div class="flex gap-2">
                <a href={`/admin/trips/${trip.id}`} class="btn ghost btn-sm">Edit</a>
                <button
                  type="button"
                  class="btn btn-sm js-delete-trip"
                  data-trip-id={trip.id}
                  data-trip-title={trip.title}
                  style="border-color: rgba(212,107,92,.45); color: var(--sunset);"
                >
                  Delete
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="bg-surface-2 border border-line rounded" id="trips-list">
    {activeTrips.length > 0 ? (
      <div class="divide-y divide-line">
        {activeTrips.map(trip => (
          <div class="p-4 flex flex-col md:flex-row justify-between md:items-center gap-4" data-trip-row={trip.id}>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="font-bold text-lg">{trip.title}</span>
                <span class={`badge text-[9px] ${statusBadge(trip.status)}`}>
                  {trip.status}
                </span>
              </div>
              <div class="text-xs text-dim font-mono tracking-widest">
                {trip.slug}
                {trip.start_date && ` · ${new Date(trip.start_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}`}
                {trip.end_date && ` – ${new Date(trip.end_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}`}
              </div>
            </div>
            <div class="flex gap-2">
              <a href={`/admin/trips/${trip.id}`} class="btn ghost btn-sm">Edit</a>
              <button
                type="button"
                class="btn btn-sm js-delete-trip"
                data-trip-id={trip.id}
                data-trip-title={trip.title}
                style="border-color: rgba(212,107,92,.45); color: var(--sunset);"
              >
                Delete
              </button>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="p-8 text-center text-muted">No trips found. Create one to get started.</div>
    )}
  </div>
</AdminLayout>

<script>
  document.querySelectorAll('button.js-delete-trip').forEach((btn) => {
    btn.addEventListener('click', async (event) => {
      const target = event.currentTarget as HTMLButtonElement;
      const tripId = target.dataset.tripId;
      const tripTitle = target.dataset.tripTitle || 'this trip';
      if (!tripId) return;

      const confirmed = window.confirm(`Delete "${tripTitle}"? This also removes its stops and planned stops. This cannot be undone.`);
      if (!confirmed) return;

      target.disabled = true;
      const originalText = target.textContent;
      target.textContent = 'Deleting...';

      try {
        const res = await fetch(`/api/admin/trips/${tripId}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (!res.ok) {
          const detail = await res.text();
          throw new Error(detail || `HTTP ${res.status}`);
        }
        document.querySelector(`[data-trip-row="${tripId}"]`)?.remove();
      } catch (error) {
        target.disabled = false;
        target.textContent = originalText;
        alert(`Could not delete trip: ${error instanceof Error ? error.message : String(error)}`);
      }
    });
  });
</script>
