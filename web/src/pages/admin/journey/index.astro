---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

let journeys = [];
let loadError = null;
try {
  const res = await fetch(apiUrl('/api/admin/journeys'), {
    headers: { 'Cookie': Astro.request.headers.get('cookie') || '' },
  });
  if (res.ok) journeys = await res.json();
  else loadError = `API ${res.status}`;
} catch (e) {
  loadError = e?.message || 'Failed to connect';
}

function fmt(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<AdminLayout title="Journeys">
  <div class="mb-8 flex justify-between items-start">
    <div>
      <div class="label mb-2">Manage</div>
      <h1 class="display text-3xl">Journeys</h1>
      <p class="text-muted text-sm mt-2">
        A journey is the long-running container for trips, stops, and posts. Only one is active at a time.
      </p>
    </div>
  </div>

  {loadError && (
    <div class="card-flat mb-6 text-sm text-ember">{loadError}</div>
  )}

  <section class="mb-10">
    <h2 class="display text-xl mb-3">+ New journey</h2>
    <form id="new-journey-form" class="card-flat" style="display: flex; flex-direction: column; gap: 12px;">
      <div>
        <label class="label" for="nj-title">Title</label>
        <input id="nj-title" name="title" required maxlength="200"
          style="width:100%;padding:10px 12px;background:var(--surface-2);border:1px solid var(--line);border-radius:6px;color:var(--paper);margin-top:6px;" />
      </div>
      <div>
        <label class="label" for="nj-summary">Summary</label>
        <textarea id="nj-summary" name="summary" rows="3" maxlength="10000"
          style="width:100%;padding:10px 12px;background:var(--surface-2);border:1px solid var(--line);border-radius:6px;color:var(--paper);margin-top:6px;font-family:var(--sans);"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <label class="label" for="nj-status">Status</label>
          <select id="nj-status" name="status"
            style="width:100%;padding:10px 12px;background:var(--surface-2);border:1px solid var(--line);border-radius:6px;color:var(--paper);margin-top:6px;">
            <option value="ACTIVE" selected>Active</option>
            <option value="PAUSED">Paused</option>
            <option value="ARCHIVED">Archived</option>
          </select>
        </div>
        <div>
          <label class="label" for="nj-vis">Visibility</label>
          <select id="nj-vis" name="visibility"
            style="width:100%;padding:10px 12px;background:var(--surface-2);border:1px solid var(--line);border-radius:6px;color:var(--paper);margin-top:6px;">
            <option value="PUBLIC" selected>Public</option>
            <option value="PRIVATE">Private</option>
          </select>
        </div>
      </div>
      <div>
        <button type="submit" class="btn btn-primary" style="min-height:44px;">Create journey</button>
        <span class="label" id="nj-status-msg" style="margin-left:12px;"></span>
      </div>
    </form>
  </section>

  <section>
    <h2 class="display text-xl mb-3">All journeys</h2>
    {journeys.length > 0 ? (
      <div class="card-flat" style="padding: 0; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
          <thead>
            <tr style="border-bottom: 1px solid var(--line);">
              <th class="label" style="padding:10px 16px;text-align:left;">Title</th>
              <th class="label" style="padding:10px 12px;text-align:center;">Status</th>
              <th class="label" style="padding:10px 12px;text-align:center;">Visibility</th>
              <th class="label" style="padding:10px 12px;text-align:center;">Starts</th>
              <th class="label" style="padding:10px 12px;text-align:center;">Action</th>
            </tr>
          </thead>
          <tbody>
            {journeys.map(j => (
              <tr style="border-bottom: 1px solid var(--line-soft);">
                <td style="padding: 10px 16px;">
                  <a href={`/admin/journey/${j.id}`} style="color: var(--paper);">{j.title}</a>
                  <span class="coord block mt-0.5">{j.slug}</span>
                </td>
                <td style="padding: 10px 12px; text-align: center;">
                  <span class={`badge text-[9px] ${j.status === 'active' ? 'badge-active' : 'badge-planned'}`}>
                    {j.status}
                  </span>
                </td>
                <td style="padding: 10px 12px; text-align: center;">
                  <span class={`badge text-[9px] ${j.visibility === 'public' ? 'badge-public' : 'badge-private'}`}>
                    {j.visibility}
                  </span>
                </td>
                <td style="padding: 10px 12px; text-align: center; color: var(--muted);">
                  {fmt(j.starts_on)}
                </td>
                <td style="padding: 10px 12px; text-align: center;">
                  {j.status === 'active' ? (
                    <span class="badge badge-active text-[9px]">active</span>
                  ) : (
                    <button type="button" class="btn btn-sm js-activate" data-id={j.id} style="min-height: 32px;">
                      Activate
                    </button>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state">
        <div class="icon">🗺️</div>
        <h3>No journeys yet</h3>
        <p>Create your first journey above. The RV Trip Wizard import auto-creates one if you skip this.</p>
      </div>
    )}
  </section>
</AdminLayout>

<script>
  const form = document.getElementById('new-journey-form') as HTMLFormElement | null;
  const msg = document.getElementById('nj-status-msg');
  form?.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const data = new FormData(form);
    if (msg) msg.textContent = 'Saving…';
    try {
      const res = await fetch('/api/admin/journeys', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: String(data.get('title') || '').trim(),
          summary: String(data.get('summary') || '').trim() || null,
          status: String(data.get('status')),
          visibility: String(data.get('visibility')),
        }),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      location.reload();
    } catch (e) {
      if (msg) msg.textContent = 'Failed: ' + (e instanceof Error ? e.message : String(e));
    }
  });

  document.querySelectorAll('button.js-activate').forEach((btn) => {
    btn.addEventListener('click', async (ev) => {
      const target = ev.currentTarget as HTMLButtonElement;
      const id = target.dataset.id;
      if (!id) return;
      target.disabled = true;
      target.textContent = 'Activating…';
      try {
        const res = await fetch(`/api/admin/journeys/${id}/activate`, {
          method: 'POST',
          credentials: 'include',
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        location.reload();
      } catch (e) {
        target.disabled = false;
        target.textContent = 'Activate';
        alert('Failed: ' + (e instanceof Error ? e.message : String(e)));
      }
    });
  });
</script>
