---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

const ADMIN_TZ = (typeof process !== 'undefined' && process.env.PUBLIC_ADMIN_TIMEZONE)
  || import.meta.env.PUBLIC_ADMIN_TIMEZONE
  || 'America/New_York';

let mediaAssets = [];
const cookie = Astro.request.headers.get('cookie');

try {
  const res = await fetch(apiUrl('/api/admin/media'), {
    headers: cookie ? { cookie } : {}
  });

  if (res.status === 401 || res.status === 403) {
    return Astro.redirect('/auth/login');
  }

  if (res.ok) {
    mediaAssets = await res.json();
  }
} catch (e) {
  console.error("Failed to load admin media", e);
}

// Collect unique folders for the filter bar
const folders = [...new Set(mediaAssets.map(a => a.folder).filter(Boolean))].sort();

function formatDate(isoStr) {
  if (!isoStr) return '';
  try {
    return new Intl.DateTimeFormat('en-US', {
      timeZone: ADMIN_TZ,
      month: 'short', day: 'numeric', year: 'numeric',
      hour: 'numeric', minute: '2-digit',
    }).format(new Date(isoStr));
  } catch {
    return isoStr;
  }
}
---

<AdminLayout title="Media">
  <div class="mb-6 flex flex-wrap gap-3 justify-between items-center">
    <div class="flex flex-wrap gap-2" id="folder-filters">
      <button class="folder-btn active" data-folder="">All</button>
      {folders.map(f => (
        <button class="folder-btn" data-folder={f}>{f}</button>
      ))}
    </div>
    <a href="/admin/intake" class="btn">Upload More</a>
  </div>

  <div class="admin-list">
    {mediaAssets.length > 0 ? (
      <div class="divide-y divide-line" id="asset-list">
        {mediaAssets.map(asset => (
          <div
            class="p-4 flex flex-col md:flex-row justify-between md:items-center gap-4"
            data-asset-row={asset.id}
            data-folder={asset.folder || ''}
          >
            <div class="flex gap-4 items-center">
              {/* Thumbnail — click to preview */}
              {asset.derivative_paths?.webp || asset.derivative_paths?.poster ? (
                <button
                  type="button"
                  class="js-preview w-16 h-16 bg-surface-1 rounded overflow-hidden flex-shrink-0 border border-line hover:border-ember transition-colors cursor-zoom-in"
                  data-kind={asset.kind}
                  data-webp={asset.derivative_paths?.webp || ''}
                  data-poster={asset.derivative_paths?.poster || ''}
                  data-mp4={asset.derivative_paths?.mp4 || ''}
                  aria-label="Preview media"
                >
                  <img
                    src={asset.derivative_paths.webp || asset.derivative_paths.poster}
                    class="w-full h-full object-cover pointer-events-none"
                    alt=""
                  />
                </button>
              ) : (
                <div class:list={[
                  "w-16 h-16 bg-surface-1 rounded border border-line flex items-center justify-center text-xs text-dim flex-shrink-0",
                  { 'danger-zone': asset.processing_state === 'failed' }
                ]}>
                  {asset.processing_state}
                </div>
              )}

              <div>
                <div class="text-xs font-mono text-dim truncate max-w-xs">{asset.original_filename || asset.id}</div>
                <div class="text-xs text-dim font-mono tracking-widest uppercase mt-0.5">
                  {asset.kind} ·
                  <span style={asset.processing_state === 'failed' ? 'color: var(--sunset);' : asset.processing_state === 'ready' ? 'color: var(--forest);' : ''}>
                    {asset.processing_state}
                  </span>
                  {asset.width && ` · ${asset.width}×${asset.height}`}
                  {asset.duration_seconds && ` · ${Math.round(asset.duration_seconds)}s`}
                </div>
                <div class="text-xs text-dim mt-0.5">
                  {formatDate(asset.created_at)}
                  {asset.folder && <span class="ml-2 px-1.5 py-0.5 bg-surface-2 border border-line rounded text-xs font-mono">{asset.folder}</span>}
                </div>
                {asset.error_message && (
                  <div class="text-xs mt-1 max-w-xl" style="color: var(--sunset);">
                    {asset.error_message}
                  </div>
                )}
              </div>
            </div>

            <div class="flex gap-2 items-center flex-shrink-0 flex-wrap">
              <span class="text-xs px-2 py-1 bg-surface-1 border border-line rounded-full uppercase font-mono tracking-widest">{asset.visibility}</span>
              {asset.processing_state === 'failed' || asset.processing_state === 'pending' ? (
                <button
                  type="button"
                  class="btn btn-sm js-requeue"
                  data-asset-id={asset.id}
                  title="Retry processing"
                >
                  Retry
                </button>
              ) : null}
              {(asset.stop_id || asset.post_id || asset.trip_id) ? (
                <button
                  type="button"
                  class="btn btn-sm js-detach"
                  data-asset-id={asset.id}
                  title="Remove from stop/post without deleting the file"
                >
                  Detach
                </button>
              ) : null}
              <button
                type="button"
                class="btn btn-sm btn-primary js-delete-asset"
                data-asset-id={asset.id}
              >
                Delete
              </button>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="p-8 text-center text-muted">
        No media assets found.
      </div>
    )}
  </div>
</AdminLayout>

<!-- Preview modal -->
<div
  id="preview-modal"
  class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/80"
  role="dialog"
  aria-modal="true"
>
  <button
    type="button"
    id="preview-close"
    class="absolute top-4 right-4 text-white text-3xl leading-none hover:text-ember"
    aria-label="Close preview"
  >&times;</button>
  <div id="preview-content" class="max-w-5xl max-h-[90vh] flex items-center justify-center p-4"></div>
</div>

<style>
  .folder-btn {
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--line);
    border-radius: 9999px;
    background: var(--surface-1);
    color: var(--text-muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .folder-btn:hover { border-color: var(--ember); color: var(--ember); }
  .folder-btn.active { background: var(--ember); color: #fff; border-color: var(--ember); }
</style>

<script define:vars={{ adminTz: ADMIN_TZ }}>
  // ── Folder filter ───────────────────────────────────────────────────────
  document.querySelectorAll('.folder-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.folder-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const folder = btn.dataset.folder;
      document.querySelectorAll('[data-asset-row]').forEach(row => {
        const match = folder === '' || row.dataset.folder === folder;
        row.style.display = match ? '' : 'none';
      });
    });
  });

  // ── Preview modal ────────────────────────────────────────────────────────
  const modal = document.getElementById('preview-modal');
  const content = document.getElementById('preview-content');
  const closeBtn = document.getElementById('preview-close');

  function openPreview(kind, webp, poster, mp4) {
    content.innerHTML = '';
    if (kind === 'video' && mp4) {
      const vid = document.createElement('video');
      vid.src = mp4;
      vid.controls = true;
      vid.autoplay = true;
      vid.className = 'max-w-full max-h-[80vh] rounded';
      if (poster) vid.poster = poster;
      content.appendChild(vid);
    } else {
      const img = document.createElement('img');
      img.src = webp || poster;
      img.className = 'max-w-full max-h-[85vh] rounded object-contain';
      img.alt = '';
      content.appendChild(img);
    }
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closePreview() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    content.innerHTML = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.js-preview').forEach(btn => {
    btn.addEventListener('click', () => {
      openPreview(btn.dataset.kind, btn.dataset.webp, btn.dataset.poster, btn.dataset.mp4);
    });
  });

  closeBtn.addEventListener('click', closePreview);
  modal.addEventListener('click', e => { if (e.target === modal) closePreview(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closePreview(); });

  // ── Requeue ──────────────────────────────────────────────────────────────
  document.querySelectorAll('button.js-requeue').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget;
      const id = target.dataset.assetId;
      if (!id) return;
      target.disabled = true;
      target.textContent = 'Queued…';
      try {
        const res = await fetch(`/api/admin/media/${id}/requeue`, {
          method: 'POST',
          credentials: 'include',
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        target.textContent = 'Queued';
      } catch (err) {
        target.disabled = false;
        target.textContent = 'Retry';
        alert(`Requeue failed: ${err instanceof Error ? err.message : String(err)}`);
      }
    });
  });

  // ── Detach ───────────────────────────────────────────────────────────────
  document.querySelectorAll('button.js-detach').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget;
      const id = target.dataset.assetId;
      if (!id || !confirm('Detach this asset from its stop/post? The file will not be deleted.')) return;
      target.disabled = true;
      target.textContent = 'Detaching…';
      try {
        const res = await fetch(`/api/admin/media/${id}/detach`, {
          method: 'POST',
          credentials: 'include',
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        target.closest('[data-asset-row]')?.querySelector('.js-detach')?.remove();
        target.remove();
      } catch (err) {
        target.disabled = false;
        target.textContent = 'Detach';
        alert(`Detach failed: ${err instanceof Error ? err.message : String(err)}`);
      }
    });
  });

  // ── Delete ───────────────────────────────────────────────────────────────
  document.querySelectorAll('button.js-delete-asset').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget;
      const id = target.dataset.assetId;
      if (!id || !confirm('Delete this media asset? This cannot be undone.')) return;
      target.disabled = true;
      try {
        const res = await fetch(`/api/admin/media/${id}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        document.querySelector(`[data-asset-row="${id}"]`)?.remove();
      } catch (err) {
        target.disabled = false;
        alert(`Delete failed: ${err instanceof Error ? err.message : String(err)}`);
      }
    });
  });
</script>
