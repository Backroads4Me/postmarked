---
import AdminLayout from '../../layouts/AdminLayout.astro';
import CurrentStopPickerIsland from '../../components/admin/CurrentStopPickerIsland.jsx';
---

<AdminLayout title="Dashboard">

  {/* Hero: current location picker — the most-used admin action from the road */}
  <section class="mb-10" id="current-stop-hero">
    <CurrentStopPickerIsland client:load />
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <a href="/admin/posts/new" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">New Update</h2>
      <p class="text-sm text-dim mt-2">Write a short note + attach a photo from the road.</p>
    </a>
    <a href="/admin/stops" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">Stops</h2>
      <p class="text-sm text-dim mt-2">Create stops, mark current, edit details.</p>
    </a>
    <a href="/admin/trips" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">Trips</h2>
      <p class="text-sm text-dim mt-2">Create trip segments and group stops.</p>
    </a>
    <a href="/admin/imports/rv-trip-wizard" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">Import Trip</h2>
      <p class="text-sm text-dim mt-2">Upload an Excel export to plan upcoming stops.</p>
    </a>
    <a href="/admin/posts" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">Posts</h2>
      <p class="text-sm text-dim mt-2">Edit or delete past updates.</p>
    </a>
    <a href="/admin/media" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">Media</h2>
      <p class="text-sm text-dim mt-2">Upload, assign, and review photos.</p>
    </a>
    <a href="/admin/backup" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">Backup & Restore</h2>
      <p class="text-sm text-dim mt-2">Download a backup or restore from a ZIP archive.</p>
    </a>
    <a href="/admin/users" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">Users</h2>
      <p class="text-sm text-dim mt-2">Approve, manage, and configure user accounts.</p>
    </a>
    <a href="/admin/site-text" class="card-flat hover:border-ember transition-colors block">
      <h2 class="display text-xl">Site Text</h2>
      <p class="text-sm text-dim mt-2">Edit the about blurb and other site copy.</p>
    </a>
  </div>
</AdminLayout>
