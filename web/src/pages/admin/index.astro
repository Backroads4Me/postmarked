---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <div class="mb-12">
    <h1 class="display text-4xl">Admin Dashboard</h1>
    <p class="text-muted mt-2">Manage the journal's content and settings.</p>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <a href="/admin/trips" class="block p-6 border border-line rounded bg-surface-2 hover:border-ember transition-colors">
      <h2 class="display text-2xl mb-2">Manage Trips</h2>
      <p class="text-sm text-dim">Create new journeys and attach stops to them.</p>
    </a>
  </div>
</AdminLayout>
