---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Media Intake">
  <div id="uppy-dashboard" class="mb-12"></div>

  <link href="https://releases.transloadit.com/uppy/v3.23.0/uppy.min.css" rel="stylesheet">
  <script type="module" hoist>
    import { Uppy, Dashboard, Tus } from "https://releases.transloadit.com/uppy/v3.23.0/uppy.min.mjs"

    const uppy = new Uppy({
      restrictions: {
        maxNumberOfFiles: 50
      }
    })
    .use(Dashboard, {
      inline: true,
      target: '#uppy-dashboard',
      theme: 'dark'
    })
    .use(Tus, {
      endpoint: '/api/admin/media/tus',
      limit: 3,
      retryDelays: [0, 1000, 3000, 5000],
      chunkSize: 5 * 1024 * 1024,
    });

    uppy.on('complete', (result) => {
      const succeeded = result.successful.length;
      const failed = result.failed.length;
      if (failed > 0) {
        alert(`${succeeded} upload${succeeded === 1 ? '' : 's'} completed; ${failed} failed. Review the failed files and retry.`);
      } else if (succeeded > 0) {
        alert("Upload finished. Assets pushed to processing queue!");
        window.location.href = '/admin/media';
      }
    });
  </script>
</AdminLayout>
