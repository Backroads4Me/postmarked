---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ImportPreviewIsland from '../../../components/admin/ImportPreviewIsland.jsx';
---

<AdminLayout title="Import RV Trip Wizard">
  <div class="mb-8">
    <div class="label mb-2">Import</div>
    <h1 class="display text-3xl">RV Trip Wizard</h1>
    <p class="text-muted text-sm mt-2">
      Upload an Excel export from RV Trip Wizard to create a draft trip with normal stops.
      Reimporting the same trip will show a diff of changes.
    </p>
  </div>

  <ImportPreviewIsland client:load />
</AdminLayout>
