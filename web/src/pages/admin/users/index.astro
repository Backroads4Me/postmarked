---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { apiUrl } from '../../../lib/api.js';

const cookie = Astro.request.headers.get('cookie');
const authHeaders = cookie ? { cookie } : {};
let users = [];
let loadError = null;
let email_enabled = false;
let siteConfig = { require_user_approval: true, sms_enabled: false };
let preApprovedEmails = [];

try {
  const [res, configRes, siteConfigRes, preApprovedRes] = await Promise.all([
    fetch(apiUrl('/api/admin/users'), { headers: authHeaders }),
    fetch(apiUrl('/api/config')),
    fetch(apiUrl('/api/admin/site-config'), { headers: authHeaders }),
    fetch(apiUrl('/api/admin/pre-approved-emails'), { headers: authHeaders }),
  ]);
  if (res.status === 401 || res.status === 403) {
    return Astro.redirect('/auth/login');
  }
  if (res.ok) {
    users = await res.json();
  } else {
    loadError = `API ${res.status}`;
  }
  if (configRes.ok) {
    ({ email_enabled } = await configRes.json());
  }
  if (siteConfigRes.ok) {
    siteConfig = await siteConfigRes.json();
  }
  if (preApprovedRes.ok) {
    preApprovedEmails = await preApprovedRes.json();
  }
} catch (e) {
  loadError = e?.message || 'Failed to connect';
}

const sms_enabled = siteConfig.sms_enabled ?? false;
const pending = users.filter(u => u.approval_state === 'pending');
const approved = users.filter(u => u.approval_state === 'approved');
const rejected = users.filter(u => u.approval_state === 'rejected');

---

<AdminLayout title="Users">

  {loadError && <div class="card-flat mb-4 text-sm text-ember">{loadError}</div>}

  <div class="grid gap-5 mb-10">
    <!-- Approval requirement toggle -->
    <div class="admin-list p-4 flex items-center justify-between gap-4">
      <div>
        <div class="font-bold">Require admin approval for new users</div>
        <div class="text-sm text-muted mt-1">When on, new registrations stay pending until you approve them. Pre-approved emails bypass this.</div>
      </div>
      <button
        id="approval-toggle"
        class="btn btn-sm"
        data-value={siteConfig.require_user_approval ? 'true' : 'false'}
        onclick="toggleApprovalRequirement(this)"
      >
        {siteConfig.require_user_approval ? 'On' : 'Off'}
      </button>
    </div>

    <!-- SMS toggle -->
    <div class="admin-list p-4 flex items-center justify-between gap-4">
      <div>
        <div class="font-bold">Enable SMS notifications</div>
        <div class="text-sm text-muted mt-1">Show the phone number and SMS consent fields on registration and account pages. Requires Twilio credentials to be configured.</div>
      </div>
      <button
        id="sms-toggle"
        class="btn btn-sm"
        data-value={siteConfig.sms_enabled ? 'true' : 'false'}
        onclick="toggleSmsEnabled(this)"
      >
        {siteConfig.sms_enabled ? 'On' : 'Off'}
      </button>
    </div>

    <!-- Pre-approved emails -->
    <div class="admin-list p-4 grid gap-4">
      <div>
        <div class="font-bold">Pre-approved emails</div>
        <div class="text-sm text-muted mt-1">Anyone who registers with one of these addresses is automatically approved, even if approval is required.</div>
      </div>

      {preApprovedEmails.length > 0 && (
        <ul id="pre-approved-list" class="grid gap-1">
          {preApprovedEmails.map((entry: { id: string; email: string }) => (
            <li class="flex items-center justify-between gap-2 text-sm py-1 border-b border-line last:border-0" data-id={entry.id}>
              <span class="font-mono">{entry.email}</span>
              <button
                class="text-xs text-muted hover:text-ember transition-colors"
                onclick={`deletePreApproved('${entry.id}', this)`}
              >
                Remove
              </button>
            </li>
          ))}
        </ul>
      )}
      <form onsubmit="event.preventDefault(); addPreApproved(this);" class="grid gap-2">
        <textarea
          name="emails"
          rows="3"
          placeholder="One email address per line"
          class="admin-input w-full text-sm font-mono"
        ></textarea>
        <div>
          <button type="submit" class="btn btn-sm">Add</button>
        </div>
      </form>
    </div>
  </div>

  {pending.length > 0 && (
    <section class="mb-10">
      <h2 class="display text-2xl mb-4">Pending Approval ({pending.length})</h2>
      <div class="grid gap-3">
        {pending.map(u => (
          <div class="card-flat grid gap-3">
            <div class="grid grid-cols-2 gap-2">
              <div class="grid gap-1">
                <label class="label">Display name</label>
                <input type="text" class="admin-input"
                  value={u.display_name || ''}
                  placeholder="(no name)"
                  data-user-id={u.id}
                  onblur={`updateUserProfile('${u.id}', this, 'name')`} />
              </div>
              <div class="grid gap-1">
                <label class="label">Email</label>
                <input type="email" class="admin-input"
                  value={u.email}
                  data-user-id={u.id}
                  onblur={`updateUserProfile('${u.id}', this, 'email')`} />
              </div>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
              {u.role !== 'admin' && (
                <select class="admin-input"
                  data-original={u.role} onchange={`updateUserRole('${u.id}', this)`}>
                  <option value="user" selected={u.role !== 'admin'}>User</option>
                  <option value="admin">Admin</option>
                </select>
              )}
              {email_enabled && (
                <select class="admin-input"
                  data-email-select={u.id}
                  onchange={`updateUserEmailOptIn('${u.id}', this)`}>
                  <option value="false" selected={!u.email_opted_in}>Email off</option>
                  <option value="true" selected={u.email_opted_in}>Email on</option>
                </select>
              )}
              {sms_enabled && (
                <input type="tel" class="admin-input w-28"
                  placeholder="Phone" value={u.phone_number || ''} data-user-id={u.id}
                  onblur={`updateUserSms('${u.id}', this)`} />
              )}
              {sms_enabled && (
                <select class="admin-input"
                  data-sms-select={u.id} onchange={`updateUserSmsOptIn('${u.id}', this)`}>
                  <option value="false" selected={!u.sms_opted_in}>SMS off</option>
                  <option value="true" selected={u.sms_opted_in}>SMS on</option>
                </select>
              )}
              {(email_enabled || sms_enabled) && (
                <select class="admin-input"
                  data-freq-select={u.id}
                  onchange={`updateUserFrequency('${u.id}', this)`}>
                  <option value="all_updates" selected={u.notification_frequency !== 'weekly_digest'}>Immediate</option>
                  <option value="weekly_digest" selected={u.notification_frequency === 'weekly_digest'}>Weekly</option>
                </select>
              )}
              <div class="flex-1"></div>
              <button class="btn btn-sm"
                onclick={`approveUser('${u.id}', this)`}>Approve</button>
              <button class="btn btn-sm btn-primary"
                onclick={`rejectUser('${u.id}', this)`}>Reject</button>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {pending.length === 0 && (
    <div class="card-flat mb-8 text-sm text-muted">No pending requests.</div>
  )}

  {approved.length > 0 && (
    <section class="mb-10">
      <h2 class="display text-xl mb-3">Approved ({approved.length})</h2>
      <div class="grid gap-2">
        {approved.map(u => (
          <div class="card-flat grid gap-3">
            <div class="grid grid-cols-2 gap-2">
              <div class="grid gap-1">
                <label class="label">Display name</label>
                <input type="text" class="admin-input"
                  value={u.display_name || ''}
                  placeholder="(no name)"
                  data-user-id={u.id}
                  onblur={`updateUserProfile('${u.id}', this, 'name')`} />
              </div>
              <div class="grid gap-1">
                <label class="label">Email</label>
                <input type="email" class="admin-input"
                  value={u.email}
                  data-user-id={u.id}
                  onblur={`updateUserProfile('${u.id}', this, 'email')`} />
              </div>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
              {u.role !== 'admin' && (
                <select class="admin-input"
                  data-original={u.role} onchange={`updateUserRole('${u.id}', this)`}>
                  <option value="user" selected={u.role !== 'admin'}>User</option>
                  <option value="admin">Admin</option>
                </select>
              )}
              {email_enabled && (
                <select class="admin-input"
                  data-email-select={u.id}
                  onchange={`updateUserEmailOptIn('${u.id}', this)`}>
                  <option value="false" selected={!u.email_opted_in}>Email off</option>
                  <option value="true" selected={u.email_opted_in}>Email on</option>
                </select>
              )}
              {sms_enabled && (
                <input type="tel" class="admin-input w-28"
                  placeholder="Phone" value={u.phone_number || ''} data-user-id={u.id}
                  onblur={`updateUserSms('${u.id}', this)`} />
              )}
              {sms_enabled && (
                <select class="admin-input"
                  data-sms-select={u.id} onchange={`updateUserSmsOptIn('${u.id}', this)`}>
                  <option value="false" selected={!u.sms_opted_in}>SMS off</option>
                  <option value="true" selected={u.sms_opted_in}>SMS on</option>
                </select>
              )}
              {(email_enabled || sms_enabled) && (
                <select class="admin-input"
                  data-freq-select={u.id}
                  onchange={`updateUserFrequency('${u.id}', this)`}>
                  <option value="all_updates" selected={u.notification_frequency !== 'weekly_digest'}>Immediate</option>
                  <option value="weekly_digest" selected={u.notification_frequency === 'weekly_digest'}>Weekly</option>
                </select>
              )}
              <div class="flex-1"></div>
              <span class="badge badge-active text-[10px]">approved</span>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {rejected.length > 0 && (
    <section class="mb-10">
      <h2 class="display text-xl mb-3">Rejected ({rejected.length})</h2>
      <div class="grid gap-2">
        {rejected.map(u => (
          <div class="card-flat grid gap-3" style="opacity:0.7;">
            <div class="grid grid-cols-2 gap-2">
              <div class="grid gap-1">
                <label class="label">Display name</label>
                <input type="text" class="admin-input"
                  value={u.display_name || ''}
                  placeholder="(no name)"
                  data-user-id={u.id}
                  onblur={`updateUserProfile('${u.id}', this, 'name')`} />
              </div>
              <div class="grid gap-1">
                <label class="label">Email</label>
                <input type="email" class="admin-input"
                  value={u.email}
                  data-user-id={u.id}
                  onblur={`updateUserProfile('${u.id}', this, 'email')`} />
              </div>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
              {u.role !== 'admin' && (
                <select class="admin-input"
                  data-original={u.role} onchange={`updateUserRole('${u.id}', this)`}>
                  <option value="user" selected={u.role !== 'admin'}>User</option>
                  <option value="admin">Admin</option>
                </select>
              )}
              {email_enabled && (
                <select class="admin-input"
                  data-email-select={u.id}
                  onchange={`updateUserEmailOptIn('${u.id}', this)`}>
                  <option value="false" selected={!u.email_opted_in}>Email off</option>
                  <option value="true" selected={u.email_opted_in}>Email on</option>
                </select>
              )}
              {sms_enabled && (
                <input type="tel" class="admin-input w-28"
                  placeholder="Phone" value={u.phone_number || ''} data-user-id={u.id}
                  onblur={`updateUserSms('${u.id}', this)`} />
              )}
              {sms_enabled && (
                <select class="admin-input"
                  data-sms-select={u.id} onchange={`updateUserSmsOptIn('${u.id}', this)`}>
                  <option value="false" selected={!u.sms_opted_in}>SMS off</option>
                  <option value="true" selected={u.sms_opted_in}>SMS on</option>
                </select>
              )}
              {(email_enabled || sms_enabled) && (
                <select class="admin-input"
                  data-freq-select={u.id}
                  onchange={`updateUserFrequency('${u.id}', this)`}>
                  <option value="all_updates" selected={u.notification_frequency !== 'weekly_digest'}>Immediate</option>
                  <option value="weekly_digest" selected={u.notification_frequency === 'weekly_digest'}>Weekly</option>
                </select>
              )}
              <div class="flex-1"></div>
              <button class="btn" style="min-height:32px; font-size:13px;"
                onclick={`approveUser('${u.id}', this)`}>Re-approve</button>
              {u.role !== 'admin' && (
                <select
                  class="admin-input"
                  data-original={u.role}
                  onchange={`updateUserRole('${u.id}', this)`}
                >
                  <option value="user" selected={u.role !== 'admin'}>User</option>
                  <option value="admin">Admin</option>
                </select>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</AdminLayout>

<script is:inline>
  async function _patchSiteConfig(patch) {
    const res = await fetch('/api/admin/site-config', {
      method: 'PATCH',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(patch),
    });
    if (!res.ok) {
      const d = await res.json().catch(() => ({}));
      throw new Error(d.detail || 'Failed to update setting');
    }
    return res.json();
  }

  async function toggleApprovalRequirement(btn) {
    const current = btn.dataset.value === 'true';
    const next = !current;
    btn.disabled = true;
    try {
      const smsBtn = document.getElementById('sms-toggle');
      const currentSms = smsBtn ? smsBtn.dataset.value === 'true' : false;
      await _patchSiteConfig({ require_user_approval: next, sms_enabled: currentSms });
      btn.dataset.value = next ? 'true' : 'false';
      btn.textContent = next ? 'On' : 'Off';
    } catch (e) {
      alert(e.message || 'Could not reach server');
    } finally {
      btn.disabled = false;
    }
  }

  async function toggleSmsEnabled(btn) {
    const current = btn.dataset.value === 'true';
    const next = !current;
    btn.disabled = true;
    try {
      const approvalBtn = document.getElementById('approval-toggle');
      const currentApproval = approvalBtn ? approvalBtn.dataset.value === 'true' : true;
      await _patchSiteConfig({ require_user_approval: currentApproval, sms_enabled: next });
      btn.dataset.value = next ? 'true' : 'false';
      btn.textContent = next ? 'On' : 'Off';
    } catch (e) {
      alert(e.message || 'Could not reach server');
    } finally {
      btn.disabled = false;
    }
  }

  async function addPreApproved(form) {
    const raw = form.emails.value.trim();
    if (!raw) return;
    const emails = raw.split('\n').map(e => e.trim()).filter(Boolean);
    try {
      const res = await fetch('/api/admin/pre-approved-emails', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ emails }),
      });
      if (res.ok) {
        const added = await res.json();
        const list = document.getElementById('pre-approved-list') || (() => {
          const ul = document.createElement('ul');
          ul.id = 'pre-approved-list';
          ul.className = 'grid gap-1';
          form.parentElement.insertBefore(ul, form);
          return ul;
        })();
        for (const entry of added) {
          if (!list.querySelector(`[data-id="${entry.id}"]`)) {
            const li = document.createElement('li');
            li.className = 'flex items-center justify-between gap-2 text-sm py-1 border-b border-line last:border-0';
            li.dataset.id = entry.id;
            li.innerHTML = `<span class="font-mono">${entry.email}</span><button class="text-xs text-muted hover:text-ember transition-colors" onclick="deletePreApproved('${entry.id}', this)">Remove</button>`;
            list.appendChild(li);
          }
        }
        form.reset();
      } else {
        const d = await res.json().catch(() => ({}));
        alert(d.detail || 'Failed to add emails');
      }
    } catch (e) {
      alert('Could not reach server');
    }
  }

  async function deletePreApproved(entryId, btn) {
    btn.disabled = true;
    try {
      const res = await fetch(`/api/admin/pre-approved-emails/${entryId}`, {
        method: 'DELETE',
        credentials: 'include',
      });
      if (res.ok) {
        const li = btn.closest('li');
        li?.remove();
      } else {
        const d = await res.json().catch(() => ({}));
        alert(d.detail || 'Failed to remove');
        btn.disabled = false;
      }
    } catch (e) {
      btn.disabled = false;
      alert('Could not reach server');
    }
  }

  async function approveUser(userId, btn) {
    btn.disabled = true;
    btn.textContent = '…';
    try {
      const res = await fetch(`/api/admin/users/${userId}/approve`, {
        method: 'POST',
        credentials: 'include',
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const d = await res.json().catch(() => ({}));
        btn.disabled = false;
        btn.textContent = 'Approve';
        alert(d.detail || 'Failed');
      }
    } catch (e) {
      btn.disabled = false;
      btn.textContent = 'Approve';
    }
  }

  async function rejectUser(userId, btn) {
    btn.disabled = true;
    btn.textContent = '…';
    try {
      const res = await fetch(`/api/admin/users/${userId}/reject`, {
        method: 'POST',
        credentials: 'include',
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const d = await res.json().catch(() => ({}));
        btn.disabled = false;
        btn.textContent = 'Reject';
        alert(d.detail || 'Failed');
      }
    } catch (e) {
      btn.disabled = false;
      btn.textContent = 'Reject';
    }
  }

  async function _patchNotifications(userId, email_opted_in, notification_frequency) {
    const res = await fetch(`/api/admin/users/${userId}/notifications`, {
      method: 'PATCH',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email_opted_in, notification_frequency }),
    });
    if (!res.ok) {
      const d = await res.json().catch(() => ({}));
      throw new Error(d.detail || 'Failed to update notifications');
    }
    return res.json();
  }

  async function updateUserEmailOptIn(userId, select) {
    const card = select.closest('.card-flat');
    const freqSelect = card.querySelector(`[data-freq-select="${userId}"]`);
    const notification_frequency = freqSelect ? freqSelect.value : 'all_updates';
    const email_opted_in = select.value === 'true';
    const prev = email_opted_in ? 'false' : 'true';
    select.disabled = true;
    try {
      await _patchNotifications(userId, email_opted_in, notification_frequency);
    } catch (e) {
      select.value = prev;
      alert(e.message);
    } finally {
      select.disabled = false;
    }
  }

  async function updateUserFrequency(userId, select) {
    const card = select.closest('.card-flat');
    const emailSelect = card.querySelector(`[data-email-select="${userId}"]`);
    const email_opted_in = emailSelect ? emailSelect.value === 'true' : false;
    const notification_frequency = select.value;
    const prev = notification_frequency === 'all_updates' ? 'weekly_digest' : 'all_updates';
    select.disabled = true;
    try {
      await _patchNotifications(userId, email_opted_in, notification_frequency);
    } catch (e) {
      select.value = prev;
      alert(e.message);
    } finally {
      select.disabled = false;
    }
  }

  const _profileCache = {};

  async function updateUserProfile(userId, inputEl, field) {
    const card = inputEl.closest('.card-flat');
    const nameEl = card.querySelector('input[type="text"]');
    const emailEl = card.querySelector('input[type="email"]');
    const name = nameEl?.value.trim() || null;
    const email = emailEl?.value.trim();
    if (!email) { inputEl.value = inputEl.dataset.original || ''; return; }
    const key = `${userId}`;
    if (_profileCache[key] && _profileCache[key].name === name && _profileCache[key].email === email) return;
    try {
      const res = await fetch(`/api/admin/users/${userId}/profile`, {
        method: 'PATCH',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ display_name: name, email }),
      });
      if (res.ok) {
        _profileCache[key] = { name, email };
      } else {
        const d = await res.json().catch(() => ({}));
        alert(d.detail || 'Failed to update profile');
        if (field === 'email' && _profileCache[key]) emailEl.value = _profileCache[key].email;
        if (field === 'name' && _profileCache[key]) nameEl.value = _profileCache[key].name || '';
      }
    } catch (e) {
      alert('Could not reach server');
    }
  }

  async function _patchUserSms(userId, phone, optedIn) {
    const res = await fetch(`/api/admin/users/${userId}/sms`, {
      method: 'PATCH',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone_number: phone || null, sms_opted_in: optedIn }),
    });
    if (!res.ok) {
      const d = await res.json().catch(() => ({}));
      throw new Error(d.detail || 'Failed to update SMS');
    }
    return res.json();
  }

  async function updateUserSms(userId, phoneInput) {
    let digits = phoneInput.value.replace(/\D/g, '');
    if (digits.length === 11 && digits.startsWith('1')) digits = digits.slice(1);
    phoneInput.value = digits;
    const card = phoneInput.closest('.card-flat');
    const optInSelect = card?.querySelector(`[data-sms-select="${userId}"]`);
    const optedIn = optInSelect ? optInSelect.value === 'true' : false;
    try {
      const result = await _patchUserSms(userId, digits || null, optedIn && digits.length > 0);
      if (optInSelect) optInSelect.value = result.sms_opted_in ? 'true' : 'false';
    } catch (e) {
      alert(e.message);
    }
  }

  async function updateUserSmsOptIn(userId, select) {
    const optedIn = select.value === 'true';
    const card = select.closest('.card-flat');
    const phoneInput = card?.querySelector(`input[data-user-id="${userId}"]`);
    const phone = phoneInput ? phoneInput.value.trim() : null;
    if (optedIn && !phone) {
      alert('Enter a phone number before enabling SMS.');
      select.value = 'false';
      return;
    }
    try {
      await _patchUserSms(userId, phone || null, optedIn);
    } catch (e) {
      select.value = optedIn ? 'false' : 'true';
      alert(e.message);
    }
  }

  async function updateUserRole(userId, select) {
    const original = select.dataset.original || select.value;
    if (select.value === original) return;
    if (select.value !== 'admin') {
      select.value = original;
      return;
    }
    select.disabled = true;
    try {
      const res = await fetch(`/api/admin/users/${userId}/promote`, {
        method: 'POST',
        credentials: 'include',
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const d = await res.json().catch(() => ({}));
        select.value = original;
        alert(d.detail || 'Failed');
      }
    } catch (e) {
      select.value = original;
    } finally {
      select.disabled = false;
    }
  }
</script>
