---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Backup & Restore">
  <div class="max-w-2xl mx-auto space-y-6">

    <section class="admin-list p-6">
      <h2 class="display text-xl mb-2">Export Backup</h2>
      <p class="text-sm text-dim mb-4">
        Download a ZIP archive containing all trips, stops, posts, media metadata,
        users, and processed photo/video derivatives. Use this to back up your
        instance or migrate to a new server.
      </p>
      <a
        href="/api/admin/backup/export"
        id="export-btn"
        class="btn btn-primary inline-block"
        download
      >
        Download Backup
      </a>
    </section>

    <section class="admin-list p-6">
      <h2 class="display text-xl mb-2">Server Database Snapshot</h2>
      <p class="text-sm text-dim mb-4">
        Write a timestamped database dump to the server's <code>backups</code>
        directory now. Snapshots are also taken automatically on a schedule.
        Back these up by copying the <code>backups</code> directory alongside
        <code>derivatives</code>.
      </p>
      <button id="snapshot-btn" class="btn btn-ghost">
        Snapshot Database Now
      </button>
      <p id="snapshot-status" class="text-sm mt-3 hidden" role="status" aria-live="polite"></p>
    </section>

    <section class="admin-list p-6">
      <h2 class="display text-xl mb-2">Import Backup</h2>
      <p class="text-sm text-dim mb-4">
        Upload a previously exported ZIP to fully restore this instance.
        <strong style="color: var(--sunset);">This will permanently erase all existing data</strong>
        before applying the backup.
      </p>

      <form id="import-form" class="space-y-4">
        <div class="backup-upload">
          <input
            id="backup-file"
            name="file"
            type="file"
            accept=".zip"
            required
            class="sr-only"
          />
          <label for="backup-file" class="backup-upload-target">
            <span class="backup-upload-icon" aria-hidden="true">ZIP</span>
            <span>
              <span class="backup-upload-title">Choose a backup ZIP</span>
              <span id="backup-file-status" class="backup-upload-status">No file selected</span>
            </span>
          </label>
          <p class="text-xs text-dim mt-2">
            Select a Postmarked backup export. The restore button will unlock after a ZIP is selected.
          </p>
        </div>
        <button type="submit" id="import-btn" class="btn btn-primary" disabled>
          Restore from Backup
        </button>
      </form>

      <div id="import-result" class="mt-4 hidden"></div>
    </section>

  </div>
</AdminLayout>

<style>
  .backup-upload-target {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    min-height: 88px;
    padding: 18px;
    border: 1px dashed var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--paper);
    cursor: pointer;
    transition: border-color 160ms ease, background 160ms ease, color 160ms ease;
  }

  .backup-upload-target:hover,
  .backup-upload-target:focus-within {
    border-color: var(--ember-border);
    background: var(--surface-2);
  }

  .backup-upload-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
    border-radius: 8px;
    border: 1px solid var(--ember-border);
    background: var(--ember-glow);
    color: var(--ember);
    font-family: var(--mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
  }

  .backup-upload-title,
  .backup-upload-status {
    display: block;
  }

  .backup-upload-title {
    font-weight: 600;
  }

  .backup-upload-status {
    margin-top: 4px;
    color: var(--muted);
    font-size: var(--fs-xs);
  }

  .backup-upload-target.has-file {
    border-style: solid;
    border-color: var(--ember-border);
  }

  .backup-upload-target.has-file .backup-upload-status {
    color: var(--paper);
  }
</style>

<script>
  const snapshotBtn = document.getElementById('snapshot-btn') as HTMLButtonElement;
  const snapshotStatus = document.getElementById('snapshot-status') as HTMLParagraphElement;

  snapshotBtn.addEventListener('click', async () => {
    snapshotBtn.disabled = true;
    snapshotStatus.classList.remove('hidden');
    snapshotStatus.style.color = 'var(--muted)';
    snapshotStatus.textContent = 'Requesting snapshot…';
    try {
      const res = await fetch('/api/admin/backup/snapshot', {
        method: 'POST',
        credentials: 'include',
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        snapshotStatus.style.color = 'var(--sunset)';
        snapshotStatus.textContent = `Error: ${data.detail ?? 'Snapshot request failed.'}`;
      } else {
        snapshotStatus.style.color = '';
        snapshotStatus.textContent =
          `${data.detail ?? 'Snapshot started.'} It runs in the background; check the server's backups directory.`;
      }
    } catch {
      snapshotStatus.style.color = 'var(--sunset)';
      snapshotStatus.textContent = 'Network error — could not reach the API.';
    } finally {
      snapshotBtn.disabled = false;
    }
  });

  const form = document.getElementById('import-form') as HTMLFormElement;
  const btn = document.getElementById('import-btn') as HTMLButtonElement;
  const resultEl = document.getElementById('import-result') as HTMLDivElement;
  const fileInput = document.getElementById('backup-file') as HTMLInputElement;
  const fileStatus = document.getElementById('backup-file-status') as HTMLSpanElement;
  const uploadTarget = document.querySelector('.backup-upload-target') as HTMLLabelElement;

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (!file) {
      fileStatus.textContent = 'No file selected';
      uploadTarget.classList.remove('has-file');
      btn.disabled = true;
      return;
    }

    fileStatus.textContent = `${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)`;
    uploadTarget.classList.add('has-file');
    btn.disabled = false;
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const confirmed = window.confirm(
      'This will permanently erase ALL existing data and replace it with the backup contents.\n\nAre you sure you want to continue?'
    );
    if (!confirmed) return;

    const file = fileInput.files?.[0];
    if (!file) return;

    btn.disabled = true;
    btn.textContent = 'Restoring…';
    btn.style.opacity = '0.6';
    resultEl.classList.add('hidden');
    resultEl.textContent = '';

    const body = new FormData();
    body.append('file', file);

    try {
      const res = await fetch('/api/admin/backup/import', {
        method: 'POST',
        body,
        credentials: 'include',
      });

      const data = await res.json();

      if (!res.ok) {
        resultEl.className = 'alert alert-danger mt-4';
        resultEl.textContent = `Error: ${data.detail ?? 'Import failed.'}`;
      } else {
        const counts = Object.entries(data.entity_counts as Record<string, number>)
          .map(([k, v]) => `${k}: ${v}`)
          .join(', ');
        resultEl.className = 'alert alert-success mt-4';
        resultEl.textContent = `Restore complete. Media files: ${data.media_files_copied}. Entities: ${counts}`;
      }
    } catch (err) {
      resultEl.className = 'alert alert-danger mt-4';
      resultEl.textContent = 'Network error — could not reach the API.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Restore from Backup';
      btn.style.opacity = '';
      resultEl.classList.remove('hidden');
    }
  });
</script>
