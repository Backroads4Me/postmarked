---
import Layout from '../../../../../../layouts/Layout.astro';
import { apiUrl } from '../../../../../../lib/api.js';
import { cityStateFromAddress } from '../../../../../../lib/location.js';
import CommentsIsland from '../../../../../../components/CommentsIsland.jsx';
import LikesIsland from '../../../../../../components/LikesIsland.jsx';
import MediaGallery from '../../../../../../components/ui/MediaGallery.astro';
import Breadcrumb from '../../../../../../components/ui/Breadcrumb.astro';

const { slug, stop: stopSlug, post_slug } = Astro.params;

let post = null;
let loadError = null;
try {
  const cookie = Astro.request.headers.get('cookie');
  const res = await fetch(apiUrl(`/api/trips/${slug}/stops/${stopSlug}/posts/${post_slug}`), {
    headers: cookie ? { cookie } : {},
  });
  if (res.ok) {
    post = await res.json();
  } else if (res.status === 404) {
    return Astro.redirect('/404');
  } else {
    loadError = `API ${res.status}`;
  }
} catch (e) {
  loadError = e?.message || 'Failed to connect';
}

if (!post) return Astro.redirect('/404');

function fmtActivityTime(d, timezoneId) {
  if (!d) return '';
  const opts = { weekday: 'long', month: 'long', day: 'numeric', hour: 'numeric', minute: '2-digit' };
  if (timezoneId) opts.timeZone = timezoneId;
  return new Date(d).toLocaleString('en-US', opts);
}

function fmtTime(d, timezoneId) {
  if (!d) return '';
  const opts = { hour: 'numeric', minute: '2-digit' };
  if (timezoneId) opts.timeZone = timezoneId;
  return new Date(d).toLocaleTimeString('en-US', opts);
}
---

<Layout title={`${post.title} — ${post.trip_title}`}>
  <main class="frame pt-4 pb-8 md:pt-6 md:pb-12">
    {loadError && <div class="card-flat mb-4 text-sm text-ember" style="max-width: 720px; margin: 0 auto;">{loadError}</div>}

    {/* ── Breadcrumb ───────────────────────────────────────── */}
    <div style="max-width: 720px; margin: 0 auto;">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: cityStateFromAddress(post.stop_address_label) || post.stop_place_name || post.stop_title, href: `/trips/${post.trip_slug}/stops/${post.stop_slug}` },
      ]} />
    </div>

    {/* ── Hero ─────────────────────────────────────────────── */}
    <section class="mb-12" style="max-width: 720px; margin: 0 auto;">
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        {post.activity_type && (
          <span class="badge" style="text-transform: capitalize;">
            {post.activity_type.replace(/_/g, ' ')}
          </span>
        )}
        {post.activity_started_at && (
          <span class="label">{fmtActivityTime(post.activity_started_at, post.stop_timezone_id)}</span>
        )}
        {post.activity_ended_at && (
          <span class="label">– {fmtTime(post.activity_ended_at, post.stop_timezone_id)}</span>
        )}
      </div>
      <h1 class="display text-3xl md:text-5xl">{post.title}</h1>
      {post.summary && (
        <p class="lede mt-4 text-base" style="font-family: var(--sans);">{post.summary}</p>
      )}
    </section>

    {/* ── Gallery ──────────────────────────────────────────── */}
    {post.media && post.media.length > 0 && (
      <section class="mb-16" style="max-width: 720px; margin: 0 auto;">
        <MediaGallery media={post.media} limit={post.media.length} />
      </section>
    )}

    {/* ── Body ─────────────────────────────────────────────── */}
    {post.body && (
      <section class="mt-8 mb-6" style="max-width: 720px; margin-left: auto; margin-right: auto;">
        <p style="font-family: var(--sans); white-space: pre-wrap; line-height: 1.8;">{post.body}</p>
      </section>
    )}

    {/* ── POI Card ─────────────────────────────────────────── */}
    {post.poi && (
      <section class="mb-10" style="max-width: 720px; margin: 0 auto;">
        <div class="card-flat">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="label mb-1" style="text-transform: capitalize;">
                {post.poi.poi_type.replace(/_/g, ' ')}
              </div>
              <h3 class="display text-lg">{post.poi.label}</h3>
            </div>
            {post.poi.google_maps_url && (
              <a
                href={post.poi.google_maps_url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-sm btn-ghost"
                style="white-space: nowrap;"
              >
                Maps ↗
              </a>
            )}
          </div>
        </div>
      </section>
    )}

    {/* ── Likes + Comments ────────────────────────────────── */}
    <section class="mb-6" style="max-width: 720px; margin-left: auto; margin-right: auto;">
      <div class="mb-4">
        <LikesIsland client:load targetKind="post" targetId={post.id} />
      </div>
      <CommentsIsland client:load targetKind="post" targetId={post.id} />
    </section>

    {/* ── Prev / Next Posts ───────────────────────────────── */}
    {(post.prev_post || post.next_post) && (
      <nav class="grid grid-cols-2 gap-3 mt-6 pt-6" style="border-top: 1px solid var(--line-soft); max-width: 720px; margin-left: auto; margin-right: auto;">
        <div>
          {post.prev_post && (
            <a
              href={`/trips/${post.prev_post.trip_slug}/stops/${post.prev_post.stop_slug}/posts/${post.prev_post.slug}`}
              class="card-flat block"
            >
              <div class="post-nav-label label mb-1">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M15 18 9 12l6-6" />
                </svg>
                <span>Previous post</span>
              </div>
              <div style="color: var(--paper);">{post.prev_post.title}</div>
            </a>
          )}
        </div>
        <div style="text-align: right;">
          {post.next_post && (
            <a
              href={`/trips/${post.next_post.trip_slug}/stops/${post.next_post.stop_slug}/posts/${post.next_post.slug}`}
              class="card-flat block"
            >
              <div class="post-nav-label post-nav-label-next label mb-1">
                <span>Next post</span>
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="m9 6 6 6-6 6" />
                </svg>
              </div>
              <div style="color: var(--paper);">{post.next_post.title}</div>
            </a>
          )}
        </div>
      </nav>
    )}
  </main>
</Layout>

<style>
  .post-nav-label {
    align-items: center;
    display: inline-flex;
    gap: 0.35rem;
  }

  .post-nav-label-next {
    justify-content: flex-end;
  }

  .post-nav-label svg {
    fill: none;
    height: 1rem;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.4;
    width: 1rem;
  }
</style>
