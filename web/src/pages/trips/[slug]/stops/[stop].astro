---
import Layout from '../../../../layouts/Layout.astro';
import { apiUrl } from '../../../../lib/api.js';
import { cityStateFromAddress } from '../../../../lib/location.js';
import CommentsIsland from '../../../../components/CommentsIsland.jsx';
import StopMapIsland from '../../../../components/StopMapIsland.jsx';
import MediaGallery from '../../../../components/ui/MediaGallery.astro';
import PostCard from '../../../../components/ui/PostCard.astro';
import Breadcrumb from '../../../../components/ui/Breadcrumb.astro';
import StopIdentity from '../../../../components/ui/StopIdentity.astro';

const { slug, stop } = Astro.params;

let detail = null;
let loadError = null;
try {
  const cookie = Astro.request.headers.get('cookie');
  const res = await fetch(apiUrl(`/api/trips/${slug}/stops/${stop}`), {
    headers: cookie ? { cookie } : {},
  });
  if (res.ok) {
    detail = await res.json();
  } else if (res.status === 404) {
    return Astro.redirect('/404');
  } else {
    loadError = `API ${res.status}`;
  }
} catch (e) {
  loadError = e?.message || 'Failed to connect';
}

if (!detail) {
  return Astro.redirect('/404');
}

const stopMedia = detail.media || [];
const seen = new Set();
const gallery = stopMedia.filter(m => {
  if (seen.has(m.id)) return false;
  seen.add(m.id);
  return true;
});
function fmtDate(d) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function fmtActivityTime(d, timezoneId) {
  if (!d) return '';
  const opts = { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' };
  if (timezoneId) opts.timeZone = timezoneId;
  return new Date(d).toLocaleString('en-US', opts);
}

const activities = (detail.posts || []).filter(p => p.post_type === 'activity');
const updates = (detail.posts || []).filter(p => p.post_type !== 'activity');

function fmtRange(start, end) {
  if (!start) return '';
  if (!end) return fmtDate(start);
  const s = new Date(start);
  const e = new Date(end);
  if (s.getFullYear() === e.getFullYear() && s.getMonth() === e.getMonth()) {
    return `${s.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}–${e.getDate()}, ${e.getFullYear()}`;
  }
  return `${fmtDate(start)} – ${fmtDate(end)}`;
}

function stopSiblingLabel(stop) {
  return cityStateFromAddress(stop?.address_label) || stop?.title || '';
}
---

<Layout title={`${detail.title} — ${detail.trip_title}`}>
  <main class="frame pt-4 pb-8 md:pt-6 md:pb-12">
    {loadError && <div class="card-flat mb-4 text-sm text-ember" style="max-width: 1100px; margin: 0 auto;">{loadError}</div>}

    {/* ── Breadcrumb ───────────────────────────────────────── */}
    <div style="max-width: 1100px; margin: 0 auto;">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: detail.trip_title, href: `/trips/${detail.trip_slug}` },
        { label: cityStateFromAddress(detail.address_label) || detail.place_name || detail.title },
      ]} />
    </div>

    {/* ── Hero ─────────────────────────────────────────────── */}
    <section class="mb-12" style="max-width: 1100px; margin: 0 auto;">
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        {detail.is_current && <span class="badge badge-active text-[10px]">currently here</span>}
        {detail.start_date && <span class="label">{fmtRange(detail.start_date, detail.end_date)}</span>}
        {detail.nights && <span class="label">{detail.nights} night{detail.nights !== 1 ? 's' : ''}</span>}
      </div>
      <StopIdentity stop={detail} as="h1" variant="hero" />
    </section>

    {/* ── Gallery ──────────────────────────────────────────── */}
    {gallery.length > 0 && (
      <section class="mb-16" style="max-width: 1100px; margin: 0 auto;">
        <MediaGallery media={gallery} limit={gallery.length} />
      </section>
    )}

    {/* ── Body ─────────────────────────────────────────────── */}
    {detail.body && (
      <section class="mb-10" style="max-width: 1100px; margin: 0 auto;">
        <p style="font-family: var(--sans); white-space: pre-wrap; line-height: 1.8;">{detail.body}</p>
      </section>
    )}

    {detail.public_note && (
      <section class="mb-10" style="max-width: 1100px; margin: 0 auto;">
        <div class="label mb-3">Note from the road</div>
        <blockquote style="border-left: 2px solid var(--ember); padding-left: 1.25rem; margin: 0; font-family: var(--sans); font-style: italic; color: var(--paper-2); line-height: 1.7;">{detail.public_note}</blockquote>
      </section>
    )}

    {/* ── Map (stop + POIs + photo GPS dots) ──────────────── */}
    {detail.latitude != null && detail.longitude != null && (
      <section class="mb-16" style="max-width: 1100px; margin: 0 auto;">
        <StopMapIsland
          client:load
          latitude={detail.latitude}
          longitude={detail.longitude}
          pois={detail.pois || []}
          mediaGps={detail.media_with_gps || []}
        />
      </section>
    )}

    {/* ── Updates ──────────────────────────────────────────── */}
    {updates.length > 0 && (
      <section style="max-width: 1100px; margin: 0 auto;">
        <div>
          {updates.map(p => (
            <PostCard
              title={p.title}
              posted_at={p.posted_at}
              body={p.body}
              summary={p.summary}
              media={p.media}
              href={`/trips/${detail.trip_slug}/stops/${detail.slug}/posts/${p.slug}`}
              cardClass="post-entry"
            />
          ))}
        </div>
      </section>
    )}

    {/* ── Comments ────────────────────────────────────────── */}
    <section class="my-6" style="max-width: 1100px; margin-left: auto; margin-right: auto;">
      <CommentsIsland client:load targetKind="stop" targetId={detail.id} />
    </section>

    {/* ── Prev / Next ─────────────────────────────────────── */}
    <nav class="grid grid-cols-2 gap-3 mt-12 pt-6 border-t border-line-soft" style="max-width: 1100px; margin: 0 auto;">
      <div>
        {detail.prev && (
          <a href={`/trips/${detail.trip_slug}/stops/${detail.prev.slug}`} class="card-flat block">
            <div class="label mb-1">← Previous</div>
            <div style="color: var(--paper);">{stopSiblingLabel(detail.prev)}</div>
          </a>
        )}
      </div>
      <div style="text-align: right;">
        {detail.next && (
          <a href={`/trips/${detail.trip_slug}/stops/${detail.next.slug}`} class="card-flat block">
            <div class="label mb-1">Next →</div>
            <div style="color: var(--paper);">{stopSiblingLabel(detail.next)}</div>
          </a>
        )}
      </div>
    </nav>
  </main>
</Layout>

<style>
  :global(.post-entry .location-post-title) {
    font-size: 1.1rem;
  }

  :global(.post-entry .location-post-header) {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.post-entry .location-post-header .label) {
    color: var(--muted);
    font-size: 0.72rem;
  }
</style>
