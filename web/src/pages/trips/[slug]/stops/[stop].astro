---
import Layout from '../../../../layouts/Layout.astro';
import { apiUrl } from '../../../../lib/api.js';
import CommentsIsland from '../../../../components/CommentsIsland.jsx';
import StopMapIsland from '../../../../components/StopMapIsland.jsx';
import MediaGallery from '../../../../components/ui/MediaGallery.astro';

const { slug, stop } = Astro.params;

let detail = null;
let loadError = null;
try {
  const res = await fetch(apiUrl(`/api/trips/${slug}/stops/${stop}`));
  if (res.ok) {
    detail = await res.json();
  } else if (res.status === 404) {
    return Astro.redirect('/404');
  } else {
    loadError = `API ${res.status}`;
  }
} catch (e) {
  loadError = e?.message || 'Failed to connect';
}

if (!detail) {
  return Astro.redirect('/404');
}

const allMedia = [
  ...(detail.media || []),
  ...((detail.posts || []).flatMap(p => p.media || [])),
];
// dedupe by id
const seen = new Set();
const gallery = allMedia.filter(m => {
  if (seen.has(m.id)) return false;
  seen.add(m.id);
  return true;
});
function fmtDate(d) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function fmtActivityTime(d, timezoneId) {
  if (!d) return '';
  const opts = { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' };
  if (timezoneId) opts.timeZone = timezoneId;
  return new Date(d).toLocaleString('en-US', opts);
}

const activities = (detail.posts || []).filter(p => p.post_type === 'activity');
const updates = (detail.posts || []).filter(p => p.post_type !== 'activity');

function fmtRange(start, end) {
  if (!start) return '';
  if (!end) return fmtDate(start);
  const s = new Date(start);
  const e = new Date(end);
  if (s.getFullYear() === e.getFullYear() && s.getMonth() === e.getMonth()) {
    return `${s.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}–${e.getDate()}, ${e.getFullYear()}`;
  }
  return `${fmtDate(start)} – ${fmtDate(end)}`;
}
---

<Layout title={`${detail.title} — ${detail.trip_title}`}>
  <main class="frame py-8 md:py-12">
    {loadError && <div class="card-flat mb-4 text-sm text-ember">{loadError}</div>}

    {/* ── Breadcrumb ───────────────────────────────────────── */}
    <nav class="label mb-3">
      <a href="/trips">Trips</a>
      <span style="margin: 0 6px;">/</span>
      <a href={`/trips/${detail.trip_slug}`}>{detail.trip_title}</a>
    </nav>

    {/* ── Hero ─────────────────────────────────────────────── */}
    <section class="mb-8">
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        {detail.is_current && <span class="badge badge-active text-[10px]">currently here</span>}
        {detail.stop_type && <span class="badge text-[10px]">{detail.stop_type}</span>}
        {detail.start_date && <span class="label">{fmtRange(detail.start_date, detail.end_date)}</span>}
        {detail.nights && <span class="label">{detail.nights} night{detail.nights !== 1 ? 's' : ''}</span>}
      </div>
      <h1 class="display text-3xl md:text-5xl">{detail.title}</h1>
      {detail.place_name && <p class="coord mt-2">{detail.place_name}</p>}
      {detail.summary && (
        <p class="lede mt-4 text-base" style="font-family: var(--sans);">{detail.summary}</p>
      )}
    </section>

    {/* ── Gallery ──────────────────────────────────────────── */}
    {gallery.length > 0 && (
      <section class="mb-10">
        <MediaGallery media={gallery} limit={10} />
      </section>
    )}

    {/* ── Body ─────────────────────────────────────────────── */}
    {detail.body && (
      <section class="mb-10">
        <p style="font-family: var(--sans); white-space: pre-wrap; line-height: 1.7;">{detail.body}</p>
      </section>
    )}

    {detail.public_note && (
      <section class="mb-10">
        <div class="card-flat">
          <div class="label mb-2">Note from the road</div>
          <p style="font-family: var(--sans); white-space: pre-wrap;">"{detail.public_note}"</p>
        </div>
      </section>
    )}

    {/* ── Activities ───────────────────────────────────────── */}
    {activities.length > 0 && (
      <section class="mb-10">
        <h2 class="display text-2xl mb-3">Activities</h2>
        <div class="grid gap-3">
          {activities.map(p => (
            <article class="card-flat">
              <div class="flex items-start justify-between mb-2 gap-3">
                <div>
                  <a href={`/trips/${detail.trip_slug}/stops/${detail.slug}/posts/${p.slug}`}
                     class="text-base font-medium hover:text-ember transition-colors"
                     style="color: var(--paper); text-decoration: none;">
                    {p.title}
                  </a>
                  {p.activity_started_at && (
                    <span class="label block mt-0.5">{fmtActivityTime(p.activity_started_at, detail.timezone_id)}</span>
                  )}
                </div>
                {p.activity_type && (
                  <span class="badge" style="white-space: nowrap; text-transform: capitalize;">{p.activity_type.replace(/_/g, ' ')}</span>
                )}
              </div>
              {p.summary && <p class="text-sm mb-2" style="color: var(--paper-muted);">{p.summary}</p>}
              {p.body && <p class="text-muted text-sm" style="white-space: pre-wrap;">{p.body}</p>}
              {p.poi && (
                <div class="mt-3 pt-3" style="border-top: 1px solid var(--line-soft);">
                  <div class="label mb-1">{p.poi.label}</div>
                  {p.poi.google_maps_url && (
                    <a href={p.poi.google_maps_url} target="_blank" rel="noopener noreferrer"
                       class="text-xs" style="color: var(--ember); text-decoration: none;">
                      Open in Maps ↗
                    </a>
                  )}
                </div>
              )}
              {p.media && p.media.length > 0 && (
                <div class="mt-3 flex gap-2 overflow-x-auto">
                  {p.media.slice(0, 4).map(m => (
                    <img src={`/media/${m.id}/webp`} alt={m.alt_text || ''} loading="lazy"
                         class="rounded" style="height: 72px; width: 72px; object-fit: cover; flex-shrink: 0;" />
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {/* ── Updates ──────────────────────────────────────────── */}
    {updates.length > 0 && (
      <section class="mb-10">
        <h2 class="display text-2xl mb-3">Updates from here</h2>
        <div class="grid gap-3">
          {updates.map(p => (
            <article class="card-flat">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-base font-medium" style="color: var(--paper);">{p.title}</h3>
                <span class="label">{fmtDate(p.posted_at)}</span>
              </div>
              {p.body && <p class="text-muted text-sm" style="white-space: pre-wrap;">{p.body}</p>}
              {p.media && p.media.length > 0 && (
                <div class="mt-3 flex gap-2 overflow-x-auto">
                  {p.media.slice(0, 4).map(m => (
                    <a href={`/media/${m.id}/webp`} target="_blank" rel="noopener noreferrer"
                       class="rounded block overflow-hidden bg-line-soft"
                       style="height: 88px; width: 88px; flex-shrink: 0;">
                      <img src={`/media/${m.id}/webp`} alt={m.alt_text || m.caption || ''} loading="lazy"
                           class="w-full h-full object-cover" />
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {/* ── Map (stop + POIs + photo GPS dots) ──────────────── */}
    {detail.latitude != null && detail.longitude != null && (
      <section class="mb-10">
        <StopMapIsland
          client:load
          latitude={detail.latitude}
          longitude={detail.longitude}
          pois={detail.pois || []}
          mediaGps={detail.media_with_gps || []}
        />
        <p class="coord mt-2" style="font-size: 11px;">
          {detail.latitude.toFixed(4)}, {detail.longitude.toFixed(4)}
        </p>
      </section>
    )}

    {/* ── Comments ────────────────────────────────────────── */}
    <section class="mb-10">
      <CommentsIsland client:load targetKind="stop" targetId={detail.id} />
    </section>

    {/* ── Prev / Next ─────────────────────────────────────── */}
    <nav class="grid grid-cols-2 gap-3 mt-12 pt-6 border-t border-line-soft">
      <div>
        {detail.prev && (
          <a href={`/trips/${detail.trip_slug}/stops/${detail.prev.slug}`} class="card-flat block">
            <div class="label mb-1">← Previous</div>
            <div style="color: var(--paper);">{detail.prev.title}</div>
          </a>
        )}
      </div>
      <div style="text-align: right;">
        {detail.next && (
          <a href={`/trips/${detail.trip_slug}/stops/${detail.next.slug}`} class="card-flat block">
            <div class="label mb-1">Next →</div>
            <div style="color: var(--paper);">{detail.next.title}</div>
          </a>
        )}
      </div>
    </nav>
  </main>
</Layout>
