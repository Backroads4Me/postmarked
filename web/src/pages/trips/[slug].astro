---
import Layout from '../../layouts/Layout.astro';
import { apiUrl } from '../../lib/api.js';
import MapIsland from '../../components/MapIsland.jsx';

const { slug } = Astro.params;

let trip = null;
let loadError = null;
try {
  const cookie = Astro.request.headers.get('cookie');
  const res = await fetch(apiUrl(`/api/trip-segments/${slug}`), {
    headers: cookie ? { cookie } : {},
  });
  if (res.ok) {
    trip = await res.json();
  } else if (res.status === 404) {
    return Astro.redirect('/404');
  } else {
    loadError = `API ${res.status}`;
  }
} catch (e) {
  loadError = e?.message || 'Failed to connect';
}

if (!trip) {
  return Astro.redirect('/404');
}

const stops = trip.stops || [];
const posts = trip.posts || [];

const stopsWithCoords = stops.filter(s => s.latitude != null && s.longitude != null);
const photoCount = posts.reduce((n, p) => n + (p.media?.length || 0), 0);
const milesTotal = stops.reduce((n, s) => n + (s.miles_from_previous || 0), 0);

function fmtDate(d) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function fmtRange(start, end) {
  if (!start) return '';
  if (!end) return fmtDate(start);
  const s = new Date(start);
  const e = new Date(end);
  if (s.getFullYear() === e.getFullYear() && s.getMonth() === e.getMonth()) {
    return `${s.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}–${e.getDate()}, ${e.getFullYear()}`;
  }
  return `${fmtDate(start)} – ${fmtDate(end)}`;
}

---

<Layout title={`${trip.title} — Postmarked`}>
  <main class="frame py-8 md:py-12">
    {loadError && <div class="card-flat mb-4 text-sm text-ember">{loadError}</div>}

    {/* ── Hero ─────────────────────────────────────────────── */}
    <section class="mb-8">
      <a href="/trips" class="label">← All trips</a>

      <div class="flex items-baseline justify-between gap-4 mt-3 mb-3">
        <h1 class="display text-3xl md:text-4xl leading-tight">{trip.title}</h1>
        {trip.start_date && (
          <span class="shrink-0 display text-3xl md:text-4xl text-muted">{fmtRange(trip.start_date, trip.end_date)}</span>
        )}
      </div>

      {trip.cover_media?.derivative_paths?.webp && (
        <div class="relative rounded-xl overflow-hidden border border-line-soft bg-surface-2" style="height: clamp(12rem, 45vh, 26rem);">
          <img
            src={`/media/${trip.cover_media.id}/webp`}
            alt={trip.cover_media.alt_text || ''}
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
          />
        </div>
      )}

      {trip.summary && (
        <p class="lede mt-3 text-base" style="font-family: var(--sans);">{trip.summary}</p>
      )}

      {stopsWithCoords.length > 0 && (
        <section class="mt-6" id="trip-map" style="height: 360px; border: 1px solid var(--line); border-radius: 8px; overflow: hidden;">
          <MapIsland client:load stops={stopsWithCoords} />
        </section>
      )}

      <div class="flex gap-6 md:gap-10 mt-6 flex-wrap">
        <div>
          <div class="label">Stops</div>
          <div class="display text-xl">{trip.stops_completed} / {trip.stops_total}</div>
        </div>
        <div>
          <div class="label">Photos</div>
          <div class="display text-xl">{photoCount}</div>
        </div>
        {milesTotal > 0 && (
          <div>
            <div class="label">Miles</div>
            <div class="display text-xl">{Math.round(milesTotal)}</div>
          </div>
        )}
      </div>
    </section>

    {/* ── Body ─────────────────────────────────────────────── */}
    {trip.body && (
      <section class="mb-10 prose-trip">
        <p style="font-family: var(--sans); white-space: pre-wrap; line-height: 1.7;">{trip.body}</p>
      </section>
    )}

    {/* ── Stop list ────────────────────────────────────────── */}
    <section class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="display text-2xl">The Route</h2>
        </div>
      </div>

      {stops.length > 0 ? (
        <ol style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
          {stops.map((stop, idx) => (
            <li>
              <a
                href={`/trips/${trip.slug}/stops/${stop.slug}`}
                class="card group block"
                style="text-decoration: none;"
              >
                <div class="flex items-start gap-4">
                  <div
                    style={`flex: 0 0 32px; height: 32px; border-radius: 50%; background: ${stop.is_current ? 'var(--ember-glow)' : 'var(--surface-2)'}; color: ${stop.is_current ? 'var(--ember)' : 'var(--muted)'}; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 12px; font-weight: 600;`}
                  >
                    {idx + 1}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                      {stop.start_date && <span class="label">{fmtRange(stop.start_date, stop.end_date)}</span>}
                      {stop.nights && <span class="label">{stop.nights} night{stop.nights !== 1 ? 's' : ''}</span>}
                      {stop.is_current && <span class="badge badge-active text-[10px]">currently here</span>}
                    </div>
                    <h3 class="display text-xl group-hover:text-ember-2 transition-colors">{stop.title}</h3>
                    {stop.summary && <p class="text-muted text-sm mt-2 line-clamp-2">{stop.summary}</p>}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <div class="card-flat text-sm text-muted">No stops yet on this trip.</div>
      )}
    </section>
  </main>
</Layout>
