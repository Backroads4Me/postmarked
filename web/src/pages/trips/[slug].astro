---
import Layout from '../../layouts/Layout.astro';
import { apiUrl } from '../../lib/api.js';
import { formatDateRange } from '../../lib/dates.js';
import MapIsland from '../../components/MapIsland.jsx';
import StopIdentity from '../../components/ui/StopIdentity.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';

const { slug } = Astro.params;

let trip = null;
let loadError = null;
try {
  const cookie = Astro.request.headers.get('cookie');
  const res = await fetch(apiUrl(`/api/trip-segments/${slug}`), {
    headers: cookie ? { cookie } : {},
  });
  if (res.ok) {
    trip = await res.json();
  } else if (res.status === 404) {
    return Astro.redirect('/404');
  } else {
    loadError = `API ${res.status}`;
  }
} catch (e) {
  loadError = e?.message || 'Failed to connect';
}

if (!trip) {
  return Astro.redirect('/404');
}

const stops = trip.stops || [];
const posts = trip.posts || [];

// Identify current stop by date range (mirrors home page API logic)
const todayMs = Date.now();
function containsToday(stop) {
  if (!stop.start_date) return false;
  const start = new Date(stop.start_date).setHours(0, 0, 0, 0);
  const end = stop.end_date ? new Date(stop.end_date).setHours(23, 59, 59, 999) : Infinity;
  return start <= todayMs && todayMs <= end;
}
const todayStops = stops.filter(containsToday);
const currentStopId = todayStops.length === 1
  ? todayStops[0].id
  : todayStops.length > 1
    ? todayStops.reduce((a, b) => new Date(a.start_date) >= new Date(b.start_date) ? a : b).id
    : null;

const tripDescription = trip.summary || trip.description || `${stops.length} stops and ${posts.length} updates from ${trip.title}.`;
const tripOgImage = trip.cover_media?.id ? `/media/${trip.cover_media.id}/webp` : undefined;

const stopsWithCoords = stops
  .filter(s => s.latitude != null && s.longitude != null)
  .map(s => ({ ...s, is_current: s.is_current || String(s.id) === String(currentStopId) }));

const photoCount = posts.reduce((n, p) => n + (p.media?.length || 0), 0);
const milesTotal = stops.reduce((n, s) => n + (s.miles_from_previous || 0), 0);

// Build stop-id → media map from posts so stop cards can show thumbnails
const stopMediaMap = new Map<string, any[]>();
for (const post of posts) {
  if (!post.stop?.id) continue;
  const key = String(post.stop.id);
  if (!stopMediaMap.has(key)) stopMediaMap.set(key, []);
  for (const m of (post.media || [])) {
    stopMediaMap.get(key)!.push(m);
  }
}

function stopThumbs(stop: any, limit = 5) {
  return (stopMediaMap.get(String(stop.id)) || []).slice(0, limit);
}

function thumbSrc(m: any) {
  return m.kind === 'video' ? `/media/${m.id}/poster` : `/media/${m.id}/webp`;
}

function fmtRange(start, end) {
  return formatDateRange(start, end);
}

const hasMapKey = Boolean(
  (typeof process !== "undefined" && process.env.PUBLIC_GOOGLE_MAPS_API_KEY) ||
  import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY
);

---

<Layout title={`${trip.title} — Postmarked`} description={tripDescription} canonicalPath={`/trips/${trip.slug}`} ogImage={tripOgImage} ogType="article">
  <main class="frame pt-4 pb-8 md:pt-6 md:pb-12">
    {loadError && <div class="card-flat mb-4 text-sm text-ember">{loadError}</div>}

    {/* ── Hero ─────────────────────────────────────────────── */}
    <section class="mb-8">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Trips', href: '/trips' }]} />

      <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 md:gap-4 mt-3 mb-3">
        <h1 class="display text-3xl md:text-4xl leading-tight">{trip.title}</h1>
        {trip.start_date && (
          <span class="shrink-0 display text-sm md:text-4xl text-muted">{fmtRange(trip.start_date, trip.end_date)}</span>
        )}
      </div>

      {trip.cover_media?.derivative_paths?.webp && (
        <div class="trip-detail-cover relative rounded-xl overflow-hidden border border-line-soft bg-surface-2">
          <img
            src={`/media/${trip.cover_media.id}/webp`}
            alt={trip.cover_media.alt_text || ''}
            class="trip-detail-cover-img w-full h-auto"
            loading="eager"
          />
        </div>
      )}

      {trip.summary && (
        <p class="lede lede-body mt-3 text-base">{trip.summary}</p>
      )}

      {hasMapKey && stopsWithCoords.length > 0 && (
        <section class="mt-6" id="trip-map" style="height: 360px; border: 1px solid var(--line); border-radius: 8px; overflow: hidden;">
          <MapIsland client:load stops={stopsWithCoords} />
        </section>
      )}

      <div class="flex gap-6 md:gap-10 mt-6 flex-wrap">
        <div>
          <div class="label">Stops</div>
          <div class="display text-xl">{trip.stops_completed} / {trip.stops_total}</div>
        </div>
        <div>
          <div class="label">Photos</div>
          <div class="display text-xl">{photoCount}</div>
        </div>
        {milesTotal > 0 && (
          <div>
            <div class="label">Miles</div>
            <div class="display text-xl">{Math.round(milesTotal)}</div>
          </div>
        )}
      </div>
    </section>

    {/* ── Body ─────────────────────────────────────────────── */}
    {trip.body && (
      <section class="mb-10 prose-trip">
        <p class="prose-body">{trip.body}</p>
      </section>
    )}

    {/* ── Stop list ────────────────────────────────────────── */}
    <section class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="display text-2xl">The Route</h2>
        </div>
      </div>

      {stops.length > 0 ? (
        <ol style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
          {stops.map((stop, idx) => (
            <li>
              <a
                href={`/trips/${trip.slug}/stops/${stop.slug}`}
                class="card group block"
                style="text-decoration: none;"
              >
                <div class="flex items-start gap-4">
                  <div
                    style={`flex: 0 0 32px; height: 32px; border-radius: 50%; background: var(--ember-glow); color: var(--ember); display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 12px; font-weight: 600;`}
                  >
                    {idx + 1}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                      {stop.start_date && <span class="label stop-meta">{fmtRange(stop.start_date, stop.end_date)}</span>}
                      {stop.nights && <span class="label stop-meta">{stop.nights} night{stop.nights !== 1 ? 's' : ''}</span>}
                      {stop.is_current && <span class="badge badge-active badge-sm">currently here</span>}
                    </div>
                    <StopIdentity stop={stop} heading />
                  </div>
                  {(() => {
                    const thumbs = stopThumbs(stop);
                    return thumbs.length > 0 ? (
                      <div class="flex gap-1.5 shrink-0 self-center">
                        {thumbs.map((m: any, i: number) => (
                          <img
                            src={thumbSrc(m)}
                            alt={m.alt_text || m.caption || ''}
                            width="48"
                            height="48"
                            loading="lazy"
                            decoding="async"
                            class={i >= 2 ? 'hidden sm:block' : ''}
                            style="width:48px;height:48px;object-fit:cover;border-radius:5px;flex-shrink:0;"
                          />
                        ))}
                      </div>
                    ) : null;
                  })()}
                </div>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <div class="card-flat text-sm text-muted">No stops yet on this trip.</div>
      )}
    </section>
  </main>
<style>
  @media (min-width: 768px) {
    .trip-detail-cover {
      height: clamp(12rem, 45vh, 26rem);
    }
    .trip-detail-cover-img {
      position: absolute;
      inset: 0;
      height: 100%;
      object-fit: cover;
    }
  }

  .stop-meta {
    transition: color 160ms ease;
  }

  .group:hover .stop-meta {
    color: var(--ember-2);
  }

  .group:hover :global(.stop-identity-primary),
  .group:hover :global(.stop-identity-detail) {
    color: var(--ember-2);
  }
</style>

</Layout>
