---
import Layout from '../../layouts/Layout.astro';
import EmptyState from '../../components/ui/EmptyState.astro';
import { apiUrl } from '../../lib/api.js';
import { formatDate, formatDateRange } from '../../lib/dates.js';
import { loadSiteText, sectionText } from '../../lib/siteText.js';

let trips = [];
try {
  const cookie = Astro.request.headers.get('cookie');
  const res = await fetch(apiUrl('/api/trip-segments'), {
    headers: cookie ? { cookie } : {},
  });
  if (res.ok) trips = await res.json();
} catch (e) {
  console.error(e);
}

function tripDateRange(trip) {
  if (trip.start_date || trip.end_date) {
    return formatDateRange(trip.start_date, trip.end_date);
  }
  const datedStops = (trip.stops || []).filter((s) => s.start_date || s.end_date);
  if (datedStops.length === 0) return '';
  const start = datedStops
    .map((s) => s.start_date || s.end_date)
    .sort((a, b) => new Date(a) - new Date(b))[0];
  const end = datedStops
    .map((s) => s.end_date || s.start_date)
    .sort((a, b) => new Date(b) - new Date(a))[0];
  return formatDateRange(start, end);
}

function coverSrc(trip) {
  const cover = trip.cover_media;
  if (cover?.processing_state !== 'ready' || !cover?.derivative_paths?.webp) return null;
  return `/media/${cover.id}/webp`;
}

const siteText = await loadSiteText();
const headerText = sectionText(siteText, 'trips.header', {
  heading: 'All Trips',
  body: 'Miles become memories.',
});
---

<Layout title="Trips — Postmarked">
  <main class="frame pt-4 pb-8 md:pt-6 md:pb-12">
    <section class="mb-8">
      <h1 class="display text-3xl md:text-4xl">{headerText.heading}</h1>
      {headerText.body && (
        <p class="lede lede-body mt-3 text-sm">
          {headerText.body}
        </p>
      )}
    </section>

    {trips.length > 0 ? (
      <div class="grid grid-cols-1 gap-6">
        {trips.map(trip => (
          <a href={`/trips/${trip.slug}`} class="card group" id={`trip-${trip.slug}`}>
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 md:gap-3 mb-3">
              <h2 class="display text-2xl group-hover:text-ember-2 transition-colors leading-tight">{trip.title}</h2>
              {tripDateRange(trip) && (
                <span class="shrink-0 display text-sm md:text-2xl text-muted">{tripDateRange(trip)}</span>
              )}
            </div>
            <div class="trip-cover-container relative bg-surface-2 rounded-lg overflow-hidden border border-line-soft">
              <img
                src={coverSrc(trip)}
                alt={trip.cover_media?.alt_text || ''}
                class="trip-cover-img w-full h-auto transition-transform duration-300 group-hover:scale-[1.03]"
                loading="lazy"
              />
              {trip.stops_total > 0 && (
                <div class="absolute bottom-2 right-2">
                  <span class="badge badge-sm">{trip.stops_completed}/{trip.stops_total} stops</span>
                </div>
              )}
            </div>
            {trip.summary && (
              <p class="text-sm text-muted mt-3 line-clamp-2">{trip.summary}</p>
            )}
          </a>
        ))}
      </div>
    ) : (
      <EmptyState
        icon="🚐"
        title="No trips yet"
      />
    )}
  </main>
</Layout>

<style>
  @media (min-width: 768px) {
    .trip-cover-container {
      height: clamp(12rem, 40vh, 22rem);
    }
    .trip-cover-img {
      position: absolute;
      inset: 0;
      height: 100%;
      object-fit: cover;
    }
  }
</style>
