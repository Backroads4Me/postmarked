---
import Layout from '../../layouts/Layout.astro';
import EmptyState from '../../components/ui/EmptyState.astro';
import { apiUrl } from '../../lib/api.js';
import { loadSiteText, sectionText } from '../../lib/siteText.js';

let trips = [];
try {
  const cookie = Astro.request.headers.get('cookie');
  const res = await fetch(apiUrl('/api/trip-segments'), {
    headers: cookie ? { cookie } : {},
  });
  if (res.ok) trips = await res.json();
} catch (e) {
  console.error(e);
}

function formatDate(dateStr) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function formatRange(start, end) {
  if (!start) return '';
  if (!end) return formatDate(start);
  const s = new Date(start);
  const e = new Date(end);
  if (s.getFullYear() === e.getFullYear() && s.getMonth() === e.getMonth()) {
    return `${s.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}–${e.getDate()}, ${e.getFullYear()}`;
  }
  return `${formatDate(start)} – ${formatDate(end)}`;
}

function tripDateRange(trip) {
  if (trip.start_date || trip.end_date) {
    return formatRange(trip.start_date, trip.end_date);
  }
  const datedStops = (trip.stops || []).filter((s) => s.start_date || s.end_date);
  if (datedStops.length === 0) return '';
  const start = datedStops
    .map((s) => s.start_date || s.end_date)
    .sort((a, b) => new Date(a) - new Date(b))[0];
  const end = datedStops
    .map((s) => s.end_date || s.start_date)
    .sort((a, b) => new Date(b) - new Date(a))[0];
  return formatRange(start, end);
}

function coverSrc(trip) {
  const cover = trip.cover_media;
  if (cover?.processing_state !== 'ready' || !cover?.derivative_paths?.webp) return null;
  return `/media/${cover.id}/webp`;
}

const siteText = await loadSiteText();
const headerText = sectionText(siteText, 'trips.header', {
  label: 'Journeys',
  heading: 'All Trips',
  body: 'Miles become memories.',
});
---

<Layout title="Trips — Postmarked">
  <main class="frame py-8 md:py-12">
    <section class="mb-8">
      {headerText.label && <div class="label mb-2">{headerText.label}</div>}
      <h1 class="display text-3xl md:text-4xl">{headerText.heading}</h1>
      {headerText.body && (
        <p class="lede mt-3 text-sm" style="font-family: var(--sans);">
          {headerText.body}
        </p>
      )}
    </section>

    {trips.length > 0 ? (
      <div class="grid grid-cols-1 gap-6">
        {trips.map(trip => (
          <a href={`/trips/${trip.slug}`} class="card group" id={`trip-${trip.slug}`}>
            {coverSrc(trip) && (
              <div class="aspect-video bg-surface-2 rounded-lg mb-4 overflow-hidden border border-line-soft relative">
                <img
                  src={coverSrc(trip)}
                  alt={trip.cover_media.alt_text || ''}
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                  loading="lazy"
                />
                {trip.stops_total > 0 && (
                  <div class="absolute bottom-2 right-2">
                    <span class="badge text-[9px]">{trip.stops_completed}/{trip.stops_total} stops</span>
                  </div>
                )}
              </div>
            )}
            <div>
              <div class="flex items-center justify-between gap-2 mb-2">
                <div>
                  {tripDateRange(trip) && (
                    <span class="label">{tripDateRange(trip)}</span>
                  )}
                </div>
                {!coverSrc(trip) && trip.stops_total > 0 && (
                  <span class="badge text-[9px]">{trip.stops_completed}/{trip.stops_total} stops</span>
                )}
              </div>
              <h2 class="display text-2xl group-hover:text-ember-2 transition-colors">{trip.title}</h2>
              {trip.summary && (
                <p class="text-sm text-muted mt-2 line-clamp-2">{trip.summary}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <EmptyState
        icon="🚐"
        title="No trips yet"
      />
    )}
  </main>
</Layout>
