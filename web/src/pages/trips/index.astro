---
import Layout from '../../layouts/Layout.astro';
import EmptyState from '../../components/ui/EmptyState.astro';
import { apiUrl } from '../../lib/api.js';
import { loadSiteText, sectionText } from '../../lib/siteText.js';

let trips = [];
try {
  const res = await fetch(apiUrl('/api/trip-segments'));
  if (res.ok) trips = await res.json();
} catch (e) {
  console.error(e);
}

function formatDate(dateStr) {
  if (!dateStr) return 'TBD';
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function coverSrc(trip) {
  const cover = trip.cover_media;
  if (cover?.processing_state !== 'ready' || !cover?.derivative_paths?.webp) return null;
  return `/media/${cover.id}/webp`;
}

const siteText = await loadSiteText();
const headerText = sectionText(siteText, 'trips.header', {
  label: 'Journeys',
  heading: 'All Trips',
  body: 'Each trip is a chapter in our RV story — from coast to coast.',
});
---

<Layout title="Trips — Goodpath">
  <main class="frame py-8 md:py-12">
    <section class="mb-8">
      {headerText.label && <div class="label mb-2">{headerText.label}</div>}
      <h1 class="display text-3xl md:text-4xl">{headerText.heading}</h1>
      {headerText.body && (
        <p class="lede mt-3 text-sm" style="font-family: var(--sans);">
          {headerText.body}
        </p>
      )}
    </section>

    {trips.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {trips.map(trip => (
          <a href={`/trips/${trip.slug}`} class="card group" id={`trip-${trip.slug}`}>
            <div class="aspect-video bg-surface-2 rounded-lg mb-4 overflow-hidden border border-line-soft relative">
              {coverSrc(trip) ? (
                <img
                  src={coverSrc(trip)}
                  alt={trip.cover_media.alt_text || ''}
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="text-4xl opacity-30">🗺️</span>
                </div>
              )}
              {trip.stops_total > 0 && (
                <div class="absolute bottom-2 right-2">
                  <span class="badge text-[9px]">{trip.stops_completed}/{trip.stops_total} stops</span>
                </div>
              )}
            </div>
            <div>
              <div class="flex items-center gap-2 mb-2">
                <span class="label">{formatDate(trip.start_date)}</span>
              </div>
              <h2 class="display text-2xl group-hover:text-ember-2 transition-colors">{trip.title}</h2>
              {trip.summary && (
                <p class="text-sm text-muted mt-2 line-clamp-2">{trip.summary}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <EmptyState
        icon="🚐"
        title="No trips yet"
        message="Import a trip from RV Trip Wizard or create one manually."
      />
    )}
  </main>
</Layout>
