---
import Layout from '../layouts/Layout.astro';
import LocationUpdateGroup from '../components/ui/LocationUpdateGroup.astro';
import EmptyState from '../components/ui/EmptyState.astro';
import { apiUrl } from '../lib/api.js';
import { loadSiteText, sectionText } from '../lib/siteText.js';

let timelineData = null;
let error = null;
const showUpcoming = Astro.url.searchParams.get('upcoming') === '1';
try {
  const params = new URLSearchParams({ limit: '50' });
  if (showUpcoming) params.set('include_future_stops', 'true');
  const res = await fetch(apiUrl(`/api/timeline?${params.toString()}`));
  if (res.ok) {
    timelineData = await res.json();
  } else {
    error = `API returned ${res.status}`;
  }
} catch (e) {
  error = e?.message || 'Failed to connect';
}

const updates = (timelineData?.updates ?? []).toSorted((a, b) => {
  return new Date(b.posted_at).getTime() - new Date(a.posted_at).getTime();
});

function stopKeyForItem(item) {
  return String(item.stop_id || item.id);
}

function stopFromItem(item) {
  return {
    id: item.stop_id || item.id,
    title: item.stop_title || item.title,
    slug: item.stop_slug || item.slug,
    trip_slug: item.trip_slug,
    trip_title: item.trip_title,
    summary: item.kind === 'stop' ? item.summary : null,
    posted_at: item.kind === 'stop' ? item.posted_at : item.posted_at,
    start_date: item.kind === 'stop' ? item.posted_at : item.posted_at,
    place_name: item.place_name,
    cover_media: item.cover_media,
  };
}

function groupByMonth(items) {
  const groups = {};
  for (const item of items) {
    const d = new Date(item.posted_at);
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
    const label = d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
    if (!groups[key]) {
      groups[key] = { label, locations: new Map() };
    }
    const locationKey = stopKeyForItem(item);
    if (!groups[key].locations.has(locationKey)) {
      groups[key].locations.set(locationKey, {
        stop: stopFromItem(item),
        posts: [],
        sortDate: new Date(item.posted_at || 0).getTime(),
      });
    }
    const location = groups[key].locations.get(locationKey);
    if (item.kind === 'stop') {
      location.stop = { ...location.stop, ...stopFromItem(item) };
    } else {
      location.posts.push(item);
    }
    location.sortDate = Math.max(location.sortDate, new Date(item.posted_at || 0).getTime());
  }
  return Object.values(groups)
    .map((group) => ({
      label: group.label,
      locations: Array.from(group.locations.values()).sort((a, b) => b.sortDate - a.sortDate),
      count: Array.from(group.locations.values()).reduce((sum, location) => sum + 1 + location.posts.length, 0),
    }))
    .toSorted((a, b) => (b.locations[0]?.sortDate || 0) - (a.locations[0]?.sortDate || 0));
}

const grouped = groupByMonth(updates);
const tripTitles = Array.from(new Set(updates.map((item) => item.trip_title).filter(Boolean)));
const tripContext = tripTitles.length === 1 ? tripTitles[0] : tripTitles.length > 1 ? 'Multiple trips' : null;
const siteText = await loadSiteText();
const headerText = sectionText(siteText, 'timeline.header', {
  heading: 'Timeline',
  body: 'Every stop, story, and moment.',
});
---

<Layout title="Timeline — Postmarked">
  <main class="frame pt-4 pb-8 md:pt-6 md:pb-12">
    <section class="mb-8">
      <div class="flex items-start justify-between gap-4">
        <div class="flex items-baseline gap-3 min-w-0">
          <h1 class="display text-3xl md:text-4xl">{headerText.heading}</h1>
          {tripContext && (
            <>
              <span class="display text-3xl md:text-4xl text-muted" aria-hidden="true">—</span>
              <span class="display text-3xl md:text-4xl text-muted truncate">{tripContext}</span>
            </>
          )}
        </div>
        <a
          href={showUpcoming ? '/timeline' : '/timeline?upcoming=1'}
          class={`btn btn-sm shrink-0 ${showUpcoming ? 'btn-primary' : 'btn-ghost-ember'}`}
          aria-pressed={showUpcoming ? 'true' : 'false'}
        >
          {showUpcoming ? 'Hide upcoming stops' : 'Show upcoming stops'}
        </a>
      </div>
      {headerText.body && (
        <p class="lede mt-3 text-sm" style="font-family: var(--sans);">
          {headerText.body}
        </p>
      )}
      {error && (
        <div class="mt-4 card-flat text-sm text-ember">
          Couldn't load the timeline ({error}).
        </div>
      )}
    </section>

    {grouped.length > 0 ? (
      <div class="space-y-8">
        {grouped.map(group => (
          <section>
            <div class="flex items-center gap-3 mb-4 sticky top-14 z-10 py-2" style="background: var(--bg);">
              <div class="w-2 h-2 rounded-full bg-ember"></div>
              <h2 class="eyebrow text-ember">{group.label}</h2>
              <div class="flex-1 h-px bg-line-soft"></div>
              <span class="label">{group.count} items</span>
            </div>

            <div class="grid gap-4 pl-4 border-l border-line-soft ml-1">
              {group.locations.map(location => (
                <LocationUpdateGroup stop={location.stop} posts={location.posts} />
              ))}
            </div>
          </section>
        ))}
      </div>
    ) : (
      <EmptyState
        icon="📅"
        title="Nothing here yet"
        message="Check back soon for travel stories and photos."
      />
    )}
  </main>
</Layout>
