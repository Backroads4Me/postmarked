---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not Found">
  <div class="frame min-h-[70vh] flex flex-col items-center justify-center text-center">
    <div class="label mb-4">404</div>
    <h1 class="display text-6xl mb-4">Lost the trail</h1>
    <p class="text-muted text-lg max-w-sm mb-8">The page you're looking for doesn't exist or is currently private.</p>
    <a href="/" class="btn">Return to the campground</a>
  </div>
</Layout>
