---
import '../styles/global.css';
import NavBar from '../components/ui/NavBar.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  hideNav?: boolean;
}

const {
  title = "Postmarked",
  description = "A travel journal for the road. Quick updates, photos, and notes — like sending a postcard from everywhere you go.",
  canonicalPath = Astro.url.pathname,
  ogImage,
  ogImageAlt = "Postmarked logo",
  ogType = "website",
  hideNav = false,
} = Astro.props;
const baseUrl =
  (typeof process !== "undefined" && process.env.APP_BASE_URL) ||
  Astro.url.origin;
const canonicalUrl = new URL(canonicalPath, baseUrl).toString();
// Fall back to the app icon so shared links show our mark instead of a
// random photo scraped from the page.
const fallbackImage = "/icon-512.png";
const resolvedImage = ogImage ?? fallbackImage;
const imageUrl = new URL(resolvedImage, baseUrl).toString();
const isLogoImage = resolvedImage === fallbackImage;
const imageWidth = isLogoImage ? "512" : undefined;
const imageHeight = isLogoImage ? "512" : undefined;
const twitterCard = isLogoImage ? "summary" : "summary_large_image";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Postmarked updates" href="/rss.xml" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0D141C" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Postmarked" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Postmarked" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {imageWidth && <meta property="og:image:width" content={imageWidth} />}
    {imageHeight && <meta property="og:image:height" content={imageHeight} />}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <script is:inline src="/postmarked-config.js"></script>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const storedTheme = localStorage.getItem('postmarked-theme');
        const resolvedTheme = storedTheme || (media.matches ? 'dark' : 'light');

        root.dataset.theme = resolvedTheme;
        root.dataset.themePreference = storedTheme || 'system';

        const themeColor = document.querySelector('meta[name="theme-color"]');
        if (themeColor) themeColor.setAttribute('content', resolvedTheme === 'dark' ? '#0D141C' : '#E1D7BE');
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    {!hideNav && <NavBar />}
    <slot />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(err => {
            console.error("SW Registration failed: ", err);
          });
        });
      }
    </script>
    <script>
      fetch('/api/config').then(r => r.json()).then(cfg => {
        if (cfg.app_env !== 'dev') return;
        const banner = document.createElement('div');
        banner.textContent = 'Development mode — not for public use';
        Object.assign(banner.style, {
          position: 'fixed', bottom: '0', left: '0', right: '0', zIndex: '9999',
          background: '#b45309', color: '#fff', textAlign: 'center',
          padding: '6px 12px', fontSize: '13px', fontFamily: 'monospace',
        });
        document.body.appendChild(banner);
      }).catch(() => {});
    </script>
  </body>
</html>

<style>
  html, body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
