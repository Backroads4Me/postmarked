---
const { title } = Astro.props;

// Very basic admin layout. 
// Uses styling matching the `design/styles.css` token ecosystem.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title} — Admin</title>
  <link rel="stylesheet" href="/styles.css">
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#111111" />
  <style>
    body { background: var(--bg); color: var(--fg); font-family: var(--sans); }
    .admin-nav { padding: 1rem 2rem; border-bottom: 1px solid var(--line); display: flex; gap: 2rem; align-items: center; background: var(--surface-1); }
    .admin-nav a { font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.1em; font-size: 11px; }
    .admin-nav a:hover { color: var(--ember); }
  </style>
</head>
<body>
  <nav class="admin-nav">
    <div style="font-weight: 700;">GOODPATH ADMIN</div>
    <a href="/admin">Dashboard</a>
    <a href="/admin/trips">Trips</a>
    <a href="/" target="_blank" style="margin-left: auto;">View Site ↗</a>
  </nav>
  <main class="frame" style="padding-top: 40px; padding-bottom: 80px;">
    <slot />
  </main>
</body>
</html>
