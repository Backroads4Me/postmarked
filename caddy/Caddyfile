{
    # Global options
    auto_https off # For local dev, turn off automatic HTTPS for now or use internal TLS
}

:80 {
    # Static PMTiles serving with range support
    handle /tiles/* {
        root * /pmtiles
        file_server
        header Access-Control-Allow-Origin *
    }

    # API Routing
    handle /api/* {
        reverse_proxy api:8000
    }

    # Media authenticated proxy routing
    handle /media/* {
        reverse_proxy api:8000
    }

    # Everything else falls back to web (Astro SSR)
    handle {
        reverse_proxy web:4321
    }
}
